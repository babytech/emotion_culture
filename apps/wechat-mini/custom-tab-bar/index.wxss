.tab-shell {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 999;
  padding: 0 18rpx calc(12rpx + constant(safe-area-inset-bottom));
  padding: 0 18rpx calc(12rpx + env(safe-area-inset-bottom));
  pointer-events: none;
}

.tab-shell-compact {
  padding-left: 10rpx;
  padding-right: 10rpx;
}

.tab-dock {
  pointer-events: auto;
  min-height: 132rpx;
  border-radius: 26rpx;
  background: rgba(247, 250, 255, 0.9);
  backdrop-filter: blur(16rpx);
  box-shadow: 0 18rpx 40rpx rgba(60, 83, 130, 0.16);
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  align-items: center;
  padding: 12rpx 4rpx 8rpx;
}

.tab-dock-compact {
  min-height: 120rpx;
  padding: 10rpx 2rpx 6rpx;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  color: #7b8cae;
}

.tab-item-active {
  color: #2f6fff;
}

.tab-item-primary .tab-label {
  font-weight: 700;
}

.tab-icon {
  font-size: 22rpx;
  line-height: 1;
  color: #95a5c6;
}

.tab-icon-active {
  color: #2f6fff;
}

.tab-icon-primary {
  font-size: 26rpx;
}

.tab-label {
  font-size: 22rpx;
  line-height: 1;
  letter-spacing: 0.5rpx;
}
