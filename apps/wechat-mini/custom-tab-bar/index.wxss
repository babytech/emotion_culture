.tab-shell {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 999;
  pointer-events: none;
}

.tab-dock {
  pointer-events: auto;
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  align-items: center;
  background:
    linear-gradient(
      180deg,
      rgba(236, 244, 255, 0.38) 0%,
      rgba(236, 244, 255, 0.88) 34%,
      rgba(236, 244, 255, 0.97) 100%
    );
  backdrop-filter: blur(14rpx);
  min-height: 102rpx;
  padding: 10rpx 8rpx calc(12rpx + env(safe-area-inset-bottom));
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2rpx;
  color: #7c8ead;
}

.tab-item-active {
  color: #2f6fff;
}

.tab-icon {
  width: 40rpx;
  height: 40rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  background: transparent;
  color: #6f83aa;
}

.tab-icon-active {
  color: #2f6fff;
}

.tab-label {
  font-size: 20rpx;
  line-height: 1.2;
  letter-spacing: 0.3rpx;
}

.tab-item-active .tab-label {
  font-weight: 700;
}

.tab-indicator {
  margin-top: 4rpx;
  width: 20rpx;
  height: 5rpx;
  border-radius: 999rpx;
  background: transparent;
}

.tab-item-active .tab-indicator {
  background: linear-gradient(90deg, #2f6fff, #6ea3ff);
}

.tab-shell-compact .tab-dock {
  min-height: 96rpx;
  padding-left: 4rpx;
  padding-right: 4rpx;
}

.tab-shell-compact .tab-icon {
  width: 36rpx;
  height: 36rpx;
  font-size: 22rpx;
}

.tab-shell-compact .tab-label {
  font-size: 19rpx;
}
