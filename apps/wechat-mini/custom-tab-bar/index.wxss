.tab-shell {
  position: fixed;
  left: 0;
  right: 0;
  z-index: 999;
  pointer-events: none;
}

.tab-dock {
  pointer-events: auto;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  align-items: center;
  background:
    linear-gradient(
      180deg,
      rgba(250, 252, 255, 0.24) 0%,
      rgba(238, 246, 255, 0.84) 34%,
      rgba(235, 245, 255, 0.96) 100%
    );
  backdrop-filter: blur(16rpx);
  min-height: 102rpx;
  padding: 10rpx 8rpx calc(12rpx + env(safe-area-inset-bottom));
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
  color: #7084a8;
}

.tab-item-active {
  color: #2e6dff;
}

.tab-label {
  font-size: 24rpx;
  line-height: 1.2;
  letter-spacing: 0.8rpx;
}

.tab-item-active .tab-label {
  font-weight: 700;
}

.tab-indicator {
  margin-top: 4rpx;
  width: 20rpx;
  height: 5rpx;
  border-radius: 999rpx;
  background: transparent;
}

.tab-item-active .tab-indicator {
  background: linear-gradient(90deg, #2e6dff, #43c9d5);
}

.tab-shell-compact .tab-dock {
  min-height: 96rpx;
  padding-left: 4rpx;
  padding-right: 4rpx;
}

.tab-shell-compact .tab-label {
  font-size: 22rpx;
}
