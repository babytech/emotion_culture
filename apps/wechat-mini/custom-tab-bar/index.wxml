<view class="tab-shell {{isCompact ? 'tab-shell-compact' : ''}}" style="bottom: {{keyboardHeight}}px;">
  <view class="tab-dock {{isCompact ? 'tab-dock-compact' : ''}}">
    <view
      wx:for="{{items}}"
      wx:key="pagePath"
      class="tab-item {{selected === item.pagePath ? 'tab-item-active' : ''}} {{item.isPrimary ? 'tab-item-primary' : ''}}"
      data-url="{{item.pagePath}}"
      bindtap="handleTabTap"
    >
      <view class="tab-icon {{selected === item.pagePath ? 'tab-icon-active' : ''}} {{item.isPrimary ? 'tab-icon-primary' : ''}}">
        {{item.isPrimary ? "◉" : "○"}}
      </view>
      <view class="tab-label">{{item.text}}</view>
    </view>
  </view>
</view>
