<view class="container page-root">
  <view wx:if="{{!hasData}}" class="error card">
    <view>{{errorMsg}}</view>
    <button class="btn btn-secondary back-btn" bindtap="goBack">返回</button>
  </view>

  <block wx:if="{{hasData}}">
    <view class="card header">
      <view class="header-head">
        <view>
          <view class="header-kicker">Share Studio</view>
          <view class="title">分享卡片导出</view>
        </view>
        <view class="header-stamp">可保存</view>
      </view>
      <view class="sub text-muted">生成基础分享图，可保存到相册后再转发给家人或朋友。</view>
      <view class="meta-grid">
        <view class="meta-pill">主情绪：{{payload.emotionLabel}}</view>
        <view class="meta-pill">连续打卡：{{payload.currentStreak}} 天</view>
        <view class="meta-pill">本月打卡：{{payload.monthCheckinDays}} 天</view>
      </view>
      <view wx:if="{{generatedAtText}}" class="meta text-muted">生成时间：{{generatedAtText}}</view>
    </view>

    <view class="render-canvas-wrap">
      <canvas canvas-id="shareCardCanvas" class="render-canvas" />
    </view>

    <view class="card content-wrap">
      <view class="content-kicker">Card Copy</view>
      <view class="content-line">
        主情绪：{{payload.emotionLabel}}
        <text wx:if="{{payload.emotionCode}}">（{{payload.emotionCode}}）</text>
      </view>
      <view wx:if="{{triggerTagsText}}" class="content-line">触发标签：{{triggerTagsText}}</view>

      <view class="content-section-title">情绪概述</view>
      <view class="content-text">{{payload.emotionOverview || "暂无情绪概述。"}}</view>

      <view class="content-section-title">诗词回应</view>
      <view class="content-sub">{{payload.poet || "诗词回应"}}</view>
      <view class="content-text">{{payload.poemText || "暂无诗词内容。"}}</view>

      <view class="content-section-title">国潮慰藉</view>
      <view class="content-sub">{{payload.guochaoName || "国潮伙伴"}}</view>
      <view class="content-text">{{payload.comfort || "暂无慰藉内容。"}}</view>

      <view class="content-section-title">今日建议</view>
      <view class="content-text">{{payload.dailySuggestion || "保持稳定作息，照顾好自己。"}}</view>
    </view>

    <view wx:if="{{payload.userImageUrl}}" class="card preview-wrap">
      <view class="preview-head" bindtap="toggleSelfiePreview">
        <view class="preview-title">用户自拍图片预览</view>
        <view class="preview-toggle">{{selfiePreviewExpanded ? '收起' : '展开'}}</view>
      </view>
      <view wx:if="{{selfiePreviewExpanded}}" class="selfie-box">
        <image class="selfie-image" mode="aspectFit" src="{{payload.userImageUrl}}" />
      </view>
    </view>

    <view wx:if="{{imageTempPath}}" class="card preview-wrap">
      <view class="preview-head" bindtap="toggleGeneratedPreview">
        <view class="preview-title">已生成卡片预览</view>
        <view class="preview-toggle">{{generatedPreviewExpanded ? '收起' : '展开'}}</view>
      </view>
      <image wx:if="{{generatedPreviewExpanded}}" class="preview-image" mode="widthFix" src="{{imageTempPath}}" />
    </view>

    <view wx:if="{{errorMsg}}" class="error card">{{errorMsg}}</view>
    <view wx:if="{{saveStatus}}" class="status card">{{saveStatus}}</view>

    <view class="card action-panel">
      <view class="content-kicker">Export Actions</view>
      <view class="action-grid">
        <button
          class="btn btn-primary action-btn action-btn-grid"
          loading="{{isGenerating}}"
          disabled="{{isGenerating}}"
          bindtap="generateCard"
        >
          生成分享卡片
        </button>
        <button class="btn btn-secondary action-btn action-btn-grid" bindtap="saveCardToAlbum">保存到相册</button>
        <button class="btn btn-secondary action-btn action-btn-grid" bindtap="previewGeneratedCard">预览生成图片</button>
        <button class="btn btn-secondary action-btn action-btn-grid" open-type="share">转发小程序</button>
      </view>
    </view>
  </block>
</view>
