.page-root {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.share-hero {
  position: relative;
  overflow: hidden;
  padding: 30rpx 24rpx 26rpx;
  background:
    radial-gradient(circle at 90% 0%, rgba(255, 255, 255, 0.36), transparent 26%),
    linear-gradient(135deg, rgba(147, 37, 29, 0.17), rgba(211, 160, 91, 0.2)),
    var(--card);
}

.share-hero::after {
  content: "";
  position: absolute;
  right: -42rpx;
  top: -38rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 999rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.28), transparent 70%);
}

.share-hero-head {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.share-hero-copy {
  flex: 1;
  min-width: 0;
}

.share-hero-kicker,
.share-section-kicker {
  font-size: 21rpx;
  letter-spacing: 3rpx;
  text-transform: uppercase;
  color: #95674b;
}

.share-hero-title {
  margin-top: 10rpx;
  font-size: 42rpx;
  line-height: 1.18;
  font-weight: 700;
}

.share-hero-sub {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.68;
}

.share-hero-badge {
  position: relative;
  z-index: 1;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 251, 243, 0.86);
  border: 2rpx solid rgba(147, 37, 29, 0.1);
  font-size: 22rpx;
  color: #7d5640;
  white-space: nowrap;
}

.share-hero-badge-live {
  background: rgba(255, 241, 237, 0.9);
  color: #952d26;
  border-color: rgba(161, 38, 27, 0.2);
}

.share-meta-grid {
  position: relative;
  z-index: 1;
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.share-meta-pill,
.share-step {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 250, 243, 0.82);
  border: 2rpx solid rgba(147, 37, 29, 0.08);
  color: #6f4f39;
  font-size: 22rpx;
}

.share-generated-at {
  position: relative;
  z-index: 1;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
}

.share-step-row {
  position: relative;
  z-index: 1;
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.render-canvas-wrap {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 0;
  height: 0;
  overflow: hidden;
  pointer-events: none;
}

.render-canvas {
  width: 720px;
  height: 1600px;
}

.share-content {
  padding: 24rpx 20rpx;
  background:
    linear-gradient(180deg, rgba(255, 251, 245, 0.98), rgba(248, 241, 232, 0.96));
}

.share-content-line {
  margin-top: 8rpx;
  font-size: 26rpx;
  line-height: 1.68;
  color: #5c4636;
}

.share-section-title {
  margin-top: 18rpx;
  font-size: 32rpx;
  line-height: 1.3;
  color: #7a4f2c;
  font-weight: 700;
}

.share-content-sub {
  margin-top: 8rpx;
  font-size: 26rpx;
  line-height: 1.5;
  color: #8b725e;
}

.share-content-text {
  margin-top: 8rpx;
  font-size: 30rpx;
  line-height: 1.74;
  color: #3f2f22;
  white-space: pre-wrap;
  word-break: break-all;
}

.share-preview-card {
  padding: 22rpx 18rpx;
}

.share-preview-selfie {
  background:
    radial-gradient(circle at 0% 0%, rgba(147, 37, 29, 0.07), transparent 26%),
    linear-gradient(180deg, rgba(255, 251, 246, 0.96), rgba(247, 241, 233, 0.94));
}

.share-preview-generated {
  background:
    radial-gradient(circle at 100% 0%, rgba(211, 160, 91, 0.1), transparent 26%),
    linear-gradient(180deg, rgba(255, 251, 245, 0.98), rgba(248, 241, 232, 0.96));
}

.share-preview-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.share-preview-title {
  font-size: 30rpx;
  font-weight: 700;
}

.share-preview-sub {
  margin-bottom: 12rpx;
  font-size: 24rpx;
  line-height: 1.68;
  color: #796758;
}

.share-preview-toggle {
  font-size: 24rpx;
  color: #7f4f27;
  background: linear-gradient(135deg, rgba(255, 250, 242, 0.94), rgba(247, 230, 199, 0.92));
  border-radius: 999rpx;
  padding: 6rpx 14rpx;
  border: 2rpx solid rgba(147, 37, 29, 0.08);
}

.preview-image {
  width: 100%;
  border-radius: 22rpx;
  background: #f5efe4;
}

.selfie-box {
  width: 100%;
  height: 620rpx;
  border-radius: 14rpx;
  border: 2rpx solid rgba(161, 38, 27, 0.12);
  background: #f5efe4;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.selfie-image {
  width: 100%;
  height: 100%;
}

.share-action-panel {
  padding: 24rpx 20rpx;
  background:
    radial-gradient(circle at 100% 0%, rgba(200, 68, 52, 0.1), transparent 30%),
    linear-gradient(180deg, rgba(255, 250, 243, 0.98), rgba(248, 241, 231, 0.96));
}

.share-action-note {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.68;
}

.share-action-grid {
  margin-top: 14rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.share-action-btn {
  min-height: 82rpx;
  line-height: 82rpx;
  font-size: 27rpx !important;
  padding: 0 12rpx !important;
  color: #5f4328 !important;
}

.share-action-btn-main {
  box-shadow: 0 12rpx 24rpx rgba(157, 102, 29, 0.16);
}

.share-timeline-tip {
  margin-top: 14rpx;
  padding: 16rpx 16rpx 18rpx;
  border-radius: 20rpx;
  background: rgba(255, 248, 237, 0.86);
  border: 2rpx solid rgba(147, 37, 29, 0.08);
}

.share-timeline-tip-title {
  font-size: 25rpx;
  font-weight: 700;
  color: #7a4f2c;
}

.share-timeline-tip-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.65;
  color: #755f4f;
}

.status,
.share-notice {
  padding: 20rpx;
  font-size: 25rpx;
}

.share-notice-success {
  color: var(--success-ink);
  background: var(--success-bg);
  border-color: rgba(15, 108, 77, 0.2);
}

.error,
.share-notice-error {
  padding: 20rpx;
  border-color: rgba(180, 33, 33, 0.24);
  color: var(--danger-ink);
  background: var(--danger-bg);
}

.share-notice-info {
  color: #6f5441;
  background: rgba(255, 248, 237, 0.86);
  border-color: rgba(147, 37, 29, 0.12);
}

.share-empty {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.back-btn {
  margin-top: 8rpx;
}

.share-action-panel .btn-primary.share-action-btn {
  color: #5f4328 !important;
  background: linear-gradient(135deg, #fff8ec 0%, #f4ddb2 100%) !important;
  border-color: rgba(146, 51, 36, 0.12) !important;
}

@media (max-width: 360px) {
  .share-hero-title {
    font-size: 38rpx;
  }

  .share-section-title {
    font-size: 30rpx;
  }

  .share-content-text {
    font-size: 28rpx;
  }
}
