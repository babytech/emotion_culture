.page-root {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.header {
  padding: 28rpx 24rpx;
  background:
    radial-gradient(circle at 85% 14%, rgba(255, 255, 255, 0.42), transparent 24%),
    linear-gradient(135deg, rgba(147, 37, 29, 0.16), rgba(211, 160, 91, 0.18)),
    var(--card);
}

.header-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.header-kicker {
  font-size: 21rpx;
  letter-spacing: 3rpx;
  text-transform: uppercase;
  color: #95674b;
  margin-bottom: 8rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
}

.sub {
  margin-top: 16rpx;
  font-size: 24rpx;
  line-height: 1.72;
}

.header-stamp {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 250, 242, 0.78);
  border: 2rpx solid rgba(147, 37, 29, 0.1);
  font-size: 22rpx;
  color: #7d5640;
  white-space: nowrap;
}

.meta-grid {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.meta-pill {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 250, 243, 0.78);
  border: 2rpx solid rgba(147, 37, 29, 0.08);
  color: #684d3a;
  font-size: 23rpx;
}

.meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #4a382a;
}

.export-steps {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.export-step {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 250, 243, 0.82);
  border: 2rpx solid rgba(147, 37, 29, 0.08);
  color: #734c35;
  font-size: 22rpx;
}

.render-canvas-wrap {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 0;
  height: 0;
  overflow: hidden;
  pointer-events: none;
}

.render-canvas {
  width: 720px;
  height: 1600px;
}

.content-wrap {
  padding: 24rpx 20rpx;
}

.content-paper {
  background:
    linear-gradient(180deg, rgba(255, 251, 245, 0.98), rgba(248, 241, 232, 0.96));
}

.content-kicker {
  font-size: 21rpx;
  letter-spacing: 3rpx;
  text-transform: uppercase;
  color: #95674b;
  margin-bottom: 8rpx;
}

.content-line {
  margin-top: 6rpx;
  font-size: 26rpx;
  line-height: 1.68;
  color: #5c4636;
}

.content-section-title {
  margin-top: 18rpx;
  font-size: 32rpx;
  line-height: 1.3;
  color: #7a4f2c;
  font-weight: 700;
}

.content-sub {
  margin-top: 8rpx;
  font-size: 26rpx;
  line-height: 1.5;
  color: #8b725e;
}

.content-text {
  margin-top: 8rpx;
  font-size: 30rpx;
  line-height: 1.74;
  color: #3f2f22;
  white-space: pre-wrap;
  word-break: break-all;
}

.preview-wrap {
  padding: 22rpx 18rpx;
}

.preview-selfie {
  background:
    radial-gradient(circle at 0% 0%, rgba(147, 37, 29, 0.06), transparent 24%),
    linear-gradient(180deg, rgba(255, 251, 246, 0.96), rgba(247, 241, 233, 0.94));
}

.preview-generated {
  background:
    radial-gradient(circle at 100% 0%, rgba(211, 160, 91, 0.1), transparent 24%),
    linear-gradient(180deg, rgba(255, 251, 245, 0.98), rgba(248, 241, 232, 0.96));
}

.preview-title {
  font-size: 30rpx;
  font-weight: 700;
}

.preview-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.preview-sub {
  margin-bottom: 12rpx;
  font-size: 24rpx;
  line-height: 1.68;
  color: #796758;
}

.preview-toggle {
  font-size: 24rpx;
  color: #7f4f27;
  background: linear-gradient(135deg, rgba(255, 250, 242, 0.94), rgba(247, 230, 199, 0.92));
  border-radius: 999rpx;
  padding: 6rpx 14rpx;
  border: 2rpx solid rgba(147, 37, 29, 0.08);
}

.preview-image {
  width: 100%;
  border-radius: 22rpx;
  background: #f5efe4;
}

.selfie-box {
  width: 100%;
  height: 620rpx;
  border-radius: 14rpx;
  border: 1rpx solid rgba(161, 38, 27, 0.14);
  background: #f5efe4;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.selfie-image {
  width: 100%;
  height: 100%;
}

.action-panel {
  padding: 24rpx 20rpx;
  background:
    radial-gradient(circle at 100% 0%, rgba(200, 68, 52, 0.1), transparent 28%),
    linear-gradient(180deg, rgba(255, 250, 243, 0.98), rgba(248, 241, 231, 0.96));
}

.action-note {
  margin-top: 4rpx;
  font-size: 24rpx;
  line-height: 1.68;
}

.timeline-hint {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.68;
  color: #7b6657;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 12rpx;
}

.action-grid-full {
  grid-column: 1 / -1;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 88rpx;
  line-height: 88rpx;
  padding: 0 !important;
  font-size: 30rpx;
  text-align: center;
  font-weight: 700;
}

.action-panel .btn-primary {
  color: #fff !important;
  background: linear-gradient(135deg, #9f2a1f 0%, #c84434 100%) !important;
  border: 2rpx solid rgba(125, 28, 21, 0.2) !important;
}

.action-panel .btn-secondary {
  color: #5f4328 !important;
  background: linear-gradient(135deg, #fff8ec 0%, #f4ddb2 100%) !important;
  border: 2rpx solid rgba(146, 51, 36, 0.12) !important;
}

.action-btn-grid {
  min-height: 82rpx;
  line-height: 82rpx;
  font-size: 27rpx;
}

.status {
  padding: 20rpx;
  color: var(--success-ink);
  background: var(--success-bg);
  border-color: rgba(15, 108, 77, 0.2);
  font-size: 25rpx;
}

.error {
  padding: 20rpx;
  border-color: rgba(180, 33, 33, 0.24);
  color: var(--danger-ink);
  background: var(--danger-bg);
}

.back-btn {
  margin-top: 16rpx;
}
