.page-root {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.header {
  padding: 24rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
}

.sub {
  margin-top: 8rpx;
  font-size: 24rpx;
}

.meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #4a382a;
}

.render-canvas-wrap {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 0;
  height: 0;
  overflow: hidden;
  pointer-events: none;
}

.render-canvas {
  width: 720px;
  height: 1600px;
}

.content-wrap {
  padding: 20rpx;
}

.content-line {
  margin-top: 6rpx;
  font-size: 26rpx;
  line-height: 1.55;
  color: #5c4636;
}

.content-section-title {
  margin-top: 18rpx;
  font-size: 36rpx;
  line-height: 1.3;
  color: #7a4f2c;
  font-weight: 700;
}

.content-sub {
  margin-top: 8rpx;
  font-size: 26rpx;
  line-height: 1.5;
  color: #8b725e;
}

.content-text {
  margin-top: 8rpx;
  font-size: 30rpx;
  line-height: 1.6;
  color: #3f2f22;
  white-space: pre-wrap;
  word-break: break-all;
}

.preview-wrap {
  padding: 18rpx;
}

.preview-title {
  font-size: 28rpx;
  font-weight: 600;
}

.preview-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.preview-toggle {
  font-size: 24rpx;
  color: #7f4f27;
  background: #f4e5cf;
  border-radius: 999rpx;
  padding: 6rpx 14rpx;
}

.preview-image {
  width: 100%;
  border-radius: 14rpx;
  background: #f5efe4;
}

.selfie-box {
  width: 100%;
  height: 620rpx;
  border-radius: 14rpx;
  border: 1rpx solid rgba(161, 38, 27, 0.14);
  background: #f5efe4;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.selfie-image {
  width: 100%;
  height: 100%;
}

.action-btn {
  width: 100%;
  min-height: 88rpx;
  line-height: 88rpx;
  padding: 0 !important;
  font-size: 30rpx;
  text-align: center;
  font-weight: 700;
}

.status {
  padding: 20rpx;
  color: #0f6c4d;
  background: #e8f7ee;
  border-color: rgba(15, 108, 77, 0.2);
  font-size: 25rpx;
}

.error {
  padding: 20rpx;
  border-color: rgba(180, 33, 33, 0.35);
  color: #8f1f1f;
  background: #fff0ef;
}

.back-btn {
  margin-top: 16rpx;
}
