<view class="container page-root">
  <view class="header card">
    <view class="header-title">历史记录</view>
    <view class="header-sub text-muted">统一时间线展示情绪分析与伴学小测，不保存原始自拍与录音文件。</view>
    <view class="header-actions">
      <button class="btn btn-secondary mini-btn" bindtap="loadTimeline" loading="{{isLoading}}" disabled="{{isLoading}}">
        刷新
      </button>
      <button class="btn mini-btn" bindtap="goSettings">设置</button>
    </view>
  </view>

  <view class="filter-row card">
    <view
      wx:for="{{filterTabs}}"
      wx:key="key"
      class="filter-chip {{timelineType === item.key ? 'filter-chip-active' : ''}}"
      data-type="{{item.key}}"
      bindtap="handleFilterChange"
    >
      {{item.label}}
    </view>
  </view>

  <view wx:if="{{errorMsg}}" class="error card">
    {{errorMsg}}
  </view>

  <view wx:if="{{isLoading}}" class="loading card">
    正在加载历史记录...
  </view>

  <view wx:elif="{{!items.length}}" class="empty card">
    <view class="empty-title">暂无历史记录</view>
    <view class="text-muted">完成一次情绪分析或伴学小测后会在这里显示。</view>
  </view>

  <block wx:else>
    <view class="summary text-muted">当前筛选共 {{total}} 条</view>
    <view
      wx:for="{{items}}"
      wx:key="timelineId"
      class="item card"
      bindtap="openDetail"
      data-type="{{item.itemType}}"
      data-emotion-id="{{item.emotionHistoryId}}"
      data-quiz-id="{{item.quizRecordId}}"
    >
      <view class="item-head">
        <view class="item-time">{{item.displayTime}}</view>
        <view class="item-mail {{item.itemType === 'quiz' ? 'sent' : 'not-sent'}}">
          {{item.itemType === 'quiz' ? '伴学小测' : '情绪分析'}}
        </view>
      </view>

      <view class="item-line">
        <text class="label">标题：</text>
        <text>{{item.title}}</text>
      </view>
      <view wx:if="{{item.subtitle}}" class="overview text-muted">{{item.subtitle}}</view>
      <view wx:if="{{item.itemType === 'quiz'}}" class="item-line">
        <text class="label">小测成绩：</text>
        <text>{{item.quizScore}} 分（{{item.quizGrade}}）</text>
      </view>

      <view class="item-actions">
        <button class="btn btn-secondary mini-btn">{{item.itemType === "quiz" ? "查看小测详情" : "查看详情"}}</button>
        <button
          wx:if="{{item.itemType === 'emotion'}}"
          class="btn mini-btn"
          catchtap="handleDeleteItem"
          data-type="{{item.itemType}}"
          data-emotion-id="{{item.emotionHistoryId}}"
        >
          删除
        </button>
      </view>
    </view>
  </block>

  <button
    class="btn clear-btn"
    bindtap="handleClearAll"
    loading="{{isClearing}}"
    disabled="{{isClearing}}"
  >
    清空情绪历史
  </button>
</view>
