.favorites-page {
  gap: 20rpx;
}

.favorites-hero {
  padding-bottom: 26rpx;
}

.favorites-hero-badge {
  position: relative;
  z-index: 1;
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 18rpx 12rpx 16rpx;
  background:
    linear-gradient(135deg, rgba(255, 252, 247, 0.94), rgba(250, 237, 216, 0.88));
  border: 2rpx solid rgba(147, 37, 29, 0.08);
  box-shadow: 0 10rpx 20rpx rgba(124, 76, 40, 0.08);
  color: #7d5640;
}

.favorites-hero-badge-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, rgba(211, 160, 91, 0.98), rgba(199, 128, 53, 0.92));
  box-shadow: 0 0 0 6rpx rgba(211, 160, 91, 0.12);
}

.favorites-hero-badge-text {
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.favorites-chip-row {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.favorites-chip {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 251, 243, 0.82);
  border: 2rpx solid rgba(147, 37, 29, 0.08);
  font-size: 23rpx;
  color: #6b4f3b;
}

.favorites-tabs {
  margin-top: 20rpx;
  display: flex;
  gap: 10rpx;
}

.favorites-tab {
  flex: 1;
  text-align: center;
  border-radius: 999rpx;
  border: 2rpx solid rgba(161, 38, 27, 0.12);
  background: rgba(255, 248, 238, 0.92);
  color: #6d5844;
  font-size: 24rpx;
  padding: 14rpx 8rpx;
  box-shadow: 0 8rpx 18rpx rgba(124, 76, 40, 0.05);
}

.favorites-tab-active {
  background: linear-gradient(135deg, rgba(247, 226, 191, 0.98), rgba(238, 194, 122, 0.92));
  color: #603f24;
  border-color: rgba(216, 162, 77, 0.42);
  font-weight: 700;
}

.favorites-feedback-card,
.favorites-error-card {
  padding: 24rpx 22rpx;
  border-radius: 26rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.favorites-feedback-card {
  background:
    linear-gradient(135deg, rgba(255, 251, 245, 0.98), rgba(250, 240, 226, 0.92));
}

.favorites-error-card {
  border-color: rgba(180, 33, 33, 0.18);
  background: linear-gradient(135deg, rgba(255, 245, 242, 0.98), rgba(255, 236, 232, 0.94));
}

.favorites-feedback-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #5c3520;
}

.favorites-feedback-body {
  font-size: 24rpx;
  line-height: 1.7;
  color: #7d6959;
}

.favorites-inline-btn {
  width: 220rpx;
}

.favorites-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.favorites-item-card {
  padding: 22rpx;
  background:
    radial-gradient(circle at 100% 0%, rgba(211, 160, 91, 0.14), transparent 26%),
    linear-gradient(135deg, rgba(255, 251, 245, 0.98), rgba(250, 240, 226, 0.92));
  border-radius: 26rpx;
  border: 2rpx solid rgba(147, 37, 29, 0.08);
  box-shadow: 0 12rpx 24rpx rgba(124, 76, 40, 0.08);
}

.favorites-item-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 10rpx;
}

.type-badge {
  border-radius: 999rpx;
  padding: 6rpx 12rpx;
  font-size: 22rpx;
  background: #efe7da;
  color: #614f3d;
}

.type-poem {
  background: #f4e5cf;
  color: #835628;
}

.type-guochao {
  background: #e8f7ee;
  color: #0f6c4d;
}

.favorites-item-time {
  font-size: 22rpx;
  color: #8b796b;
}

.favorites-item-title {
  margin-top: 10rpx;
  font-size: 30rpx;
  line-height: 1.55;
  color: #3f2f22;
}

.favorites-item-sub {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #8a7768;
}

.favorites-item-summary {
  margin-top: 10rpx;
  font-size: 26rpx;
  line-height: 1.65;
  color: #4b392a;
  display: -webkit-box;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
}

.favorites-item-foot {
  margin-top: 16rpx;
  padding-top: 14rpx;
  border-top: 2rpx solid rgba(147, 37, 29, 0.06);
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 16rpx;
}

.mini-btn {
  margin-top: 14rpx;
  min-height: 66rpx;
  line-height: 66rpx;
  padding: 0 24rpx !important;
  font-size: 24rpx !important;
}

.favorites-item-btn {
  width: 220rpx;
  margin-top: 0;
}

.action-btn {
  width: 100%;
  min-height: 86rpx;
  line-height: 86rpx;
  padding: 0 !important;
  font-size: 30rpx;
  text-align: center;
  font-weight: 700;
}

.favorites-action-btn {
  margin-top: 2rpx;
}
