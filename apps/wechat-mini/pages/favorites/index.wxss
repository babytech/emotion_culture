.favorites-page {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding-bottom: 148rpx;
}

.favorites-head-card {
  padding: 18rpx;
  border: none;
}

.favorites-head-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.favorites-head-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #24334f;
}

.favorites-head-meta {
  font-size: 23rpx;
  color: #6b7ea4;
}

.favorites-tabs {
  margin-top: 12rpx;
  display: flex;
  gap: 8rpx;
}

.favorites-tab {
  flex: 1;
  text-align: center;
  border-radius: 999rpx;
  border: 2rpx solid rgba(84, 111, 164, 0.12);
  background: #f4f8ff;
  color: #5f739a;
  font-size: 24rpx;
  padding: 12rpx 8rpx;
}

.favorites-tab-active {
  background: linear-gradient(135deg, #e7f0ff, #d6e6ff);
  color: #2f63c6;
  border-color: rgba(52, 94, 182, 0.28);
  font-weight: 700;
}

.favorites-feedback-card,
.favorites-error-card {
  padding: 18rpx;
  border: none;
}

.favorites-feedback-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #2d3d5e;
}

.favorites-feedback-body {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.6;
  color: #62759a;
}

.favorites-inline-btn {
  margin-top: 10rpx;
  width: 180rpx;
}

.favorites-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.favorites-item-card {
  padding: 16rpx;
  border: none;
  background: #ffffff;
}

.favorites-item-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 8rpx;
}

.type-badge {
  border-radius: 999rpx;
  padding: 6rpx 12rpx;
  font-size: 21rpx;
  background: #edf3ff;
  color: #4b6faf;
}

.type-poem {
  background: #e7f5ef;
  color: #2d7a59;
}

.type-guochao {
  background: #fff4da;
  color: #a9741e;
}

.favorites-item-time {
  font-size: 21rpx;
  color: #8798b8;
}

.favorites-item-title {
  margin-top: 8rpx;
  font-size: 28rpx;
  line-height: 1.5;
  color: #2f4061;
}

.favorites-item-sub {
  margin-top: 5rpx;
  font-size: 22rpx;
  color: #7284a7;
}

.favorites-item-summary {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.62;
  color: #5c6f95;
  display: -webkit-box;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.favorites-item-foot {
  margin-top: 10rpx;
  display: flex;
  justify-content: flex-end;
}

.mini-btn {
  min-height: 62rpx;
  line-height: 62rpx;
  padding: 0 20rpx !important;
  font-size: 22rpx !important;
}

.favorites-item-btn {
  width: 120rpx;
}

.action-btn {
  width: 100%;
  min-height: 78rpx;
  line-height: 78rpx;
  padding: 0 !important;
  font-size: 27rpx;
}

.favorites-action-btn {
  margin-top: 2rpx;
}
