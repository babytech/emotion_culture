.quiz-page {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.quiz-hero {
  padding: 20rpx;
  border: none;
  background:
    radial-gradient(circle at 100% 0%, rgba(149, 193, 255, 0.3), transparent 38%),
    linear-gradient(135deg, #ffffff, #eef5ff);
}

.quiz-kicker {
  font-size: 22rpx;
  color: #6281b6;
  letter-spacing: 2rpx;
}

.quiz-title {
  margin-top: 8rpx;
  font-size: 36rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #22324f;
}

.quiz-sub {
  margin-top: 8rpx;
  font-size: 23rpx;
  color: #607398;
}

.quiz-meta-row {
  margin-top: 12rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.status-chip {
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(80, 122, 204, 0.14);
  color: #4a6faf;
  font-size: 22rpx;
}

.quiz-progress-track {
  margin-top: 12rpx;
  width: 100%;
  height: 10rpx;
  border-radius: 999rpx;
  background: #dfe9ff;
  overflow: hidden;
}

.quiz-progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #2f6fff, #6aa2ff);
  transition: width 0.2s ease;
}

.loading-card,
.error-card {
  padding: 18rpx;
  border: none;
}

.error-card {
  color: #9e3d4d;
  background: #fff3f5;
}

.error-text {
  font-size: 23rpx;
  line-height: 1.55;
}

.error-retry-btn {
  margin-top: 10rpx;
  width: 220rpx;
  min-height: 64rpx;
  line-height: 64rpx;
  padding: 0 18rpx !important;
  font-size: 22rpx !important;
}

.question-card {
  padding: 18rpx;
  border: none;
}

.question-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
}

.question-index {
  font-size: 25rpx;
  font-weight: 700;
  color: #2b3f61;
}

.question-type {
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #e8f0ff;
  color: #466fb5;
  font-size: 21rpx;
}

.question-stem {
  margin-top: 12rpx;
  font-size: 28rpx;
  line-height: 1.62;
  color: #263753;
}

.option-list {
  margin-top: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.option-chip {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  padding: 14rpx;
  border-radius: 14rpx;
  border: 2rpx solid rgba(96, 123, 173, 0.16);
  background: #f6f9ff;
}

.option-chip-active {
  border-color: rgba(47, 111, 255, 0.42);
  background: #eaf1ff;
}

.option-item {
  width: 38rpx;
  height: 38rpx;
  border-radius: 999rpx;
  background: rgba(76, 116, 189, 0.14);
  color: #355a9d;
  font-size: 21rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.option-content {
  flex: 1;
  font-size: 25rpx;
  line-height: 1.58;
  color: #364d72;
}

.fill-list {
  margin-top: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.fill-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.fill-label {
  width: 84rpx;
  font-size: 22rpx;
  color: #6c80a7;
}

.fill-input {
  flex: 1;
  height: 72rpx;
  border-radius: 12rpx;
  border: 2rpx solid rgba(96, 123, 173, 0.16);
  background: #f8fbff;
  padding: 0 14rpx;
  font-size: 26rpx;
  color: #2f4568;
}

.navigator-card {
  padding: 16rpx;
  border: none;
}

.dot-scroll {
  width: 100%;
  white-space: nowrap;
}

.dot-row {
  display: inline-flex;
  gap: 8rpx;
}

.dot-item {
  min-width: 54rpx;
  height: 54rpx;
  padding: 0 8rpx;
  border-radius: 14rpx;
  background: #edf3ff;
  color: #6e83aa;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dot-item-done {
  color: #2f66c6;
}

.dot-item-active {
  background: #2f6fff;
  color: #ffffff;
}

.nav-row {
  margin-top: 12rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx;
}

.nav-btn {
  width: 100%;
  min-height: 70rpx;
  line-height: 70rpx;
  padding: 0 !important;
  font-size: 24rpx !important;
}

.quiz-action-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx;
}
