<view class="container quiz-page">
  <view class="card quiz-hero">
    <view class="quiz-kicker">伴学小测</view>
    <view class="quiz-title">{{paperTitle || (selectedCourseLabel + "伴学小测")}}</view>
    <view class="quiz-sub">先选科目和时长，再开始测试。</view>

    <view class="quiz-config-grid">
      <view class="quiz-config-item">
        <view class="quiz-config-label">测试科目</view>
        <picker
          class="quiz-picker"
          mode="selector"
          range="{{courseOptions}}"
          range-key="label"
          value="{{selectedCourseIndex}}"
          disabled="{{hasStarted}}"
          bindchange="handleCourseChange"
        >
          <view class="quiz-picker-value">{{selectedCourseLabel}}</view>
        </picker>
      </view>
      <view class="quiz-config-item">
        <view class="quiz-config-label">测试时长</view>
        <picker
          class="quiz-picker"
          mode="selector"
          range="{{durationOptions}}"
          value="{{selectedDurationIndex}}"
          disabled="{{hasStarted}}"
          bindchange="handleDurationChange"
        >
          <view class="quiz-picker-value">{{selectedDurationLabel}}</view>
        </picker>
      </view>
    </view>

    <view class="quiz-meta-row">
      <view wx:if="{{hasStarted}}" class="status-chip status-chip-countdown">倒计时 {{remainingText}}</view>
      <view wx:if="{{hasStarted}}" class="status-chip">进度 {{answeredQuestions}} / {{totalQuestions}}</view>
      <view wx:if="{{hasStarted}}" class="status-chip">未答 {{unansweredQuestions}}</view>
      <view wx:if="{{loadedFromCache}}" class="status-chip">缓存题库</view>
      <view wx:if="{{isRefreshingPaper}}" class="status-chip">题库更新中</view>
      <view wx:if="{{draftRecovered}}" class="status-chip">已恢复草稿</view>
      <view wx:if="{{paperVersion}}" class="status-chip">版本 {{paperVersion}}</view>
    </view>
    <view wx:if="{{hasStarted}}" class="quiz-progress-track">
      <view class="quiz-progress-fill" style="width: {{progressPercent}}%;"></view>
    </view>
  </view>

  <view wx:if="{{errorMsg}}" class="card error-card">
    <view class="error-text">{{errorMsg}}</view>
    <button
      class="btn btn-secondary error-retry-btn"
      bindtap="handleRetryLoadPaper"
      disabled="{{isLoading || isRefreshingPaper}}"
    >
      重试加载
    </button>
  </view>
  <view wx:if="{{hasStarted && isLoading && !currentQuestion}}" class="card loading-card">试卷加载中...</view>

  <view wx:if="{{!hasStarted}}" class="card quiz-waiting-card">
    <view class="quiz-waiting-title">准备开始测试</view>
    <view class="quiz-waiting-text">点击底部“开始测试”后才会显示第一题。</view>
  </view>

  <block wx:if="{{hasStarted && !isLoading && currentQuestion}}">
    <view class="card question-card">
      <view class="question-head">
        <view class="question-index">第 {{currentIndex + 1}} / {{totalQuestions}} 题</view>
        <view class="question-type">
          {{currentQuestion.type === "radio" ? "单选" : currentQuestion.type === "check" ? "多选" : "填空"}}
        </view>
      </view>
      <view class="question-stem">{{currentQuestion.stem}}</view>

      <view wx:if="{{currentQuestion.type === 'radio'}}" class="option-list">
        <view
          wx:for="{{currentQuestion.options}}"
          wx:key="item"
          wx:for-item="option"
          class="option-chip {{option.item === currentQuestion.selectedRadio ? 'option-chip-active' : ''}}"
          data-qid="{{currentQuestion.questionId}}"
          data-option="{{option.item}}"
          bindtap="handleRadioChange"
        >
          <text class="option-item">{{option.item}}</text>
          <text class="option-content">{{option.content}}</text>
        </view>
      </view>

      <view wx:if="{{currentQuestion.type === 'check'}}" class="option-list">
        <view
          wx:for="{{currentQuestion.options}}"
          wx:key="item"
          wx:for-item="option"
          class="option-chip {{option.selected ? 'option-chip-active' : ''}}"
          data-qid="{{currentQuestion.questionId}}"
          data-option="{{option.item}}"
          bindtap="handleCheckToggle"
        >
          <text class="option-item">{{option.item}}</text>
          <text class="option-content">{{option.content}}</text>
        </view>
      </view>

      <view wx:if="{{currentQuestion.type === 'fill'}}" class="fill-list">
        <view
          wx:for="{{currentQuestion.fillValues}}"
          wx:key="index"
          wx:for-item="fillValue"
          wx:for-index="fillIndex"
          class="fill-row"
        >
          <view class="fill-label">空 {{fillIndex + 1}}</view>
          <input
            class="fill-input"
            placeholder="请输入答案"
            value="{{fillValue}}"
            data-qid="{{currentQuestion.questionId}}"
            data-idx="{{fillIndex}}"
            bindinput="handleFillInput"
          />
        </view>
      </view>
    </view>

    <view class="card navigator-card">
      <scroll-view class="dot-scroll" scroll-x="true" enhanced="{{true}}" show-scrollbar="{{false}}">
        <view class="dot-row">
          <view
            wx:for="{{questions}}"
            wx:key="questionId"
            wx:for-index="index"
            class="dot-item {{index === currentIndex ? 'dot-item-active' : ''}} {{item.answered ? 'dot-item-done' : ''}}"
            data-index="{{index}}"
            bindtap="jumpToQuestion"
          >
            {{index + 1}}
          </view>
        </view>
      </scroll-view>
      <view class="nav-row">
        <button class="btn btn-secondary nav-btn" bindtap="handlePrevQuestion" disabled="{{currentIndex <= 0}}">
          上一题
        </button>
        <button
          class="btn btn-secondary nav-btn"
          bindtap="handleNextQuestion"
          disabled="{{currentIndex >= totalQuestions - 1}}"
        >
          下一题
        </button>
      </view>
    </view>
  </block>

  <view class="quiz-action-row">
    <button
      wx:if="{{!hasStarted}}"
      class="btn btn-primary"
      bindtap="handleStartQuiz"
      loading="{{isLoading}}"
      disabled="{{isLoading || isSubmitting}}"
    >
      {{isLoading ? "准备中..." : "开始测试"}}
    </button>
    <button
      wx:if="{{hasStarted}}"
      class="btn btn-primary"
      bindtap="submitQuiz"
      loading="{{isSubmitting}}"
      disabled="{{isSubmitting || isLoading || !questions.length}}"
    >
      {{isSubmitting ? "判分中..." : "提交并查看成绩"}}
    </button>
    <button class="btn btn-secondary" bindtap="openQuizBankIngestPage">题库录入</button>
    <button wx:if="{{!hasStarted}}" class="btn btn-secondary" bindtap="goAnalyzeDirectly">直接去情绪分析</button>
  </view>
</view>
