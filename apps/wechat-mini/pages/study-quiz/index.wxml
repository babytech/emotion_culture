<view class="container quiz-page">
  <view class="card quiz-hero">
    <view class="quiz-kicker">伴学小测</view>
    <view class="quiz-title">{{paperTitle || "英语伴学小测"}}</view>
    <view class="quiz-sub">先做小测，再做情绪分析。</view>
    <view class="quiz-meta-row">
      <view class="status-chip">进度 {{answeredQuestions}} / {{totalQuestions}}</view>
      <view class="status-chip">未答 {{unansweredQuestions}}</view>
      <view wx:if="{{loadedFromCache}}" class="status-chip">缓存题库</view>
      <view wx:if="{{paperVersion}}" class="status-chip">版本 {{paperVersion}}</view>
    </view>
    <view class="quiz-progress-track">
      <view class="quiz-progress-fill" style="width: {{progressPercent}}%;"></view>
    </view>
  </view>

  <view wx:if="{{errorMsg}}" class="card error-card">
    <view class="error-text">{{errorMsg}}</view>
    <button class="btn btn-secondary error-retry-btn" bindtap="handleRetryLoadPaper" disabled="{{isLoading}}">
      重试加载
    </button>
  </view>
  <view wx:if="{{isLoading}}" class="card loading-card">试卷加载中...</view>

  <block wx:if="{{!isLoading && currentQuestion}}">
    <view class="card question-card">
      <view class="question-head">
        <view class="question-index">第 {{currentIndex + 1}} / {{totalQuestions}} 题</view>
        <view class="question-type">
          {{currentQuestion.type === "radio" ? "单选" : currentQuestion.type === "check" ? "多选" : "填空"}}
        </view>
      </view>
      <view class="question-stem">{{currentQuestion.stem}}</view>

      <view wx:if="{{currentQuestion.type === 'radio'}}" class="option-list">
        <view
          wx:for="{{currentQuestion.options}}"
          wx:key="item"
          wx:for-item="option"
          class="option-chip {{option.item === currentQuestion.selectedRadio ? 'option-chip-active' : ''}}"
          data-qid="{{currentQuestion.questionId}}"
          data-option="{{option.item}}"
          bindtap="handleRadioChange"
        >
          <text class="option-item">{{option.item}}</text>
          <text class="option-content">{{option.content}}</text>
        </view>
      </view>

      <view wx:if="{{currentQuestion.type === 'check'}}" class="option-list">
        <view
          wx:for="{{currentQuestion.options}}"
          wx:key="item"
          wx:for-item="option"
          class="option-chip {{option.selected ? 'option-chip-active' : ''}}"
          data-qid="{{currentQuestion.questionId}}"
          data-option="{{option.item}}"
          bindtap="handleCheckToggle"
        >
          <text class="option-item">{{option.item}}</text>
          <text class="option-content">{{option.content}}</text>
        </view>
      </view>

      <view wx:if="{{currentQuestion.type === 'fill'}}" class="fill-list">
        <view
          wx:for="{{currentQuestion.fillValues}}"
          wx:key="index"
          wx:for-item="fillValue"
          wx:for-index="fillIndex"
          class="fill-row"
        >
          <view class="fill-label">空 {{fillIndex + 1}}</view>
          <input
            class="fill-input"
            placeholder="请输入答案"
            value="{{fillValue}}"
            data-qid="{{currentQuestion.questionId}}"
            data-idx="{{fillIndex}}"
            bindinput="handleFillInput"
          />
        </view>
      </view>
    </view>

    <view class="card navigator-card">
      <scroll-view class="dot-scroll" scroll-x="true" enhanced="{{true}}" show-scrollbar="{{false}}">
        <view class="dot-row">
          <view
            wx:for="{{questions}}"
            wx:key="questionId"
            wx:for-index="index"
            class="dot-item {{index === currentIndex ? 'dot-item-active' : ''}} {{item.answered ? 'dot-item-done' : ''}}"
            data-index="{{index}}"
            bindtap="jumpToQuestion"
          >
            {{index + 1}}
          </view>
        </view>
      </scroll-view>
      <view class="nav-row">
        <button class="btn btn-secondary nav-btn" bindtap="handlePrevQuestion" disabled="{{currentIndex <= 0}}">
          上一题
        </button>
        <button
          class="btn btn-secondary nav-btn"
          bindtap="handleNextQuestion"
          disabled="{{currentIndex >= totalQuestions - 1}}"
        >
          下一题
        </button>
      </view>
    </view>
  </block>

  <view class="quiz-action-row">
    <button
      class="btn btn-primary"
      bindtap="submitQuiz"
      loading="{{isSubmitting}}"
      disabled="{{isSubmitting || isLoading || !questions.length}}"
    >
      {{isSubmitting ? "判分中..." : "提交并查看成绩"}}
    </button>
    <button class="btn btn-secondary" bindtap="goAnalyzeDirectly">直接去情绪分析</button>
  </view>
</view>
