<view class="container page-root">
  <view class="hero card">
    <view class="hero-title">青少年情绪文化助手</view>
    <view class="hero-sub text-muted">
      输入你的想法，前置自拍拍照，或者录一段语音。
    </view>
  </view>

  <view class="section card">
    <view class="section-title">1. 写下当下感受</view>
    <textarea
      class="thought-input"
      placeholder="例如：今天有点难过，考试没发挥好。"
      maxlength="4000"
      value="{{text}}"
      bindinput="handleTextInput"
    />
  </view>

  <view class="section card">
    <view class="section-title">2. 前置自拍拍照（可选）</view>
    <view class="section-tip text-muted">仅支持拍照，不支持从相册导入。</view>
    <view wx:if="{{isDevtools}}" class="section-tip text-muted">
      开发者工具中可能显示“选图片/文件”，请用真机调试验证前置摄像头。
    </view>
    <view wx:if="{{isHarmonyOS}}" class="section-tip text-muted">
      检测到 HarmonyOS 运行环境，已启用兼容策略（平台识别与安全区适配）。
    </view>
    <view class="media-row">
      <button class="btn btn-secondary" bindtap="chooseSelfie">前置自拍</button>
      <button
        class="btn"
        disabled="{{!imageTempPath && !pendingSelfiePath}}"
        bindtap="clearImage"
      >
        清除
      </button>
    </view>

    <view wx:if="{{pendingSelfiePath}}" class="preview-wrap">
      <view class="preview-label">待确认自拍</view>
      <image class="preview-image" mode="widthFix" src="{{pendingSelfiePath}}" />
      <view class="media-row confirm-row">
        <button class="btn btn-primary" bindtap="confirmSelfie">确认使用</button>
        <button class="btn btn-secondary" bindtap="retakeSelfie">重新拍摄</button>
        <button class="btn" bindtap="cancelPendingSelfie">取消</button>
      </view>
    </view>

    <view wx:elif="{{imageTempPath}}" class="preview-wrap">
      <view class="preview-label">已确认自拍</view>
      <image class="preview-image" mode="widthFix" src="{{imageTempPath}}" />
    </view>
  </view>

  <view class="section card">
    <view class="section-title">3. 录音输入（可选）</view>
    <view class="media-row">
      <button
        wx:if="{{!isRecording}}"
        class="btn btn-secondary"
        bindtap="startRecord"
      >
        开始录音
      </button>
      <button
        wx:if="{{isRecording}}"
        class="btn btn-primary"
        bindtap="stopRecord"
      >
        停止录音
      </button>
      <button class="btn" disabled="{{!audioTempPath}}" bindtap="clearAudio">
        清除
      </button>
    </view>
    <view class="audio-status text-muted">
      <text wx:if="{{isRecording}}">录音中：{{recordSeconds}} 秒</text>
      <text wx:elif="{{audioTempPath}}">已录制音频</text>
      <text wx:else>尚未录音</text>
    </view>
  </view>

  <view wx:if="{{errorMsg}}" class="error card">
    {{errorMsg}}
  </view>

  <view wx:if="{{isSubmitting || submitStage === 'failed'}}" class="status card status-{{submitStage}}">
    <view class="status-title">
      <text wx:if="{{submitStage === 'uploading'}}">上传中</text>
      <text wx:elif="{{submitStage === 'analyzing'}}">分析中</text>
      <text wx:elif="{{submitStage === 'rendering'}}">结果生成中</text>
      <text wx:elif="{{submitStage === 'failed'}}">失败可恢复</text>
      <text wx:else>处理中</text>
    </view>
    <view class="status-text">{{submitStatusText}}</view>
  </view>

  <view class="section card quick-actions">
    <view class="section-title">更多功能</view>
    <view class="media-row">
      <button class="btn btn-secondary" bindtap="goHistory">查看历史</button>
      <button class="btn" bindtap="goSettings">设置</button>
    </view>
  </view>

  <button
    class="btn btn-primary submit-btn"
    loading="{{isSubmitting}}"
    disabled="{{isSubmitting}}"
    bindtap="submitAnalyze"
  >
    {{submitButtonText}}
  </button>
</view>
