.page-root {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.hero {
  padding: 34rpx 30rpx;
  background:
    radial-gradient(circle at 85% 12%, rgba(255, 255, 255, 0.45), transparent 26%),
    linear-gradient(135deg, rgba(147, 37, 29, 0.16), rgba(211, 160, 91, 0.2)),
    var(--card);
}

.hero-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.hero-kicker {
  font-size: 22rpx;
  letter-spacing: 3rpx;
  text-transform: uppercase;
  color: #92644a;
}

.hero-title {
  margin-top: 10rpx;
  font-size: 48rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  line-height: 1.18;
}

.hero-sub {
  margin-top: 18rpx;
  line-height: 1.72;
  font-size: 27rpx;
}

.hero-stamp {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 250, 242, 0.78);
  border: 2rpx solid rgba(147, 37, 29, 0.12);
  font-size: 22rpx;
  color: #7d5640;
  white-space: nowrap;
}

.hero-chip-row {
  margin-top: 20rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.hero-chip {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 23rpx;
  color: #6b4f3b;
  background: rgba(255, 250, 243, 0.8);
  border: 2rpx solid rgba(147, 37, 29, 0.08);
}

.section {
  padding: 28rpx 24rpx;
}

.section-head {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.compact-head {
  margin-bottom: 14rpx;
}

.section-index {
  width: 70rpx;
  height: 70rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #f8ebd1, #efcf9a);
  color: #7f532f;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.section-heading {
  flex: 1;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.25;
}

.section-tip {
  margin-top: 6rpx;
  font-size: 24rpx;
  line-height: 1.6;
}

.inline-note {
  margin: -4rpx 0 16rpx;
  padding: 14rpx 16rpx;
  border-radius: 18rpx;
  background: rgba(255, 248, 235, 0.74);
  font-size: 23rpx;
  line-height: 1.6;
}

.thought-input {
  min-height: 260rpx;
  width: 100%;
  border-radius: 22rpx;
  background: #fffcf7;
  border: 2rpx solid rgba(161, 38, 27, 0.2);
  padding: 22rpx 20rpx;
  line-height: 1.72;
  font-size: 29rpx;
  box-sizing: border-box;
}

.media-row {
  display: flex;
  gap: 14rpx;
  flex-wrap: wrap;
}

.media-btn {
  flex: 1;
  min-width: 0;
}

.media-btn-plain {
  color: #6a5240 !important;
  background: linear-gradient(135deg, rgba(255, 250, 242, 0.96), rgba(245, 234, 216, 0.96)) !important;
  border: 2rpx solid rgba(146, 51, 36, 0.12) !important;
  box-shadow: none !important;
}

.media-row .btn-secondary,
.confirm-row .btn-secondary {
  color: #5f4328 !important;
  background: linear-gradient(135deg, #fff8ec 0%, #f4ddb2 100%) !important;
  border: 2rpx solid rgba(146, 51, 36, 0.12) !important;
}

.media-row .btn-primary,
.confirm-row .btn-primary,
.submit-btn {
  color: #fff !important;
  background: linear-gradient(135deg, #9f2a1f 0%, #c84434 100%) !important;
  border: 2rpx solid rgba(125, 28, 21, 0.2) !important;
}

.preview-wrap {
  margin-top: 16rpx;
}

.preview-label {
  margin-bottom: 10rpx;
  font-size: 24rpx;
  color: #7f4f27;
  font-weight: 600;
}

.preview-image {
  width: 100%;
  height: auto;
  border-radius: 22rpx;
  display: block;
}

.framed-image {
  border: 2rpx solid rgba(146, 51, 36, 0.1);
  box-shadow: inset 0 0 0 8rpx rgba(255, 250, 243, 0.85);
  background: #f6eee2;
}

.confirm-row {
  margin-top: 12rpx;
  flex-wrap: wrap;
}

.confirm-row .btn {
  flex: 1;
  min-width: 0;
}

.audio-status {
  margin-top: 14rpx;
  font-size: 26rpx;
}

.audio-status-panel {
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(255, 248, 235, 0.72);
}

.error {
  padding: 20rpx;
  border-color: rgba(180, 33, 33, 0.24);
  color: var(--danger-ink);
  background: var(--danger-bg);
}

.status {
  padding: 24rpx 22rpx;
}

.status-title {
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.status-text {
  font-size: 25rpx;
  line-height: 1.7;
  color: #664f3a;
}

.status-uploading,
.status-analyzing,
.status-rendering {
  background: var(--warn-bg);
  border-color: rgba(161, 38, 27, 0.24);
}

.status-failed {
  background: var(--danger-bg);
  border-color: rgba(180, 33, 33, 0.28);
}

.quick-actions {
  margin-top: 2rpx;
}

.submit-shell {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.submit-title {
  font-size: 30rpx;
  font-weight: 700;
}

.submit-tip {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.6;
}

.submit-btn {
  margin-top: 2rpx;
  width: 100%;
  min-height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx !important;
  box-shadow: 0 14rpx 26rpx rgba(159, 42, 31, 0.18) !important;
}
