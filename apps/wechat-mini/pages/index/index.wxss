.page-root {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.hero {
  padding: 30rpx;
  background:
    linear-gradient(135deg, rgba(161, 38, 27, 0.12), rgba(216, 162, 77, 0.16)),
    var(--card);
}

.hero-title {
  font-size: 44rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.hero-sub {
  margin-top: 12rpx;
  line-height: 1.6;
  font-size: 27rpx;
}

.section {
  padding: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.section-tip {
  margin: -6rpx 0 14rpx;
  font-size: 24rpx;
}

.thought-input {
  min-height: 220rpx;
  width: 100%;
  border-radius: 14rpx;
  background: #fffcf7;
  border: 2rpx solid rgba(161, 38, 27, 0.2);
  padding: 18rpx;
  line-height: 1.6;
  font-size: 29rpx;
  box-sizing: border-box;
}

.media-row {
  display: flex;
  gap: 14rpx;
}

.preview-wrap {
  margin-top: 16rpx;
}

.preview-label {
  margin-bottom: 10rpx;
  font-size: 24rpx;
  color: #7f4f27;
  font-weight: 600;
}

.preview-image {
  width: 100%;
  height: auto;
  border-radius: 16rpx;
  display: block;
}

.confirm-row {
  margin-top: 12rpx;
  flex-wrap: wrap;
}

.audio-status {
  margin-top: 14rpx;
  font-size: 26rpx;
}

.error {
  padding: 20rpx;
  border-color: rgba(180, 33, 33, 0.35);
  color: #8f1f1f;
  background: #fff0ef;
}

.status {
  padding: 20rpx;
}

.status-title {
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.status-text {
  font-size: 25rpx;
  line-height: 1.6;
  color: #664f3a;
}

.status-uploading,
.status-analyzing,
.status-rendering {
  background: #fff8eb;
  border-color: rgba(161, 38, 27, 0.24);
}

.status-failed {
  background: #fff1f1;
  border-color: rgba(180, 33, 33, 0.28);
}

.quick-actions {
  margin-top: 2rpx;
}

.submit-btn {
  margin-top: 4rpx;
}
