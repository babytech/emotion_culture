.home-page {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding-bottom: 148rpx;
}

.home-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 2rpx 2rpx 6rpx;
}

.home-top-title {
  font-size: 36rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #1f2d49;
}

.home-top-meta {
  font-size: 22rpx;
  color: #7b88a2;
}

.home-hero {
  padding: 24rpx 22rpx;
  border: none;
  background:
    radial-gradient(circle at 100% 0%, rgba(255, 255, 255, 0.28), transparent 36%),
    radial-gradient(circle at 12% 92%, rgba(255, 166, 122, 0.2), transparent 38%),
    linear-gradient(135deg, #3a68f2, #4f89ff 52%, #3ec4d3);
  color: #ffffff;
}

.home-hero-calm,
.home-hero-happy {
  background:
    radial-gradient(circle at 100% 0%, rgba(255, 255, 255, 0.3), transparent 38%),
    radial-gradient(circle at 12% 92%, rgba(255, 180, 120, 0.16), transparent 36%),
    linear-gradient(135deg, #2e86dd, #3fb9e2 58%, #6fcbff);
}

.home-hero-sad,
.home-hero-fear {
  background:
    radial-gradient(circle at 100% 0%, rgba(255, 255, 255, 0.24), transparent 36%),
    radial-gradient(circle at 10% 90%, rgba(144, 122, 255, 0.15), transparent 34%),
    linear-gradient(135deg, #6a78c9, #6ea2d6 58%, #8fc0df);
}

.home-hero-angry {
  background:
    radial-gradient(circle at 100% 0%, rgba(255, 255, 255, 0.22), transparent 36%),
    radial-gradient(circle at 12% 88%, rgba(255, 164, 120, 0.2), transparent 38%),
    linear-gradient(135deg, #5a71d5, #6880eb 58%, #74b0ff);
}

.home-hero-surprise {
  background:
    radial-gradient(circle at 100% 0%, rgba(255, 255, 255, 0.24), transparent 36%),
    radial-gradient(circle at 10% 90%, rgba(255, 176, 121, 0.18), transparent 36%),
    linear-gradient(135deg, #4b75ea, #5f92ff 58%, #52c9d8);
}

.home-hero-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.home-hero-kicker {
  font-size: 22rpx;
  letter-spacing: 2rpx;
  color: rgba(255, 255, 255, 0.86);
}

.home-hero-badge {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  font-size: 23rpx;
  color: #ffffff;
}

.home-hero-title {
  margin-top: 14rpx;
  font-size: 48rpx;
  line-height: 1.1;
  font-weight: 700;
}

.home-hero-sub {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.9);
}

.home-hero-foot {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.home-hero-stat {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.92);
}

.home-hero-link {
  font-size: 24rpx;
  color: #ffffff;
}

.home-action-card {
  padding: 16rpx 12rpx;
}

.home-action-grid {
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 8rpx;
}

.home-action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.home-action-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #e8f2ff, #e9f8ff 54%, #ffece0);
  color: #2f63b7;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.home-action-text {
  font-size: 22rpx;
  color: #4b5d82;
  text-align: center;
}

.home-checkin-card {
  padding: 20rpx;
  border: none;
  background:
    radial-gradient(circle at 100% 0%, rgba(255, 194, 126, 0.3), transparent 38%),
    radial-gradient(circle at 10% 90%, rgba(120, 203, 237, 0.14), transparent 34%),
    linear-gradient(135deg, #ffffff, #f6fbff);
}

.home-checkin-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.home-checkin-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2a3551;
}

.home-checkin-points {
  font-size: 24rpx;
  color: #c39a2e;
  font-weight: 700;
}

.home-checkin-sub {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #586a8f;
}

.home-checkin-foot {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.home-checkin-streak {
  font-size: 24rpx;
  color: #415279;
}

.home-checkin-btn {
  min-height: 70rpx;
  line-height: 70rpx;
  font-size: 24rpx !important;
  padding: 0 22rpx !important;
}

.home-week-card {
  padding: 22rpx 20rpx;
  border: none;
  background:
    radial-gradient(circle at 100% 0%, rgba(132, 186, 255, 0.24), transparent 34%),
    radial-gradient(circle at 12% 92%, rgba(255, 171, 122, 0.15), transparent 32%),
    linear-gradient(135deg, #ffffff, #f0f7ff);
}

.home-week-tag {
  display: inline-flex;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #3562c0;
  background: rgba(97, 142, 228, 0.12);
}

.home-week-title {
  margin-top: 12rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #24314d;
}

.home-week-text {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.65;
  color: #4f6188;
}

.home-banner-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.home-banner-card {
  padding: 18rpx 16rpx;
  border: none;
  background:
    radial-gradient(circle at 100% 0%, rgba(156, 201, 255, 0.24), transparent 34%),
    radial-gradient(circle at 12% 92%, rgba(255, 180, 120, 0.14), transparent 30%),
    linear-gradient(140deg, #fffefe, #edf7ff);
}

.home-banner-card-accent {
  background:
    radial-gradient(circle at 100% 0%, rgba(255, 194, 133, 0.24), transparent 34%),
    radial-gradient(circle at 12% 92%, rgba(117, 204, 232, 0.16), transparent 34%),
    linear-gradient(140deg, #ffffff, #f3f6ff);
}

.home-banner-label {
  font-size: 22rpx;
  color: #6a7fa8;
}

.home-banner-title {
  margin-top: 10rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2f4d;
}

.home-banner-sub {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.55;
  color: #627598;
}

.home-today-card {
  padding: 20rpx;
  border: none;
}

.home-today-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.home-today-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #24314d;
}

.home-today-toggle {
  font-size: 23rpx;
  color: #5576b8;
}

.home-today-meta {
  margin-top: 10rpx;
  font-size: 23rpx;
  color: #6e7e9d;
}

.home-today-headline {
  margin-top: 10rpx;
  font-size: 28rpx;
  line-height: 1.45;
  color: #2f3f62;
}

.home-today-summary {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #52658f;
}

.home-today-note {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.65;
  color: #7387ae;
}

.home-today-source {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #7f8db0;
}

.home-today-empty {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #7789aa;
}

.home-two-col {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.home-mini-card {
  padding: 18rpx 16rpx;
  border: none;
}

.home-mini-title {
  font-size: 24rpx;
  color: #6b7d9f;
}

.home-mini-main {
  margin-top: 12rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #21314d;
}

.home-mini-sub {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #5f7399;
}

.home-mini-empty {
  margin-top: 12rpx;
  font-size: 23rpx;
  line-height: 1.55;
  color: #7f8fb0;
}
