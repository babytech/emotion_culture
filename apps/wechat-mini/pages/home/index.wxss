.home-page {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding-bottom: 148rpx;
}

.home-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 2rpx 2rpx 6rpx;
}

.home-top-title {
  font-size: 36rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #1f2d49;
}

.home-top-meta {
  font-size: 22rpx;
  color: #7b88a2;
}

.home-hero {
  padding: 24rpx 22rpx;
  border: none;
  background:
    radial-gradient(circle at 100% 0%, rgba(255, 255, 255, 0.28), transparent 36%),
    radial-gradient(circle at 12% 92%, rgba(255, 166, 122, 0.2), transparent 38%),
    linear-gradient(135deg, #3a68f2, #4f89ff 52%, #3ec4d3);
  color: #ffffff;
}

.home-hero-calm {
  background:
    radial-gradient(circle at 100% 0%, rgba(255, 255, 255, 0.3), transparent 38%),
    radial-gradient(circle at 12% 92%, rgba(189, 220, 255, 0.16), transparent 36%),
    linear-gradient(135deg, #4a86e8, #63a5ff 58%, #8bc4ff);
}

.home-hero-happy {
  background:
    radial-gradient(circle at 100% 0%, rgba(255, 255, 255, 0.24), transparent 36%),
    radial-gradient(circle at 12% 92%, rgba(199, 255, 214, 0.18), transparent 36%),
    linear-gradient(135deg, #39a76e, #44be77 58%, #6adf92);
}

.home-hero-sad {
  background:
    radial-gradient(circle at 100% 0%, rgba(255, 255, 255, 0.24), transparent 36%),
    radial-gradient(circle at 10% 90%, rgba(208, 214, 223, 0.18), transparent 34%),
    linear-gradient(135deg, #7c8796, #929cab 58%, #b0bac8);
}

.home-hero-fear {
  background:
    radial-gradient(circle at 100% 0%, rgba(255, 255, 255, 0.24), transparent 36%),
    radial-gradient(circle at 10% 90%, rgba(255, 233, 159, 0.22), transparent 36%),
    linear-gradient(135deg, #d5ab38, #e0be4f 58%, #f0d77f);
  color: #4f410f;
}

.home-hero-fear .home-hero-kicker,
.home-hero-fear .home-hero-sub,
.home-hero-fear .home-hero-stat,
.home-hero-fear .home-hero-link {
  color: rgba(79, 65, 15, 0.9);
}

.home-hero-fear .home-hero-badge {
  color: #4f410f;
  background: rgba(255, 245, 208, 0.78);
}

.home-hero-angry {
  background:
    radial-gradient(circle at 100% 0%, rgba(255, 255, 255, 0.22), transparent 36%),
    radial-gradient(circle at 12% 88%, rgba(255, 183, 145, 0.22), transparent 38%),
    linear-gradient(135deg, #d4704b, #dd8658 58%, #efad76);
}

.home-hero-surprise {
  background:
    radial-gradient(circle at 100% 0%, rgba(255, 255, 255, 0.24), transparent 36%),
    radial-gradient(circle at 10% 90%, rgba(255, 176, 121, 0.18), transparent 36%),
    linear-gradient(135deg, #4b75ea, #5f92ff 58%, #52c9d8);
}

.home-hero-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.home-hero-kicker {
  font-size: 22rpx;
  letter-spacing: 2rpx;
  color: rgba(255, 255, 255, 0.86);
}

.home-hero-badge {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  font-size: 23rpx;
  color: #ffffff;
}

.home-hero-title {
  margin-top: 14rpx;
  font-size: 48rpx;
  line-height: 1.1;
  font-weight: 700;
}

.home-hero-sub {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.9);
}

.home-hero-foot {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.home-hero-stat {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.92);
}

.home-hero-link {
  font-size: 24rpx;
  color: #ffffff;
}

.home-checkin-card {
  padding: 20rpx;
  border: none;
  background:
    radial-gradient(circle at 100% 0%, rgba(255, 194, 126, 0.3), transparent 38%),
    radial-gradient(circle at 10% 90%, rgba(120, 203, 237, 0.14), transparent 34%),
    linear-gradient(135deg, #ffffff, #f6fbff);
}

.home-checkin-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.home-checkin-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2a3551;
}

.home-checkin-points {
  font-size: 24rpx;
  color: #c39a2e;
  font-weight: 700;
}

.home-checkin-sub {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #586a8f;
}

.home-checkin-foot {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.home-checkin-streak {
  font-size: 24rpx;
  color: #415279;
}

.home-checkin-btn {
  min-height: 70rpx;
  line-height: 70rpx;
  font-size: 24rpx !important;
  padding: 0 22rpx !important;
}

.home-today-card {
  padding: 20rpx;
  border: none;
}

.home-today-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.home-today-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #24314d;
}

.home-today-toggle {
  font-size: 23rpx;
  color: #5576b8;
}

.home-today-meta {
  margin-top: 10rpx;
  font-size: 23rpx;
  color: #6e7e9d;
}

.home-today-headline {
  margin-top: 10rpx;
  font-size: 28rpx;
  line-height: 1.45;
  color: #2f3f62;
}

.home-today-summary {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #52658f;
}

.home-today-note {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.65;
  color: #7387ae;
}

.home-today-source {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #7f8db0;
}

.home-today-empty {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #7789aa;
}

.home-two-col {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.home-mini-card {
  padding: 18rpx 16rpx;
  border: none;
}

.home-mini-title {
  font-size: 24rpx;
  color: #6b7d9f;
}

.home-mini-main {
  margin-top: 12rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #21314d;
}

.home-mini-sub {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #5f7399;
}

.home-mini-empty {
  margin-top: 12rpx;
  font-size: 23rpx;
  line-height: 1.55;
  color: #7f8fb0;
}
