<view class="container home-page">
  <view class="home-top">
    <view class="home-top-title">情绪陪伴小助手</view>
    <view class="home-top-meta">{{todayLabel}}</view>
  </view>

  <view class="card home-hero home-hero-{{heroTheme}}">
    <view class="home-hero-head">
      <view class="home-hero-kicker">{{isRefreshing ? "同步中" : "今日概览"}}</view>
      <view class="home-hero-badge">{{heroStreak}}</view>
    </view>
    <view class="home-hero-title">{{heroEmotion}}</view>
    <view class="home-hero-sub">{{heroLatestTime}}</view>
    <view class="home-hero-foot">
      <view class="home-hero-stat">本月记录 {{heroMonthCount}}</view>
      <view class="home-hero-link" bindtap="openRecentRecord">查看最近结果</view>
    </view>
  </view>

  <view class="card home-checkin-card">
    <view class="home-checkin-head">
      <view class="home-checkin-title">每日签到</view>
      <view class="home-checkin-points">积分 {{checkin.pointsBalance}}</view>
    </view>
    <view class="home-checkin-sub">{{checkin.message}}</view>
    <view class="home-checkin-foot">
      <view class="home-checkin-streak">连续 {{checkin.currentStreak}} 天</view>
      <button class="btn btn-primary home-checkin-btn" bindtap="openCheckinPage">
        {{checkin.signedToday ? "已签到" : "签到 +" + checkin.dailyPoints}}
      </button>
    </view>
  </view>

  <view class="card home-today-card">
    <view class="home-today-head">
      <view class="home-today-title">历史上的今天</view>
      <view class="home-today-toggle" wx:if="{{todayHistory.available}}" bindtap="toggleTodayHistory">
        {{todayHistory.expanded ? "收起" : "展开"}}
      </view>
    </view>
    <view wx:if="{{todayHistory.available}}">
      <view class="home-today-meta">{{todayHistory.monthDay}} {{todayHistory.eventYear}}</view>
      <view class="home-today-headline">{{todayHistory.headline}}</view>
      <view wx:if="{{todayHistory.expanded}}" class="home-today-summary">{{todayHistory.summary}}</view>
      <view wx:if="{{todayHistory.expanded && todayHistory.optionalNote}}" class="home-today-note">
        {{todayHistory.optionalNote}}
      </view>
      <view class="home-today-source">{{todayHistory.sourceLabel}}{{todayHistory.cacheHit ? " · 缓存" : ""}}</view>
    </view>
    <view wx:else class="home-today-empty">历史事件整理中，稍后会在这里展示。</view>
  </view>

  <view class="home-two-col">
    <view class="card home-mini-card" bindtap="openRecentRecord">
      <view class="home-mini-title">最近结果</view>
      <view wx:if="{{recentRecord}}">
        <view class="home-mini-main">{{recentRecord.primaryEmotionLabel}}</view>
        <view class="home-mini-sub">{{recentRecord.displayTime}}</view>
      </view>
      <view wx:else class="home-mini-empty">{{recentRecordStatus}}</view>
    </view>
    <view class="card home-mini-card" bindtap="openFavoritesTab">
      <view class="home-mini-title">收藏预览</view>
      <view wx:if="{{favoritePreview.length}}">
        <view class="home-mini-main">{{favoritePreview[0].typeLabel}}</view>
        <view class="home-mini-sub">{{favoritePreview[0].title}}</view>
      </view>
      <view wx:else class="home-mini-empty">暂无收藏</view>
    </view>
  </view>
</view>
