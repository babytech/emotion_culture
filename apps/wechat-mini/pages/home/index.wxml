<view class="container shell-page">
  <view class="card shell-hero home-hero">
    <view class="section-head">
      <view class="section-head-copy">
        <view class="home-title-wrap">
          <view class="home-title-meta">{{todayLabel}}</view>
          <view class="home-title-line">
            今天也可以<text class="home-title-accent">慢一点</text>
          </view>
          <view class="home-title-line home-title-line-strong">
            把情绪<text class="home-title-accent home-title-accent-strong">先放下来</text>
          </view>
        </view>
      </view>
      <view class="shell-badge home-hero-badge">
        <view class="home-hero-badge-dot {{isRefreshing ? 'home-hero-badge-dot-live' : ''}}"></view>
        <text class="home-hero-badge-text">{{isRefreshing ? "刷新中" : "首页"}}</text>
      </view>
    </view>

    <view class="home-rhythm-strip">
      <view class="home-rhythm-chip">
        <view class="home-rhythm-chip-label">更新状态</view>
        <view class="home-rhythm-chip-value">{{isRefreshing ? "同步中" : "已同步"}}</view>
      </view>
      <view class="home-rhythm-chip">
        <view class="home-rhythm-chip-label">历史板块</view>
        <view class="home-rhythm-chip-value">{{todayHistory.statusText}}</view>
      </view>
    </view>

    <view class="home-hero-stage">
      <view class="home-spotlight-card home-spotlight-card-{{heroTheme}}">
        <view class="home-spotlight-kicker">今日陪伴状态</view>
        <view class="home-spotlight-value">{{heroEmotion}}</view>
        <view class="home-spotlight-meta">{{heroLatestTime}}</view>
      </view>
      <view class="home-stage-side">
        <view class="home-stage-mini-card home-stage-mini-card-{{heroTheme}}">
          <view class="home-stage-mini-label">连续记录</view>
          <view class="home-stage-mini-value">{{heroStreak}}</view>
        </view>
        <view class="home-stage-mini-card home-stage-mini-card-accent home-stage-mini-card-{{heroTheme}}">
          <view class="home-stage-mini-label">本月打卡</view>
          <view class="home-stage-mini-value">{{heroMonthCount}}</view>
        </view>
      </view>
    </view>

    <view class="home-hero-action-row">
      <button class="btn btn-primary home-hero-btn home-hero-btn-primary" bindtap="openAnalyzeTab">
        立即开始
      </button>
      <button class="btn btn-secondary home-hero-btn home-hero-btn-secondary" bindtap="openRecentRecord">查看最近结果</button>
    </view>
  </view>

  <view class="card home-fastlane-card">
    <view class="home-fastlane-head">
      <view class="home-fastlane-title">快速入口</view>
      <view class="home-fastlane-sub">按你现在想做的事直接走</view>
    </view>
    <view class="home-fastlane-grid">
      <button class="btn home-fastlane-btn home-fastlane-btn-journey" bindtap="openJourneyTab">
        <view class="home-fastlane-btn-title">去记录页</view>
        <view class="home-fastlane-btn-sub">看轨迹中枢</view>
      </button>
      <button class="btn home-fastlane-btn home-fastlane-btn-favorites" bindtap="openFavoritesTab">
        <view class="home-fastlane-btn-title">看收藏</view>
        <view class="home-fastlane-btn-sub">回看诗词与国潮</view>
      </button>
      <button class="btn home-fastlane-btn home-fastlane-btn-profile" bindtap="openProfileTab">
        <view class="home-fastlane-btn-title">我的设置</view>
        <view class="home-fastlane-btn-sub">管理偏好与隐私</view>
      </button>
    </view>
  </view>

  <view class="metric-grid home-metric-grid">
    <view wx:for="{{metrics}}" wx:key="label" class="card metric-card home-summary-card">
      <view class="home-summary-copy">
        <view class="home-summary-label">{{item.label}}</view>
        <view class="home-summary-caption">{{item.caption}}</view>
      </view>
      <view class="home-summary-value">{{item.value}}</view>
    </view>
  </view>

  <view class="card section-card">
    <view class="section-head">
      <view class="section-head-copy">
        <view class="section-title">本周洞察</view>
      </view>
      <view class="status-chip">{{weekInsightStatus}}</view>
    </view>
    <view class="home-insight-card">
      <view class="home-insight-mark">周</view>
      <view class="home-insight-body">{{weekInsightText}}</view>
      <view class="home-insight-footer">
        <view class="home-insight-caption">来自本周记录</view>
      </view>
    </view>
  </view>

  <view class="card section-card today-history-card">
    <view class="section-head">
      <view class="section-head-copy">
        <view class="section-title">历史上的今天</view>
      </view>
      <view class="today-history-head-actions">
        <view class="status-chip">{{todayHistory.statusText}}</view>
        <view wx:if="{{todayHistory.available}}" class="today-history-toggle" bindtap="toggleTodayHistory">
          {{todayHistory.expanded ? "收起" : "展开"}} {{todayHistory.expanded ? "↑" : "↓"}}
        </view>
      </view>
    </view>

    <view wx:if="{{todayHistory.available}}" class="today-history-body">
      <view class="today-history-topline">
        <view class="today-history-date">{{todayHistory.monthDay}}</view>
        <view wx:if="{{todayHistory.eventYear}}" class="today-history-year">{{todayHistory.eventYear}}</view>
      </view>
      <view class="today-history-headline">{{todayHistory.headline}}</view>
      <view wx:if="{{todayHistory.expanded}}" class="today-history-summary">{{todayHistory.summary}}</view>
      <view wx:if="{{todayHistory.expanded && todayHistory.optionalNote}}" class="today-history-note">
        {{todayHistory.optionalNote}}
      </view>
      <view class="today-history-foot">
        <view class="today-history-source">{{todayHistory.sourceLabel}}{{todayHistory.cacheHit ? " · 缓存" : ""}}</view>
        <view class="today-history-footnote">{{todayHistory.expanded ? "轻补充，不打断主任务" : "点展开可查看摘要"}}</view>
      </view>
    </view>

    <view wx:else class="today-history-empty">
      历史事件内容正在整理，稍后回来这里会看到一条简短的历史片段。
    </view>
  </view>

  <view class="card section-card">
    <view class="section-head">
      <view class="section-head-copy">
        <view class="section-title">最近一条结果摘要</view>
      </view>
      <view class="status-chip">{{recentRecordStatus}}</view>
    </view>

    <view wx:if="{{recentRecord}}" class="recent-card" bindtap="openRecentRecord">
      <view class="recent-topline">
        <view class="recent-time-pill">{{recentRecord.displayTime}}</view>
      </view>
      <view class="recent-emotion">{{recentRecord.primaryEmotionLabel}}</view>
      <view class="recent-secondary-pill">{{recentRecord.secondaryEmotionText}}</view>
      <view class="recent-summary">{{recentRecord.summary}}</view>
      <view class="recent-footer">
        <view class="recent-link">查看详情</view>
      </view>
    </view>

    <view wx:else class="empty-copy">完成一次分析后，这里会展示最近一条结果摘要。</view>
  </view>

  <view class="card section-card">
    <view class="section-head">
      <view class="section-head-copy">
        <view class="section-title">收藏预览</view>
      </view>
      <view class="status-chip">{{favoriteStatusText}}</view>
    </view>

    <view wx:if="{{favoritePreview.length}}" class="favorite-preview-list">
      <view wx:for="{{favoritePreview}}" wx:key="favoriteId" class="favorite-preview-item">
        <view class="favorite-preview-head">
          <view class="favorite-preview-type">{{item.typeLabel}}</view>
          <view class="favorite-preview-flag">已收藏</view>
        </view>
        <view class="favorite-preview-title">{{item.title}}</view>
        <view class="favorite-preview-sub">{{item.subtitle}}</view>
        <view class="favorite-preview-foot">
          <view class="favorite-preview-hint">{{item.hint}}</view>
          <view class="favorite-preview-link">去查看</view>
        </view>
      </view>
    </view>

    <view wx:else class="empty-copy">还没有收藏内容。</view>
  </view>
</view>
