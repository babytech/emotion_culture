.quiz-result-page {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.loading-card,
.error-card {
  padding: 18rpx;
  border: none;
}

.error-card {
  color: #9f3d4d;
  background: #fff2f5;
}

.result-hero {
  padding: 20rpx;
  border: none;
  background:
    radial-gradient(circle at 100% 0%, rgba(148, 193, 255, 0.26), transparent 38%),
    linear-gradient(135deg, #ffffff, #eef5ff);
}

.result-hero-good {
  background:
    radial-gradient(circle at 100% 0%, rgba(174, 227, 190, 0.26), transparent 38%),
    linear-gradient(135deg, #f7fdf8, #ecf9ef);
}

.result-hero-normal {
  background:
    radial-gradient(circle at 100% 0%, rgba(154, 198, 255, 0.28), transparent 38%),
    linear-gradient(135deg, #ffffff, #eef5ff);
}

.result-hero-low {
  background:
    radial-gradient(circle at 100% 0%, rgba(255, 201, 194, 0.24), transparent 38%),
    linear-gradient(135deg, #fff8f8, #fff0f0);
}

.result-kicker {
  font-size: 22rpx;
  color: #637faa;
  letter-spacing: 2rpx;
}

.result-score {
  margin-top: 8rpx;
  font-size: 56rpx;
  line-height: 1.06;
  font-weight: 700;
  color: #233451;
}

.result-grade {
  margin-top: 6rpx;
  font-size: 27rpx;
  color: #45618e;
}

.result-meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #6d83ab;
}

.result-pill-row {
  margin-top: 12rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.status-chip {
  padding: 7rpx 14rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
  color: #486cab;
  background: rgba(79, 118, 191, 0.14);
}

.section-card {
  padding: 18rpx;
  border: none;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #233451;
}

.summary-line {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #3d5379;
}

.hint-line {
  color: #5f769f;
  line-height: 1.6;
}

.wrong-list {
  margin-top: 10rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.wrong-item {
  padding: 14rpx;
  border-radius: 14rpx;
  background: #f5f9ff;
  border: 2rpx solid rgba(100, 128, 173, 0.14);
}

.wrong-stem {
  font-size: 25rpx;
  line-height: 1.58;
  color: #2d4369;
}

.wrong-line {
  margin-top: 7rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #56719f;
}

.empty-copy {
  margin-top: 8rpx;
  font-size: 23rpx;
  color: #7088b0;
}

.action-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx;
}

.action-row-single {
  width: 100%;
}
