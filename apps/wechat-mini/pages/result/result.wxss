.page-root {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  box-sizing: border-box;
}

.empty {
  padding: 26rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 700;
}

.emotion {
  padding: 24rpx;
}

.emotion-title {
  font-size: 30rpx;
  margin-bottom: 16rpx;
  font-weight: 700;
}

.emotion-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 14rpx;
}

.emotion-key {
  font-size: 28rpx;
  color: #6f5a45;
  font-weight: 600;
}

.emotion-badge {
  display: inline-block;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
  border: 2rpx solid transparent;
}

.emotion-happy {
  color: #0f6c4d;
  background: #e8f7ee;
  border-color: #83cfa8;
}

.emotion-sad {
  color: #345580;
  background: #eef4ff;
  border-color: #a7bfe5;
}

.emotion-angry {
  color: #832f2c;
  background: #ffefef;
  border-color: #e6a2a0;
}

.emotion-surprise {
  color: #7e4f14;
  background: #fff5e5;
  border-color: #e8c083;
}

.emotion-neutral {
  color: #5f5d57;
  background: #f4f2ec;
  border-color: #d4cec1;
}

.emotion-fear {
  color: #52477d;
  background: #f3f0ff;
  border-color: #c4b5ea;
}

.emotion-subtitle {
  margin-top: 14rpx;
  margin-bottom: 8rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #6b543f;
}

.chip-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.chip {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  line-height: 1.3;
}

.emotion-chip {
  background: #f2e3cc;
  color: #7a4f2c;
}

.tag-chip {
  background: #efe7da;
  color: #614f3d;
}

.chip-empty {
  font-size: 24rpx;
  color: #8c7c68;
}

.overview {
  line-height: 1.7;
  font-size: 28rpx;
  color: #3f2f22;
}

.suggestion {
  line-height: 1.7;
  font-size: 28rpx;
  color: #3f2f22;
}

.request-id {
  margin-top: 12rpx;
  font-size: 22rpx;
}

.section {
  padding: 24rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 14rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
}

.poet-tag {
  font-size: 24rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #f4e5cf;
  color: #835628;
}

.result-image {
  width: 100%;
  height: auto;
  min-height: 280rpx;
  border-radius: 16rpx;
  display: block;
  background: #f5efe4;
}

.img-placeholder {
  height: 200rpx;
  border-radius: 16rpx;
  background: #f8f1e3;
  border: 2rpx dashed #e1c48f;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8e7d62;
}

.poem-text {
  margin-top: 16rpx;
  white-space: pre-wrap;
  line-height: 1.8;
  font-size: 29rpx;
}

.interpretation {
  margin-top: 12rpx;
  line-height: 1.6;
  font-size: 27rpx;
}

.comfort {
  margin-top: 16rpx;
  line-height: 1.8;
  white-space: pre-wrap;
  font-size: 29rpx;
}

.user-actions {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-bottom: 12rpx;
}

.mini-action-btn {
  min-height: 68rpx;
  line-height: 68rpx;
  padding: 0 24rpx !important;
  font-size: 26rpx;
}

.user-image {
  margin-top: 8rpx;
}

.selfie-state {
  font-size: 24rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #f4e5cf;
  color: #835628;
}

.email-input {
  width: 100%;
  box-sizing: border-box;
  border-radius: 16rpx;
  border: 2rpx solid rgba(161, 38, 27, 0.2);
  background: #fffcf7;
  padding: 20rpx 18rpx;
  min-height: 90rpx;
  margin-top: 10rpx;
  margin-bottom: 14rpx;
  font-size: 33rpx;
  line-height: 1.4;
}

.email-input-error {
  border-color: #d23b3b;
  background: #fff4f4;
}

.email-section {
  scroll-margin-top: 80rpx;
}

.email-section-focus {
  border-color: rgba(161, 38, 27, 0.28);
}

.email-tip {
  font-size: 24rpx;
  margin-bottom: 6rpx;
}

.email-error {
  margin-top: -4rpx;
  margin-bottom: 14rpx;
  color: #b42323;
  font-size: 25rpx;
  line-height: 1.5;
}

.email-submit-btn {
  width: 100%;
  min-height: 92rpx;
  line-height: 92rpx;
  padding: 0 !important;
  font-size: 30rpx;
  text-align: center;
  font-weight: 700;
  margin-top: 6rpx;
}

.result-bottom-btn {
  width: 100%;
  min-height: 90rpx;
  line-height: 90rpx;
  padding: 0 !important;
  font-size: 42rpx;
  text-align: center;
  font-weight: 700;
  margin-top: 8rpx;
}

.email-status {
  margin-top: 12rpx;
  font-size: 26rpx;
}
