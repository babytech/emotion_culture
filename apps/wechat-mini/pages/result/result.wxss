.result-page {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  box-sizing: border-box;
}

.empty {
  padding: 30rpx 26rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 700;
}

.result-hero {
  padding: 32rpx 26rpx 26rpx;
  background:
    radial-gradient(circle at 100% 0%, rgba(211, 160, 91, 0.14), transparent 28%),
    linear-gradient(180deg, rgba(255, 251, 245, 0.98), rgba(248, 241, 232, 0.96));
  position: relative;
  overflow: hidden;
}

.result-hero::after {
  content: "";
  position: absolute;
  right: -42rpx;
  top: -48rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 999rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.24), transparent 70%);
}

.panel-kicker {
  font-size: 21rpx;
  letter-spacing: 3rpx;
  text-transform: uppercase;
  color: #95674b;
  margin-bottom: 8rpx;
}

.panel-badge {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, rgba(255, 251, 244, 0.92), rgba(247, 230, 199, 0.92));
  border: 2rpx solid rgba(147, 37, 29, 0.08);
  color: #7a5231;
  font-size: 23rpx;
  white-space: nowrap;
}

.panel-badge-happy {
  color: #0f6c4d;
  background: linear-gradient(135deg, rgba(232, 247, 238, 0.96), rgba(214, 240, 221, 0.94));
}

.panel-badge-sad {
  color: #345580;
  background: linear-gradient(135deg, rgba(238, 244, 255, 0.96), rgba(225, 235, 251, 0.94));
}

.panel-badge-angry {
  color: #832f2c;
  background: linear-gradient(135deg, rgba(255, 239, 239, 0.96), rgba(249, 226, 226, 0.94));
}

.panel-badge-surprise {
  color: #7e4f14;
  background: linear-gradient(135deg, rgba(255, 245, 229, 0.96), rgba(249, 236, 207, 0.94));
}

.panel-badge-neutral {
  color: #5f5d57;
  background: linear-gradient(135deg, rgba(244, 242, 236, 0.96), rgba(236, 232, 223, 0.94));
}

.panel-badge-fear {
  color: #52477d;
  background: linear-gradient(135deg, rgba(243, 240, 255, 0.96), rgba(232, 225, 250, 0.94));
}

.result-title,
.section-title {
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.25;
}

.result-hero-stage {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: minmax(0, 1.35fr) minmax(0, 0.85fr);
  gap: 16rpx;
}

.result-hero-main {
  min-height: 232rpx;
  padding: 24rpx 22rpx;
  border-radius: 26rpx;
  background:
    radial-gradient(circle at 100% 0%, rgba(255, 255, 255, 0.28), transparent 34%),
    linear-gradient(135deg, rgba(255, 249, 241, 0.96), rgba(250, 239, 224, 0.94));
  border: 2rpx solid rgba(147, 37, 29, 0.08);
  box-shadow: 0 12rpx 26rpx rgba(124, 76, 40, 0.1);
  box-sizing: border-box;
}

.result-hero-main-happy {
  background: linear-gradient(135deg, rgba(232, 247, 238, 0.98), rgba(219, 242, 225, 0.94));
}

.result-hero-main-sad {
  background: linear-gradient(135deg, rgba(238, 244, 255, 0.98), rgba(227, 235, 249, 0.94));
}

.result-hero-main-angry {
  background: linear-gradient(135deg, rgba(255, 239, 239, 0.98), rgba(249, 229, 226, 0.94));
}

.result-hero-main-surprise {
  background: linear-gradient(135deg, rgba(255, 245, 229, 0.98), rgba(248, 235, 206, 0.94));
}

.result-hero-main-neutral {
  background: linear-gradient(135deg, rgba(244, 242, 236, 0.98), rgba(236, 232, 223, 0.94));
}

.result-hero-main-fear {
  background: linear-gradient(135deg, rgba(243, 240, 255, 0.98), rgba(232, 225, 250, 0.94));
}

.result-hero-main-label {
  font-size: 22rpx;
  color: #896f5d;
  letter-spacing: 1rpx;
}

.result-hero-main .emotion-badge {
  margin-top: 12rpx;
}

.result-hero-main-text {
  margin-top: 16rpx;
  font-size: 30rpx;
  line-height: 1.7;
  color: #3f2f22;
}

.result-hero-side {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.result-hero-side-card {
  min-height: 0;
  min-height: 110rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.result-hero-side-card-happy {
  background: rgba(232, 247, 238, 0.88);
}

.result-hero-side-card-sad {
  background: rgba(238, 244, 255, 0.88);
}

.result-hero-side-card-angry {
  background: rgba(255, 239, 239, 0.88);
}

.result-hero-side-card-surprise {
  background: rgba(255, 245, 229, 0.88);
}

.result-hero-side-card-neutral {
  background: rgba(244, 242, 236, 0.88);
}

.result-hero-side-card-fear {
  background: rgba(243, 240, 255, 0.88);
}

.emotion-summary-value-small {
  font-size: 24rpx;
  line-height: 1.4;
}

.emotion-summary-grid {
  margin-top: 16rpx;
  margin-bottom: 10rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.emotion-summary-card {
  padding: 18rpx 16rpx;
  border-radius: 20rpx;
  background: rgba(255, 249, 241, 0.82);
  border: 2rpx solid rgba(147, 37, 29, 0.08);
  box-shadow: 0 8rpx 18rpx rgba(124, 76, 40, 0.06);
  box-sizing: border-box;
}

.emotion-summary-label {
  font-size: 22rpx;
  color: #8a715d;
}

.emotion-summary-value {
  margin-top: 8rpx;
  font-size: 29rpx;
  line-height: 1.34;
  font-weight: 700;
  color: #7e4d2d;
}

.result-block {
  margin-top: 16rpx;
  padding: 18rpx 18rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(255, 250, 242, 0.78);
  border: 2rpx solid rgba(147, 37, 29, 0.08);
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.42);
}

.result-block-muted {
  background: rgba(246, 240, 231, 0.78);
}

.result-block-accent {
  background:
    linear-gradient(135deg, rgba(255, 247, 235, 0.94), rgba(250, 238, 217, 0.9));
  box-shadow:
    inset 0 2rpx 0 rgba(255, 255, 255, 0.42),
    0 10rpx 22rpx rgba(124, 76, 40, 0.08);
}

.result-block-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #6b543f;
}

.emotion-badge {
  display: inline-block;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
  border: 2rpx solid transparent;
}

.emotion-happy {
  color: #0f6c4d;
  background: #e8f7ee;
  border-color: #83cfa8;
}

.emotion-sad {
  color: #345580;
  background: #eef4ff;
  border-color: #a7bfe5;
}

.emotion-angry {
  color: #832f2c;
  background: #ffefef;
  border-color: #e6a2a0;
}

.emotion-surprise {
  color: #7e4f14;
  background: #fff5e5;
  border-color: #e8c083;
}

.emotion-neutral {
  color: #5f5d57;
  background: #f4f2ec;
  border-color: #d4cec1;
}

.emotion-fear {
  color: #52477d;
  background: #f3f0ff;
  border-color: #c4b5ea;
}

.emotion-subtitle {
  margin-top: 0;
  margin-bottom: 8rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #6b543f;
}

.result-meta-grid {
  margin-top: 16rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.result-meta-card {
  padding: 18rpx 16rpx;
  border-radius: 22rpx;
  background: rgba(255, 250, 242, 0.78);
  border: 2rpx solid rgba(147, 37, 29, 0.08);
  box-shadow: 0 8rpx 18rpx rgba(124, 76, 40, 0.06);
}

.result-meta-foot {
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 2rpx solid rgba(147, 37, 29, 0.06);
}

.chip-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.chip {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  line-height: 1.3;
}

.emotion-chip {
  background: #f2e3cc;
  color: #7a4f2c;
}

.tag-chip {
  background: #efe7da;
  color: #614f3d;
}

.chip-empty {
  font-size: 24rpx;
  color: #8c7c68;
}

.overview,
.suggestion,
.speech-transcript {
  margin-top: 8rpx;
  line-height: 1.78;
  font-size: 28rpx;
  color: #3f2f22;
  white-space: pre-wrap;
}

.speech-transcript.muted {
  color: #7e7365;
}

.request-id {
  margin-top: 12rpx;
  font-size: 22rpx;
}

.section {
  padding: 26rpx 24rpx;
}

.result-input-card,
.section-poem,
.section-guochao,
.section-selfie,
.section-media,
.section-email,
.section-action {
  background:
    radial-gradient(circle at 100% 0%, rgba(211, 160, 91, 0.1), transparent 30%),
    linear-gradient(180deg, rgba(255, 251, 245, 0.98), rgba(248, 241, 232, 0.96));
}

.section-guochao {
  background:
    radial-gradient(circle at 0% 0%, rgba(147, 37, 29, 0.08), transparent 24%),
    linear-gradient(180deg, rgba(255, 250, 245, 0.98), rgba(249, 240, 235, 0.96));
}

.section-selfie {
  background:
    radial-gradient(circle at 100% 0%, rgba(211, 160, 91, 0.08), transparent 24%),
    linear-gradient(180deg, rgba(255, 251, 246, 0.96), rgba(247, 241, 233, 0.94));
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.section-head-copy {
  flex: 1;
  min-width: 0;
}

.section-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.68;
}

.poet-tag {
  font-size: 24rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, rgba(255, 250, 242, 0.92), rgba(247, 230, 199, 0.9));
  color: #835628;
  border: 2rpx solid rgba(147, 37, 29, 0.08);
  white-space: nowrap;
}

.result-image {
  width: 100%;
  height: auto;
  min-height: 280rpx;
  border-radius: 16rpx;
  display: block;
  background: #f5efe4;
}

.img-placeholder {
  height: 200rpx;
  border-radius: 16rpx;
  background: #f8f1e3;
  border: 2rpx dashed #e1c48f;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8e7d62;
}

.img-loading-tip {
  margin-top: 10rpx;
  margin-bottom: 4rpx;
  font-size: 24rpx;
  color: #8e7d62;
}

.poem-text,
.comfort {
  margin-top: 16rpx;
  white-space: pre-wrap;
  line-height: 1.86;
  font-size: 29rpx;
  color: #3d2e21;
}

.interpretation {
  margin-top: 12rpx;
  line-height: 1.72;
  font-size: 27rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(255, 250, 243, 0.74);
}

.favorite-actions,
.user-actions {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.favorite-badge {
  font-size: 23rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #e8f7ee;
  color: #0f6c4d;
}

.mini-action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 72rpx;
  line-height: 72rpx;
  padding: 0 24rpx !important;
  font-size: 26rpx;
}

.user-image {
  margin-top: 8rpx;
}

.selfie-state {
  font-size: 24rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #f4e5cf;
  color: #835628;
}

.action-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.result-bottom-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  margin: 0;
  min-height: 88rpx;
  line-height: 88rpx;
  padding: 0 !important;
  font-size: 28rpx;
  text-align: center;
  font-weight: 700;
}

.sheet-mask {
  position: fixed;
  inset: 0;
  background: rgba(36, 25, 18, 0.28);
  z-index: 998;
}

.email-sheet {
  position: fixed;
  left: 18rpx;
  right: 18rpx;
  z-index: 999;
  border-radius: 34rpx 34rpx 28rpx 28rpx;
  box-shadow: 0 24rpx 58rpx rgba(36, 25, 18, 0.24);
  padding-bottom: calc(28rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(28rpx + env(safe-area-inset-bottom));
  background:
    radial-gradient(circle at 100% 0%, rgba(211, 160, 91, 0.12), transparent 32%),
    linear-gradient(180deg, rgba(255, 251, 245, 0.99), rgba(248, 241, 232, 0.98));
}

.sheet-handle {
  width: 84rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: rgba(125, 105, 89, 0.35);
  margin: 0 auto 18rpx;
}

.email-sheet-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.email-input {
  width: 100%;
  box-sizing: border-box;
  border-radius: 22rpx;
  border: 2rpx solid rgba(161, 38, 27, 0.2);
  background: #fffcf7;
  padding: 22rpx 20rpx;
  min-height: 90rpx;
  margin-top: 10rpx;
  margin-bottom: 14rpx;
  font-size: 33rpx;
  line-height: 1.4;
}

.email-input-error {
  border-color: #d23b3b;
  background: #fff4f4;
}

.email-section-focus {
  border-color: rgba(161, 38, 27, 0.28);
}

.email-tip {
  font-size: 24rpx;
  margin-bottom: 6rpx;
}

.email-error {
  margin-top: -4rpx;
  margin-bottom: 14rpx;
  color: #b42323;
  font-size: 25rpx;
  line-height: 1.5;
}

.email-submit-btn,
.email-cancel-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 92rpx;
  line-height: 92rpx;
  padding: 0 !important;
  font-size: 30rpx;
  text-align: center;
  font-weight: 700;
  margin-top: 10rpx;
}

.email-status-inline {
  margin-top: 0;
  font-size: 24rpx;
  line-height: 1.4;
  font-weight: 700;
  white-space: nowrap;
}

.email-status-inline-success {
  color: #1f6b4e;
}

.email-status-inline-error {
  color: #b42323;
}

.result-action-bar {
  position: fixed;
  left: 18rpx;
  right: 18rpx;
  z-index: 997;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 18rpx 18rpx calc(16rpx + constant(safe-area-inset-bottom));
  padding: 18rpx 18rpx calc(16rpx + env(safe-area-inset-bottom));
  border-radius: 34rpx;
  background:
    linear-gradient(180deg, rgba(255, 253, 249, 0.99), rgba(254, 247, 236, 0.98));
  border: 2rpx solid rgba(147, 37, 29, 0.08);
  box-shadow: 0 18rpx 40rpx rgba(62, 36, 23, 0.18);
  backdrop-filter: blur(10rpx);
  overflow: hidden;
}

.result-action-bar::before {
  content: "";
  position: absolute;
  left: 20rpx;
  right: 20rpx;
  top: 0;
  height: 8rpx;
  border-radius: 0 0 999rpx 999rpx;
  background: linear-gradient(90deg, rgba(200, 68, 52, 0.18), rgba(211, 160, 91, 0.28), rgba(200, 68, 52, 0.12));
}

.result-action-bar-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.result-action-bar-copy {
  min-width: 0;
  flex: 1;
}

.result-action-bar-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(159, 42, 31, 0.08);
  color: #8f3429;
  font-size: 21rpx;
  font-weight: 700;
}

.result-action-bar-title {
  margin-top: 10rpx;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.3;
  color: #4a301f;
}

.result-action-bar-sub {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 126rpx;
  padding: 12rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 248, 239, 0.92);
  border: 2rpx solid rgba(147, 37, 29, 0.08);
  font-size: 22rpx;
  color: #8c6c57;
  text-align: center;
  box-sizing: border-box;
}

.result-action-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.result-action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100rpx;
  padding: 16rpx 12rpx !important;
  border-radius: 22rpx;
  border: none;
  background: rgba(245, 237, 225, 0.96);
  color: #5c4737;
  font-size: 24rpx;
  line-height: 1.2;
  text-align: center;
  font-weight: 700;
  box-shadow: inset 0 2rpx 0 rgba(255, 255, 255, 0.42);
  box-sizing: border-box;
  gap: 8rpx;
}

.result-action-btn-title {
  font-size: 27rpx;
  font-weight: 700;
  line-height: 1.25;
  color: inherit;
}

.result-action-btn-sub {
  font-size: 21rpx;
  line-height: 1.3;
  color: rgba(92, 71, 55, 0.74);
}

.result-action-btn-primary .result-action-btn-sub {
  color: rgba(255, 248, 240, 0.82);
}

.result-action-btn::after {
  border: none;
}

.result-action-btn-primary {
  color: #fff8f0;
  background: linear-gradient(135deg, #a1261b, #c84434);
}

.error {
  padding: 20rpx;
  border-color: rgba(180, 33, 33, 0.24);
  color: var(--danger-ink);
  background: var(--danger-bg);
}
