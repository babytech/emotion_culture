.page-root {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  box-sizing: border-box;
}

.empty {
  padding: 30rpx 26rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 700;
}

.emotion {
  padding: 28rpx 24rpx;
}

.panel-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.panel-kicker {
  font-size: 21rpx;
  letter-spacing: 3rpx;
  text-transform: uppercase;
  color: #95674b;
  margin-bottom: 8rpx;
}

.panel-badge {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, rgba(255, 251, 244, 0.92), rgba(247, 230, 199, 0.92));
  border: 2rpx solid rgba(147, 37, 29, 0.08);
  color: #7a5231;
  font-size: 23rpx;
  white-space: nowrap;
}

.emotion-title {
  font-size: 34rpx;
  font-weight: 700;
}

.emotion-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 14rpx;
}

.emotion-summary-grid {
  margin-bottom: 12rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
}

.emotion-summary-card {
  padding: 16rpx 14rpx;
  border-radius: 20rpx;
  background: rgba(255, 249, 241, 0.82);
  border: 2rpx solid rgba(147, 37, 29, 0.08);
}

.emotion-summary-label {
  font-size: 22rpx;
  color: #8a715d;
}

.emotion-summary-value {
  margin-top: 8rpx;
  font-size: 27rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #7e4d2d;
}

.overview-block,
.speech-block,
.suggestion-block {
  padding: 18rpx;
  border-radius: 20rpx;
  background: rgba(255, 250, 242, 0.78);
  border: 2rpx solid rgba(147, 37, 29, 0.08);
}

.speech-block-muted {
  background: rgba(246, 240, 231, 0.78);
}

.emotion-key {
  font-size: 28rpx;
  color: #6f5a45;
  font-weight: 600;
}

.emotion-badge {
  display: inline-block;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
  border: 2rpx solid transparent;
}

.emotion-happy {
  color: #0f6c4d;
  background: #e8f7ee;
  border-color: #83cfa8;
}

.emotion-sad {
  color: #345580;
  background: #eef4ff;
  border-color: #a7bfe5;
}

.emotion-angry {
  color: #832f2c;
  background: #ffefef;
  border-color: #e6a2a0;
}

.emotion-surprise {
  color: #7e4f14;
  background: #fff5e5;
  border-color: #e8c083;
}

.emotion-neutral {
  color: #5f5d57;
  background: #f4f2ec;
  border-color: #d4cec1;
}

.emotion-fear {
  color: #52477d;
  background: #f3f0ff;
  border-color: #c4b5ea;
}

.emotion-subtitle {
  margin-top: 14rpx;
  margin-bottom: 8rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #6b543f;
}

.chip-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.chip {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  line-height: 1.3;
}

.emotion-chip {
  background: #f2e3cc;
  color: #7a4f2c;
}

.tag-chip {
  background: #efe7da;
  color: #614f3d;
}

.chip-empty {
  font-size: 24rpx;
  color: #8c7c68;
}

.overview {
  line-height: 1.78;
  font-size: 28rpx;
  color: #3f2f22;
}

.suggestion {
  line-height: 1.78;
  font-size: 28rpx;
  color: #3f2f22;
  padding: 18rpx 18rpx 0;
  border-top: 2rpx solid rgba(147, 37, 29, 0.08);
}

.checkin-wrap {
  margin-top: 8rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  align-items: center;
}

.checkin-chip {
  border-radius: 999rpx;
  padding: 8rpx 14rpx;
  font-size: 24rpx;
}

.checkin-chip.ok {
  background: #e8f7ee;
  color: #0f6c4d;
}

.checkin-chip.miss {
  background: #f4efe6;
  color: #7e6d58;
}

.checkin-meta {
  font-size: 24rpx;
  color: #6d5844;
}

.speech-transcript {
  margin-top: 6rpx;
  line-height: 1.7;
  font-size: 27rpx;
  color: #3f2f22;
  white-space: pre-wrap;
}

.speech-transcript.muted {
  color: #7e7365;
}

.request-id {
  margin-top: 12rpx;
  font-size: 22rpx;
}

.section {
  padding: 28rpx 24rpx;
}

.section-poem {
  background:
    radial-gradient(circle at 100% 0%, rgba(211, 160, 91, 0.1), transparent 26%),
    linear-gradient(180deg, rgba(255, 251, 245, 0.98), rgba(248, 241, 232, 0.96));
}

.section-guochao {
  background:
    radial-gradient(circle at 0% 0%, rgba(147, 37, 29, 0.08), transparent 24%),
    linear-gradient(180deg, rgba(255, 250, 245, 0.98), rgba(249, 240, 235, 0.96));
}

.section-selfie {
  background:
    radial-gradient(circle at 100% 0%, rgba(211, 160, 91, 0.08), transparent 24%),
    linear-gradient(180deg, rgba(255, 251, 246, 0.96), rgba(247, 241, 233, 0.94));
}

.section-media {
  border-color: rgba(146, 51, 36, 0.18);
}

.section-email {
  background:
    radial-gradient(circle at 100% 0%, rgba(147, 37, 29, 0.06), transparent 24%),
    linear-gradient(180deg, rgba(255, 251, 245, 0.96), rgba(247, 241, 233, 0.94));
}

.section-action {
  border-color: rgba(146, 51, 36, 0.18);
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.25;
}

.poet-tag {
  font-size: 24rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, rgba(255, 250, 242, 0.92), rgba(247, 230, 199, 0.9));
  color: #835628;
  border: 2rpx solid rgba(147, 37, 29, 0.08);
  white-space: nowrap;
}

.result-image {
  width: 100%;
  height: auto;
  min-height: 280rpx;
  border-radius: 16rpx;
  display: block;
  background: #f5efe4;
}

.img-placeholder {
  height: 200rpx;
  border-radius: 16rpx;
  background: #f8f1e3;
  border: 2rpx dashed #e1c48f;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8e7d62;
}

.img-loading-tip {
  margin-top: 10rpx;
  margin-bottom: 4rpx;
  font-size: 24rpx;
  color: #8e7d62;
}

.poem-text {
  margin-top: 16rpx;
  white-space: pre-wrap;
  line-height: 1.86;
  font-size: 29rpx;
  color: #3d2e21;
}

.interpretation {
  margin-top: 12rpx;
  line-height: 1.72;
  font-size: 27rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(255, 250, 243, 0.74);
}

.comfort {
  margin-top: 16rpx;
  line-height: 1.86;
  white-space: pre-wrap;
  font-size: 29rpx;
  color: #3d2e21;
  padding: 16rpx 18rpx 0;
  border-top: 2rpx solid rgba(147, 37, 29, 0.08);
}

.favorite-actions {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.favorite-badge {
  font-size: 23rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #e8f7ee;
  color: #0f6c4d;
}

.user-actions {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-bottom: 12rpx;
}

.mini-action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 72rpx;
  line-height: 72rpx;
  padding: 0 24rpx !important;
  font-size: 26rpx;
}

.favorite-actions .btn-secondary,
.user-actions .btn-secondary,
.result-bottom-btn {
  color: #5f4328 !important;
  background: linear-gradient(135deg, #fff8ec 0%, #f4ddb2 100%) !important;
  border: 2rpx solid rgba(146, 51, 36, 0.12) !important;
}

.user-image {
  margin-top: 8rpx;
}

.selfie-state {
  font-size: 24rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #f4e5cf;
  color: #835628;
}

.media-generate-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  background:
    radial-gradient(circle at 100% 0%, rgba(211, 160, 91, 0.12), transparent 34%),
    linear-gradient(180deg, rgba(255, 250, 243, 0.98), rgba(248, 241, 231, 0.96));
}

.media-generate-tip {
  font-size: 24rpx;
  line-height: 1.76;
  padding: 18rpx;
  border-radius: 20rpx;
  background: rgba(255, 247, 235, 0.7);
}

.media-style-group {
  display: flex;
  justify-content: center;
  align-items: center;
  flex-wrap: nowrap;
  gap: 12rpx;
  width: 100%;
  margin: 0 auto 2rpx;
  box-sizing: border-box;
}

.media-style-btn {
  flex: 1 1 0;
  min-width: 0;
  width: auto;
  min-height: 78rpx;
  line-height: 78rpx;
  padding: 0 18rpx !important;
  font-size: 24rpx !important;
  font-weight: 700;
  text-align: center;
  color: #6b543f !important;
  background: #f8f1e4 !important;
  border: 2rpx solid rgba(161, 38, 27, 0.18) !important;
  box-shadow: none !important;
}

.media-style-btn-active {
  color: #fff !important;
  background: linear-gradient(135deg, #a1261b, #c94335) !important;
  border-color: transparent !important;
}

.media-generate-submit {
  margin-top: 2rpx;
  width: 100%;
  min-height: 92rpx;
  line-height: 92rpx;
  font-size: 30rpx !important;
  color: #fff !important;
  background: linear-gradient(135deg, #9f2a1f 0%, #c84434 100%) !important;
  border: 2rpx solid rgba(125, 28, 21, 0.2) !important;
}

.media-generate-status {
  border-radius: 20rpx;
  padding: 18rpx 20rpx;
  font-size: 25rpx;
  line-height: 1.72;
}

.media-generate-status.muted {
  background: #f7f2e8;
  color: #7e6d58;
}

.media-generate-status.working {
  background: #fff5e6;
  color: #9a6628;
}

.media-generate-status.success {
  background: #e9f6ee;
  color: #1f6b4e;
}

.media-generate-status.error {
  background: #fff1f1;
  color: #9d3d3a;
}

.media-generate-image {
  margin-top: 4rpx;
}

.email-input {
  width: 100%;
  box-sizing: border-box;
  border-radius: 22rpx;
  border: 2rpx solid rgba(161, 38, 27, 0.2);
  background: #fffcf7;
  padding: 22rpx 20rpx;
  min-height: 90rpx;
  margin-top: 10rpx;
  margin-bottom: 14rpx;
  font-size: 33rpx;
  line-height: 1.4;
}

.email-input-error {
  border-color: #d23b3b;
  background: #fff4f4;
}

.email-section {
  scroll-margin-top: 80rpx;
}

.email-section-focus {
  border-color: rgba(161, 38, 27, 0.28);
}

.action-card {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  background:
    radial-gradient(circle at 100% 0%, rgba(147, 37, 29, 0.08), transparent 28%),
    linear-gradient(180deg, rgba(255, 250, 243, 0.98), rgba(248, 241, 231, 0.96));
}

.action-tip {
  font-size: 24rpx;
  line-height: 1.68;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(255, 247, 235, 0.74);
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.action-grid-full {
  grid-column: 1 / -1;
}

.result-bottom-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  margin: 0;
  min-height: 88rpx;
  line-height: 88rpx;
  padding: 0 !important;
  font-size: 28rpx;
  text-align: center;
  font-weight: 700;
}

.action-home-btn {
  width: 100%;
  margin-top: 4rpx;
  min-height: 92rpx;
  line-height: 92rpx;
  font-size: 30rpx !important;
  color: #fff !important;
  background: linear-gradient(135deg, #9f2a1f 0%, #c84434 100%) !important;
  border: 2rpx solid rgba(125, 28, 21, 0.2) !important;
}

.email-tip {
  font-size: 24rpx;
  margin-bottom: 6rpx;
}

.email-error {
  margin-top: -4rpx;
  margin-bottom: 14rpx;
  color: #b42323;
  font-size: 25rpx;
  line-height: 1.5;
}

.email-submit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 92rpx;
  line-height: 92rpx;
  padding: 0 !important;
  font-size: 30rpx;
  text-align: center;
  font-weight: 700;
  margin-top: 6rpx;
  color: #fff !important;
  background: linear-gradient(135deg, #9f2a1f 0%, #c84434 100%) !important;
  border: 2rpx solid rgba(125, 28, 21, 0.2) !important;
}

.email-status {
  margin-top: 12rpx;
  font-size: 26rpx;
}

.error {
  padding: 20rpx;
  border-color: rgba(180, 33, 33, 0.24);
  color: var(--danger-ink);
  background: var(--danger-bg);
}
