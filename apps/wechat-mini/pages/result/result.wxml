<view class="container page-root" style="padding-bottom: {{bottomPaddingPx}}px;">
  <view wx:if="{{!hasData}}" class="empty card">
    <view class="empty-title">暂无分析结果</view>
    <view class="text-muted">请返回上一页先提交分析。</view>
    <button class="btn btn-secondary" bindtap="backHome">返回输入页</button>
  </view>

  <block wx:if="{{hasData}}">
    <view class="emotion card">
      <view class="emotion-title">情绪反馈卡</view>
      <view class="emotion-row">
        <view class="emotion-key">主情绪</view>
        <view class="emotion-badge emotion-{{emotionCode}}">
          {{emotionLabel}}
          <text wx:if="{{emotionCode}}">（{{emotionCode}}）</text>
        </view>
      </view>

      <view class="emotion-subtitle">补充情绪</view>
      <view class="chip-wrap">
        <block wx:if="{{secondaryEmotions.length}}">
          <view wx:for="{{secondaryEmotions}}" wx:key="index" class="chip emotion-chip">
            {{item.label}}
            <text wx:if="{{item.code}}">（{{item.code}}）</text>
          </view>
        </block>
        <view wx:else class="chip-empty">暂无补充情绪</view>
      </view>

      <view class="emotion-subtitle">情绪概述</view>
      <view class="overview">{{emotionOverview}}</view>

      <view wx:if="{{speechTranscript}}" class="emotion-subtitle">语音识别文字</view>
      <view wx:if="{{speechTranscript}}" class="speech-transcript">{{speechTranscript}}</view>

      <view wx:if="{{!speechTranscript && speechTranscriptHint}}" class="emotion-subtitle">语音识别状态</view>
      <view wx:if="{{!speechTranscript && speechTranscriptHint}}" class="speech-transcript muted">
        {{speechTranscriptHint}}
      </view>

      <view class="emotion-subtitle">触发因素标签</view>
      <view class="chip-wrap">
        <block wx:if="{{triggerTags.length}}">
          <view wx:for="{{triggerTags}}" wx:key="*this" class="chip tag-chip">
            {{item}}
          </view>
        </block>
        <view wx:else class="chip-empty">暂无触发标签</view>
      </view>

      <view class="emotion-subtitle">今日建议</view>
      <view class="suggestion">{{dailySuggestion}}</view>

      <view class="emotion-subtitle">连续打卡</view>
      <view wx:if="{{retentionLoading}}" class="speech-transcript muted">正在刷新打卡状态...</view>
      <view wx:elif="{{retentionErrorMsg}}" class="speech-transcript muted">{{retentionErrorMsg}}</view>
      <view wx:else class="checkin-wrap">
        <view class="checkin-chip {{checkedTodayClass}}">
          {{checkedTodayText}}
        </view>
        <view class="checkin-meta">当前连续 {{currentStreak}} 天</view>
        <view class="checkin-meta">本月已打卡 {{monthCheckinDays}} 天</view>
        <view class="checkin-meta">最长连续 {{longestStreak}} 天</view>
      </view>

      <view wx:if="{{requestId}}" class="request-id text-muted">
        请求编号：{{requestId}}
      </view>
      <view wx:if="{{processingSummary}}" class="request-id text-muted">
        {{processingSummary}}
      </view>
    </view>

    <view class="section card">
      <view class="section-head">
        <view class="section-title">诗词回应</view>
        <view class="poet-tag">{{poet}}</view>
      </view>
      <image
        wx:if="{{poetImageUrl && !poetImageFailed}}"
        class="result-image"
        mode="widthFix"
        src="{{poetImageUrl}}"
        binderror="onPoetImageError"
      />
      <view wx:if="{{!poetImageUrl || poetImageFailed}}" class="img-placeholder">
        诗人图片暂不可用
      </view>
      <view class="poem-text">{{poemText}}</view>
      <view class="interpretation text-muted">{{interpretation}}</view>
      <view class="favorite-actions">
        <button
          class="btn btn-secondary mini-action-btn"
          loading="{{poemFavoriteLoading}}"
          disabled="{{poemFavoriteLoading}}"
          bindtap="togglePoemFavorite"
        >
          {{poemFavoriteButtonText}}
        </button>
        <view wx:if="{{poemFavoriteBadgeText}}" class="favorite-badge">{{poemFavoriteBadgeText}}</view>
      </view>
    </view>

    <view class="section card">
      <view class="section-head">
        <view class="section-title">国潮伙伴慰藉</view>
        <view class="poet-tag">{{guochaoName}}</view>
      </view>
      <image
        wx:if="{{guochaoImageUrl && !guochaoImageFailed}}"
        class="result-image"
        mode="widthFix"
        src="{{guochaoImageUrl}}"
        binderror="onGuochaoImageError"
      />
      <view wx:if="{{!guochaoImageUrl || guochaoImageFailed}}" class="img-placeholder">
        国潮图片暂不可用
      </view>
      <view class="comfort">{{comfort}}</view>
      <view class="favorite-actions">
        <button
          class="btn btn-secondary mini-action-btn"
          loading="{{guochaoFavoriteLoading}}"
          disabled="{{guochaoFavoriteLoading}}"
          bindtap="toggleGuochaoFavorite"
        >
          {{guochaoFavoriteButtonText}}
        </button>
        <view wx:if="{{guochaoFavoriteBadgeText}}" class="favorite-badge">{{guochaoFavoriteBadgeText}}</view>
      </view>
    </view>

    <view wx:if="{{favoriteErrorMsg}}" class="error card">{{favoriteErrorMsg}}</view>

    <view wx:if="{{userImagePreviewUrl || userImageRemoved}}" class="section card">
      <view class="section-head">
        <view class="section-title">本次自拍</view>
        <view wx:if="{{userImageRemoved}}" class="selfie-state">已从邮件中移除</view>
      </view>
      <view wx:if="{{!userImageRemoved}}" class="user-actions">
        <button class="btn btn-secondary mini-action-btn" bindtap="toggleUserImageVisible">
          {{userImageVisible ? '隐藏自拍' : '显示自拍'}}
        </button>
        <button class="btn mini-action-btn" bindtap="removeUserImageForEmail">从邮件移除</button>
      </view>
      <image
        wx:if="{{!userImageRemoved && userImageVisible && userImagePreviewUrl && !userImageFailed}}"
        class="result-image user-image"
        mode="widthFix"
        src="{{userImagePreviewUrl}}"
        binderror="onUserImageError"
      />
      <view
        wx:if="{{!userImageRemoved && userImageVisible && (!userImagePreviewUrl || userImageFailed)}}"
        class="img-placeholder"
      >
        自拍图片暂不可用
      </view>
    </view>

    <view id="email-section" class="section card email-section {{emailFocused ? 'email-section-focus' : ''}}">
      <view class="section-title">发送到邮箱（可选）</view>
      <view class="email-tip text-muted">请输入常用邮箱，结果将发送到该地址。</view>
      <input
        class="email-input {{emailError ? 'email-input-error' : ''}}"
        type="text"
        maxlength="320"
        confirm-type="done"
        adjust-position="{{true}}"
        cursor-spacing="150"
        placeholder="例如：name@example.com"
        value="{{email}}"
        bindinput="handleEmailInput"
        bindfocus="handleEmailFocus"
        bindblur="handleEmailBlur"
      />
      <view wx:if="{{emailError}}" class="email-error">{{emailError}}</view>
      <button
        class="btn btn-primary email-submit-btn"
        loading="{{isSendingEmail}}"
        disabled="{{isSendingEmail}}"
        bindtap="submitEmail"
      >
        {{isSendingEmail ? '发送中...' : '发送结果到邮箱'}}
      </button>
      <view wx:if="{{emailStatus}}" class="email-status text-muted">
        {{emailStatus}}
      </view>
    </view>

    <button class="btn btn-secondary result-bottom-btn" bindtap="goCalendar">查看情绪日历</button>
    <button class="btn btn-secondary result-bottom-btn" bindtap="goReport">查看周报复盘</button>
    <button class="btn btn-secondary result-bottom-btn" bindtap="goFavorites">查看我的收藏</button>
    <button class="btn btn-secondary result-bottom-btn" bindtap="goShareCard">导出分享卡片</button>
    <button class="btn btn-secondary result-bottom-btn" bindtap="goHistory">查看历史记录</button>
    <button class="btn result-bottom-btn" bindtap="backHome">返回继续分析</button>
  </block>
</view>
