<view class="container result-page" style="padding-bottom: {{bottomPaddingPx}}px;">
  <view wx:if="{{!hasData}}" class="empty card">
    <view class="empty-title">暂无分析结果</view>
    <view class="text-muted">请返回分析工作台后先提交一次分析。</view>
    <button class="btn btn-secondary" bindtap="backHome">返回分析</button>
  </view>

  <block wx:if="{{hasData}}">
    <view class="card result-hero">
      <view class="section-head">
        <view class="section-head-copy">
          <view class="result-title">今天的情绪摘要</view>
        </view>
        <view class="panel-badge panel-badge-{{resultHeroTheme}}">{{resultHeroTone}}</view>
      </view>

      <view class="result-hero-stage">
        <view class="result-hero-main result-hero-main-{{resultHeroTheme}}">
          <view class="result-hero-main-label">主情绪</view>
          <view class="emotion-badge emotion-{{emotionCode}}">{{emotionLabel}}</view>
          <view class="result-hero-main-text">{{emotionOverview}}</view>
        </view>
        <view class="result-hero-side">
          <view class="emotion-summary-card result-hero-side-card result-hero-side-card-{{resultHeroTheme}}">
            <view class="emotion-summary-label">今日状态</view>
            <view class="emotion-summary-value emotion-summary-value-small">{{checkedTodayText}}</view>
          </view>
          <view class="emotion-summary-card result-hero-side-card">
            <view class="emotion-summary-label">本月进度</view>
            <view class="emotion-summary-value">{{monthCheckinDays}} 天记录</view>
          </view>
        </view>
      </view>

      <view class="emotion-summary-grid">
        <view class="emotion-summary-card">
          <view class="emotion-summary-label">连续记录</view>
          <view class="emotion-summary-value">{{currentStreak}} 天</view>
        </view>
        <view class="emotion-summary-card">
          <view class="emotion-summary-label">最长连续</view>
          <view class="emotion-summary-value">{{longestStreak}} 天</view>
        </view>
      </view>

      <view wx:if="{{retentionLoading}}" class="request-id text-muted">记录状态更新中...</view>
      <view wx:if="{{retentionErrorMsg}}" class="request-id text-muted">{{retentionErrorMsg}}</view>

      <view class="result-block result-block-accent">
        <view class="result-block-title">今日建议</view>
        <view class="suggestion">{{dailySuggestion}}</view>
      </view>

      <view class="result-meta-grid">
        <view class="result-meta-card">
          <view class="emotion-subtitle">补充情绪</view>
          <view class="chip-wrap">
            <block wx:if="{{secondaryEmotions.length}}">
              <view wx:for="{{secondaryEmotions}}" wx:key="index" class="chip emotion-chip">{{item.label}}</view>
            </block>
            <view wx:else class="chip-empty">暂无补充情绪</view>
          </view>
        </view>
        <view class="result-meta-card">
          <view class="emotion-subtitle">触发因素</view>
          <view class="chip-wrap">
            <block wx:if="{{triggerTags.length}}">
              <view wx:for="{{triggerTags}}" wx:key="*this" class="chip tag-chip">{{item}}</view>
            </block>
            <view wx:else class="chip-empty">暂无触发标签</view>
          </view>
        </view>
      </view>

    </view>

    <view wx:if="{{speechTranscript || speechTranscriptHint || requestTextPreview || inputModeBadges.length}}" class="card section result-input-card">
      <view class="section-head">
        <view class="section-head-copy">
          <view class="section-title">本次输入回看</view>
        </view>
      </view>

      <view wx:if="{{inputModeBadges.length}}" class="chip-wrap">
        <view wx:for="{{inputModeBadges}}" wx:key="*this" class="chip tag-chip">{{item}}</view>
      </view>

      <view wx:if="{{requestTextPreview}}" class="result-block">
        <view class="result-block-title">文字输入</view>
        <view class="speech-transcript">{{requestTextPreview}}</view>
      </view>

      <view wx:if="{{speechTranscript}}" class="result-block">
        <view class="result-block-title">语音识别文字</view>
        <view class="speech-transcript">{{speechTranscript}}</view>
      </view>

      <view wx:if="{{!speechTranscript && speechTranscriptHint}}" class="result-block result-block-muted">
        <view class="result-block-title">录音说明</view>
        <view class="speech-transcript muted">{{speechTranscriptHint}}</view>
      </view>
    </view>

    <view class="section section-poem card">
      <view class="section-head">
        <view class="section-head-copy">
          <view class="section-title">诗词回应</view>
          <view class="section-sub result-card-sub">借一句古意，把这一刻轻轻接住。</view>
        </view>
        <view class="poet-tag">{{poet}}</view>
      </view>
      <view class="result-visual-frame result-visual-frame-poem">
        <image
          wx:if="{{poetImageUrl && !poetImageFailed}}"
          class="result-image"
          mode="widthFix"
          src="{{poetImageUrl}}"
          bindload="onPoetImageLoad"
          binderror="onPoetImageError"
        />
        <view wx:if="{{poetImageLoading && !poetImageFailed}}" class="img-loading-tip">诗人图片加载中...</view>
        <view wx:if="{{!poetImageUrl || poetImageFailed}}" class="img-placeholder">诗人图片暂不可用</view>
      </view>
      <view class="result-reading-block result-reading-block-poem">
        <view class="result-reading-mark">诗意回应</view>
        <view class="poem-text">{{poemText}}</view>
      </view>
      <view class="result-support-block">
        <view class="result-support-title">这句回应想告诉你</view>
        <view class="interpretation text-muted">{{interpretation}}</view>
      </view>
      <view class="favorite-actions result-card-footer">
        <button
          class="btn btn-secondary mini-action-btn"
          loading="{{poemFavoriteLoading}}"
          disabled="{{poemFavoriteLoading}}"
          bindtap="togglePoemFavorite"
        >
          {{poemFavoriteButtonText}}
        </button>
        <view wx:if="{{poemFavoriteBadgeText}}" class="favorite-badge">{{poemFavoriteBadgeText}}</view>
      </view>
    </view>

    <view class="section section-guochao card">
      <view class="section-head">
        <view class="section-head-copy">
          <view class="section-title">国潮伙伴慰藉</view>
          <view class="section-sub result-card-sub">换一种更直接的方式，陪你把情绪放松下来。</view>
        </view>
        <view class="poet-tag">{{guochaoName}}</view>
      </view>
      <view class="result-visual-frame result-visual-frame-guochao">
        <image
          wx:if="{{guochaoImageUrl && !guochaoImageFailed}}"
          class="result-image"
          mode="widthFix"
          src="{{guochaoImageUrl}}"
          bindload="onGuochaoImageLoad"
          binderror="onGuochaoImageError"
        />
        <view wx:if="{{guochaoImageLoading && !guochaoImageFailed}}" class="img-loading-tip">国潮图片加载中...</view>
        <view wx:if="{{!guochaoImageUrl || guochaoImageFailed}}" class="img-placeholder">国潮图片暂不可用</view>
      </view>
      <view class="result-reading-block result-reading-block-guochao">
        <view class="result-reading-mark">陪伴话语</view>
        <view class="comfort">{{comfort}}</view>
      </view>
      <view class="favorite-actions result-card-footer">
        <button
          class="btn btn-secondary mini-action-btn"
          loading="{{guochaoFavoriteLoading}}"
          disabled="{{guochaoFavoriteLoading}}"
          bindtap="toggleGuochaoFavorite"
        >
          {{guochaoFavoriteButtonText}}
        </button>
        <view wx:if="{{guochaoFavoriteBadgeText}}" class="favorite-badge">{{guochaoFavoriteBadgeText}}</view>
      </view>
    </view>

    <view wx:if="{{favoriteErrorMsg}}" class="error card">{{favoriteErrorMsg}}</view>

    <view wx:if="{{userImagePreviewUrl || userImageRemoved}}" class="section section-selfie card">
      <view class="section-head">
        <view class="section-head-copy">
          <view class="section-title">本次自拍</view>
          <view class="section-sub result-card-sub">保留这一刻的表情线索，你也可以随时隐藏或移出邮件。</view>
        </view>
        <view wx:if="{{userImageRemoved}}" class="selfie-state">已从邮件中移除</view>
      </view>
      <view wx:if="{{!userImageRemoved}}" class="result-visual-frame result-visual-frame-selfie">
        <image
          wx:if="{{userImageVisible && userImagePreviewUrl && !userImageFailed}}"
          class="result-image user-image"
          mode="widthFix"
          src="{{userImagePreviewUrl}}"
          binderror="onUserImageError"
        />
        <view
          wx:if="{{userImageVisible && (!userImagePreviewUrl || userImageFailed)}}"
          class="img-placeholder"
        >
          自拍图片暂不可用
        </view>
        <view wx:if="{{!userImageVisible}}" class="selfie-placeholder-card">
          <view class="selfie-placeholder-title">当前已隐藏自拍</view>
          <view class="selfie-placeholder-sub">需要时可点击下方按钮再次查看</view>
        </view>
      </view>
      <view wx:if="{{userImageRemoved}}" class="result-support-block result-support-block-muted">
        <view class="result-support-title">邮件状态</view>
        <view class="interpretation text-muted">这张自拍已从邮件内容中移除，但不会影响你当前查看结果。</view>
      </view>
      <view wx:if="{{!userImageRemoved}}" class="user-actions result-card-footer">
        <button class="btn btn-secondary mini-action-btn" bindtap="toggleUserImageVisible">
          {{userImageVisible ? '隐藏自拍' : '显示自拍'}}
        </button>
        <button class="btn btn-secondary mini-action-btn" bindtap="removeUserImageForEmail">从邮件移除</button>
      </view>
      <view wx:if="{{!userImageRemoved}}" class="selfie-note">
        <view class="selfie-note-dot"></view>
        <view class="selfie-note-text">仅用于本次结果展示与邮件发送控制，不会单独出现在首页流中。</view>
      </view>
    </view>

    <view class="section section-action card action-card">
      <view class="section-head">
        <view class="section-head-copy">
          <view class="section-title">继续查看</view>
        </view>
      </view>
      <view class="action-grid">
        <button class="btn btn-secondary result-bottom-btn" bindtap="goHomeTab">首页</button>
        <button class="btn btn-secondary result-bottom-btn" bindtap="goJourneyTab">记录页</button>
        <button class="btn btn-secondary result-bottom-btn" bindtap="goCalendar">情绪日历</button>
        <button class="btn btn-secondary result-bottom-btn" bindtap="goReport">周报复盘</button>
        <button class="btn btn-secondary result-bottom-btn" bindtap="goHistory">全部历史</button>
        <button class="btn btn-secondary result-bottom-btn" bindtap="goFavorites">我的收藏</button>
      </view>
    </view>
  </block>

  <view wx:if="{{emailSheetVisible}}" class="sheet-mask" bindtap="closeEmailSheet"></view>
  <view
    wx:if="{{emailSheetVisible}}"
    class="section section-email card email-sheet {{emailFocused ? 'email-section-focus' : ''}}"
    style="bottom: {{keyboardHeight}}px;"
    catchtap="handleEmailPanelTap"
  >
    <view class="sheet-handle"></view>
    <view class="email-sheet-head">
      <view>
        <view class="section-title">发送到邮箱</view>
      </view>
      <view wx:if="{{emailStatus}}" class="email-status-inline email-status-inline-{{emailStatusClass}}">
        {{emailStatus}}
      </view>
    </view>
    <view class="email-tip text-muted">请输入常用邮箱，结果将发送到该地址。</view>
    <input
      class="email-input {{emailError ? 'email-input-error' : ''}}"
      type="text"
      maxlength="320"
      confirm-type="done"
      adjust-position="{{true}}"
      cursor-spacing="150"
      placeholder="例如：name@example.com"
      value="{{email}}"
      bindinput="handleEmailInput"
      bindfocus="handleEmailFocus"
      bindblur="handleEmailBlur"
    />
    <view wx:if="{{emailError}}" class="email-error">{{emailError}}</view>
    <button
      class="btn btn-primary email-submit-btn"
      loading="{{isSendingEmail}}"
      disabled="{{isSendingEmail}}"
      bindtap="submitEmail"
    >
      {{isSendingEmail ? '发送中...' : '发送结果到邮箱'}}
    </button>
    <button class="btn btn-secondary email-cancel-btn" bindtap="closeEmailSheet">收起面板</button>
  </view>

  <view wx:if="{{hasData && !emailSheetVisible}}" class="result-action-bar" style="bottom: {{actionBarBottomPx}}px;">
    <view class="result-action-bar-head">
      <view class="result-action-bar-copy">
        <view class="result-action-bar-badge">快捷动作</view>
        <view class="result-action-bar-title">接下来想怎么继续</view>
      </view>
      <view class="result-action-bar-sub">保留本次结果</view>
    </view>
    <view class="result-action-grid">
      <button class="result-action-btn result-action-btn-primary" bindtap="backHome">
        <view class="result-action-btn-title">再次分析</view>
        <view class="result-action-btn-sub">回到工作台</view>
      </button>
      <button class="result-action-btn" bindtap="goStyleStudio">
        <view class="result-action-btn-title">换风格</view>
        <view class="result-action-btn-sub">去风格页</view>
      </button>
      <button class="result-action-btn" bindtap="openEmailSheet">
        <view class="result-action-btn-title">发邮箱</view>
        <view class="result-action-btn-sub">发送结果</view>
      </button>
      <button class="result-action-btn" bindtap="goShareCard">
        <view class="result-action-btn-title">分享</view>
        <view class="result-action-btn-sub">生成分享卡</view>
      </button>
    </view>
  </view>
</view>
