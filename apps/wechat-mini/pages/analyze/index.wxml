<view class="container page-root shell-page analyze-page">
  <view class="hero card">
    <view class="hero-head">
      <view class="hero-copy">
        <view class="hero-title">把这一刻交给我</view>
        <view class="hero-subtitle">文字、自拍、录音可任选</view>
      </view>
      <view class="hero-stamp analyze-hero-badge">
        <view class="analyze-hero-badge-dot"></view>
        <text class="analyze-hero-badge-text">分析</text>
      </view>
    </view>
    <view class="hero-chip-row analyze-summary-row">
      <view class="hero-chip analyze-summary-chip">
        <view class="hero-chip-line">
          <view class="hero-chip-label">文字</view>
          <view class="hero-chip-value">{{text ? '已填写' : '未填写'}}</view>
        </view>
      </view>
      <view class="hero-chip analyze-summary-chip">
        <view class="hero-chip-line">
          <view class="hero-chip-label">自拍</view>
          <view class="hero-chip-value">{{imageTempPath ? '已确认' : pendingSelfiePath ? '待确认' : '未添加'}}</view>
        </view>
      </view>
      <view class="hero-chip analyze-summary-chip">
        <view class="hero-chip-line">
          <view class="hero-chip-label">录音</view>
          <view class="hero-chip-value">{{audioTempPath ? '已录制' : isRecording ? '录音中' : '未录制'}}</view>
        </view>
      </view>
    </view>
  </view>

  <view class="section section-thought card">
    <view class="section-head section-head-tight">
      <view class="section-head-main">
        <view class="section-index">01</view>
        <view class="section-heading">
          <view class="section-title">写下现在的感受</view>
        </view>
      </view>
      <view class="section-state">{{text ? '已填写' : '未填写'}}</view>
    </view>
    <textarea
      class="thought-input"
      placeholder="例如：今天有点难过，考试没发挥好。"
      maxlength="4000"
      value="{{text}}"
      bindinput="handleTextInput"
    />
    <view class="thought-footer">
      <view class="thought-footer-note">{{textLength ? '继续写也可以，写一点也够。' : '从一句话开始就好。'}}</view>
      <view class="thought-footer-count">{{textLength}} / 4000</view>
    </view>
  </view>

  <view class="section section-selfie card">
    <view class="section-head section-head-tight">
      <view class="section-head-main">
        <view class="section-index">02</view>
        <view class="section-heading">
          <view class="section-title">拍一张自拍</view>
        </view>
      </view>
      <view class="section-state">{{imageTempPath ? '已确认' : pendingSelfiePath ? '待确认' : '未添加'}}</view>
    </view>
    <view wx:if="{{isDevtools || isHarmonyOS}}" class="runtime-note-row">
      <view wx:if="{{isDevtools}}" class="inline-note text-muted">开发者工具里请以真机为准。</view>
      <view wx:if="{{isHarmonyOS}}" class="inline-note text-muted">已启用 HarmonyOS 兼容策略。</view>
    </view>
    <view class="media-row">
      <button class="btn btn-secondary media-btn" bindtap="chooseSelfie">前置自拍</button>
      <button
        class="btn media-btn media-btn-plain"
        disabled="{{!imageTempPath && !pendingSelfiePath}}"
        bindtap="clearImage"
      >
        清除
      </button>
    </view>

    <view wx:if="{{pendingSelfiePath}}" class="preview-wrap preview-wrap-pending">
      <view class="preview-label">待确认自拍</view>
      <image class="preview-image framed-image" mode="widthFix" src="{{pendingSelfiePath}}" />
      <view class="confirm-stack">
        <button class="btn btn-primary confirm-primary-btn" bindtap="confirmSelfie">确认使用</button>
        <view class="media-row confirm-row">
          <button class="btn btn-secondary" bindtap="retakeSelfie">重新拍摄</button>
          <button class="btn media-btn-plain" bindtap="cancelPendingSelfie">取消</button>
        </view>
      </view>
    </view>

    <view wx:elif="{{imageTempPath}}" class="preview-wrap">
      <view class="preview-label">已确认自拍</view>
      <image class="preview-image framed-image" mode="widthFix" src="{{imageTempPath}}" />
    </view>
  </view>

  <view class="section section-audio card">
    <view class="section-head section-head-tight">
      <view class="section-head-main">
        <view class="section-index">03</view>
        <view class="section-heading">
          <view class="section-title">录一段声音</view>
        </view>
      </view>
      <view class="section-state">{{audioTempPath ? '已录制' : isRecording ? '录音中' : '未录制'}}</view>
    </view>
    <view class="media-row">
      <button
        wx:if="{{!isRecording}}"
        class="btn btn-secondary media-btn"
        disabled="{{isRecordBusy}}"
        bindtap="startRecord"
      >
        {{isRecordBusy ? "录音启动中..." : "开始录音"}}
      </button>
      <button
        wx:if="{{isRecording}}"
        class="btn btn-primary media-btn"
        disabled="{{isRecordBusy}}"
        bindtap="stopRecord"
      >
        {{isRecordBusy ? "停止中..." : "停止录音"}}
      </button>
      <button class="btn media-btn media-btn-plain" disabled="{{!audioTempPath}}" bindtap="clearAudio">
        清除
      </button>
    </view>
    <view class="audio-status text-muted audio-status-panel">
      <view class="audio-status-head">
        <view class="audio-status-badge {{isRecording ? 'audio-status-badge-live' : ''}}">
          <view class="audio-status-dot"></view>
          <text wx:if="{{isRecording}}">录音中</text>
          <text wx:elif="{{audioTempPath}}">已录制</text>
          <text wx:else>等待录音</text>
        </view>
        <view class="audio-status-time">
          <text wx:if="{{isRecording}}">{{recordSeconds}} 秒</text>
          <text wx:elif="{{audioTempPath}}">可直接提交</text>
          <text wx:else>最长 60 秒</text>
        </view>
      </view>
    </view>
  </view>

  <view class="analyze-dock-spacer"></view>

  <view class="analyze-dock">
    <view class="card analyze-dock-card">
      <view class="analyze-dock-head">
        <view class="analyze-dock-copy">
          <view class="analyze-dock-badge">
            <text wx:if="{{isSubmitting}}">处理中</text>
            <text wx:elif="{{submitStage === 'failed' || errorMsg}}">需要处理</text>
            <text wx:elif="{{pendingSelfiePath && !imageTempPath}}">待确认</text>
            <text wx:elif="{{text || imageTempPath || audioTempPath}}">已准备</text>
            <text wx:else>任选输入</text>
          </view>
          <view class="analyze-dock-title">
            <text wx:if="{{isSubmitting}}">正在为你生成分析结果</text>
            <text wx:elif="{{submitStage === 'failed' || errorMsg}}">可以直接重试</text>
            <text wx:elif="{{pendingSelfiePath && !imageTempPath}}">先确认这张自拍</text>
            <text wx:elif="{{text || imageTempPath || audioTempPath}}">准备好后开始分析</text>
            <text wx:else>至少添加 1 项输入</text>
          </view>
          <view class="analyze-dock-sub">
            <text wx:if="{{isSubmitting}}">{{submitStatusText}}</text>
            <text wx:elif="{{pendingSelfiePath && !imageTempPath}}">确认后可把自拍一起带入分析</text>
            <text wx:elif="{{readyInputCount}}">已准备 {{readyInputCount}} 项输入</text>
            <text wx:else>文字、自拍、录音任选一种即可</text>
          </view>
        </view>
      </view>

      <view wx:if="{{submitStage === 'failed' || errorMsg}}" class="analyze-dock-status analyze-dock-status-failed">
        <view class="analyze-dock-status-title">需要处理</view>
        <view class="analyze-dock-status-text">{{errorMsg || submitStatusText}}</view>
      </view>
      <view
        wx:elif="{{isSubmitting || submitStage === 'uploading' || submitStage === 'analyzing' || submitStage === 'rendering'}}"
        class="analyze-dock-status analyze-dock-status-active"
      >
        <view class="analyze-dock-status-title">
          <text wx:if="{{submitStage === 'uploading'}}">上传中</text>
          <text wx:elif="{{submitStage === 'analyzing'}}">分析中</text>
          <text wx:elif="{{submitStage === 'rendering'}}">结果生成中</text>
          <text wx:else>处理中</text>
        </view>
        <view class="analyze-dock-status-text">{{submitStatusText}}</view>
      </view>

      <button
        class="btn btn-primary submit-btn analyze-dock-btn"
        loading="{{isSubmitting}}"
        disabled="{{isSubmitting}}"
        bindtap="submitAnalyze"
      >
        {{submitButtonText}}
      </button>
    </view>
  </view>
</view>
