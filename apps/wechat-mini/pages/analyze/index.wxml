<view class="container analyze-page">
  <view class="card analyze-head-card">
    <view class="analyze-head-top">
      <view class="analyze-head-title">情绪分析</view>
      <view class="analyze-head-chip">{{isSubmitting ? "处理中" : "待提交"}}</view>
    </view>
    <view class="analyze-head-grid">
      <view class="analyze-head-item">
        <view class="analyze-head-label">文字</view>
        <view class="analyze-head-value">{{text ? "已填" : "未填"}}</view>
      </view>
      <view class="analyze-head-item">
        <view class="analyze-head-label">自拍</view>
        <view class="analyze-head-value">{{imageTempPath ? "已确认" : pendingSelfiePath ? "待确认" : "未加"}}</view>
      </view>
      <view class="analyze-head-item">
        <view class="analyze-head-label">录音</view>
        <view class="analyze-head-value">{{audioTempPath ? "已录" : isRecording ? "录音中" : "未录"}}</view>
      </view>
    </view>
  </view>

  <view wx:if="{{entrySource === 'study_quiz' && entryHint}}" class="card analyze-entry-card">
    <view class="analyze-entry-title">小测摘要</view>
    <view class="analyze-entry-text">{{entryHint}}</view>
  </view>

  <view class="card analyze-section">
    <view class="analyze-section-head">
      <view class="analyze-section-title">文字</view>
      <view class="analyze-section-state">{{text ? "已填写" : "未填写"}}</view>
    </view>
    <textarea
      class="thought-input"
      placeholder="写一句当前感受"
      maxlength="4000"
      value="{{text}}"
      bindinput="handleTextInput"
    />
    <view class="thought-footer">
      <view class="thought-footer-count">{{textLength}} / 4000</view>
    </view>
  </view>

  <view class="card analyze-section">
    <view class="analyze-section-head">
      <view class="analyze-section-title">自拍</view>
      <view class="analyze-section-state">{{imageTempPath ? "已确认" : pendingSelfiePath ? "待确认" : "未添加"}}</view>
    </view>
    <view wx:if="{{isDevtools || isHarmonyOS}}" class="runtime-note-row">
      <view wx:if="{{isDevtools}}" class="inline-note text-muted">开发者工具请以真机为准</view>
      <view wx:if="{{isHarmonyOS}}" class="inline-note text-muted">已启用 HarmonyOS 兼容</view>
    </view>
    <view class="media-row">
      <button class="btn btn-secondary media-btn" bindtap="chooseSelfie">前置自拍</button>
      <button
        class="btn media-btn media-btn-plain"
        disabled="{{!imageTempPath && !pendingSelfiePath}}"
        bindtap="clearImage"
      >
        清除
      </button>
    </view>

    <view wx:if="{{pendingSelfiePath}}" class="preview-wrap preview-wrap-pending">
      <image class="preview-image framed-image" mode="widthFix" src="{{pendingSelfiePath}}" />
      <view class="confirm-stack">
        <button class="btn btn-primary confirm-primary-btn" bindtap="confirmSelfie">使用这张</button>
        <view class="media-row confirm-row">
          <button class="btn btn-secondary" bindtap="retakeSelfie">重拍</button>
          <button class="btn media-btn-plain" bindtap="cancelPendingSelfie">取消</button>
        </view>
      </view>
    </view>

    <view wx:elif="{{imageTempPath}}" class="preview-wrap">
      <image class="preview-image framed-image" mode="widthFix" src="{{imageTempPath}}" />
    </view>
  </view>

  <view class="card analyze-section">
    <view class="analyze-section-head">
      <view class="analyze-section-title">录音</view>
      <view class="analyze-section-state">{{audioTempPath ? "已录制" : isRecording ? "录音中" : "未录制"}}</view>
    </view>
    <view class="media-row">
      <button
        wx:if="{{!isRecording}}"
        class="btn btn-secondary media-btn"
        disabled="{{isRecordBusy}}"
        bindtap="startRecord"
      >
        {{isRecordBusy ? "启动中..." : "开始录音"}}
      </button>
      <button
        wx:if="{{isRecording}}"
        class="btn btn-primary media-btn"
        disabled="{{isRecordBusy}}"
        bindtap="stopRecord"
      >
        {{isRecordBusy ? "停止中..." : "停止录音"}}
      </button>
      <button class="btn media-btn media-btn-plain" disabled="{{!audioTempPath}}" bindtap="clearAudio">
        清除
      </button>
    </view>
    <view class="audio-status text-muted audio-status-panel">
      <view class="audio-status-head">
        <view class="audio-status-badge {{isRecording ? 'audio-status-badge-live' : ''}}">
          <view class="audio-status-dot"></view>
          <text wx:if="{{isRecording}}">录音中</text>
          <text wx:elif="{{audioTempPath}}">已录制</text>
          <text wx:else>待录音</text>
        </view>
        <view class="audio-status-time">
          <text wx:if="{{isRecording}}">{{recordSeconds}} 秒</text>
          <text wx:elif="{{audioTempPath}}">可提交</text>
          <text wx:else>最长 60 秒</text>
        </view>
      </view>
    </view>
  </view>

  <view class="analyze-dock-spacer"></view>

  <view class="analyze-dock">
    <view class="card analyze-dock-card">
      <view class="analyze-dock-head">
        <view class="analyze-dock-copy">
          <view class="analyze-dock-title">
            <text wx:if="{{isSubmitting}}">处理中</text>
            <text wx:elif="{{submitStage === 'failed' || errorMsg}}">提交失败</text>
            <text wx:elif="{{pendingSelfiePath && !imageTempPath}}">请先确认自拍</text>
            <text wx:elif="{{text || imageTempPath || audioTempPath}}">可以提交</text>
            <text wx:else>请先输入</text>
          </view>
          <view class="analyze-dock-sub">
            <text wx:if="{{isSubmitting}}">{{submitStatusText}}</text>
            <text wx:elif="{{submitStage === 'failed' || errorMsg}}">{{errorMsg || "请重试"}}</text>
            <text wx:elif="{{readyInputCount}}">{{readyInputCount}} 项已准备</text>
            <text wx:else>文字 / 自拍 / 录音任选</text>
          </view>
        </view>
      </view>

      <view wx:if="{{isSubmitting}}" class="analyze-progress-wrap">
        <view class="analyze-progress-meta">
          <view class="analyze-progress-title">当前进度</view>
          <view class="analyze-progress-percent">{{submitProgressPercent}}%</view>
        </view>
        <view class="analyze-progress-track">
          <view class="analyze-progress-fill" style="width: {{submitProgressPercent}}%;"></view>
        </view>
      </view>

      <button
        class="btn btn-primary submit-btn analyze-dock-btn"
        loading="{{isSubmitting}}"
        disabled="{{isSubmitting}}"
        bindtap="submitAnalyze"
      >
        {{submitButtonText}}
      </button>
    </view>
  </view>
</view>
