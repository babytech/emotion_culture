.analyze-page {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding-bottom: 420rpx;
}

.analyze-head-card {
  padding: 20rpx;
  border: none;
  background:
    radial-gradient(circle at 100% 0%, rgba(136, 182, 255, 0.26), transparent 38%),
    linear-gradient(135deg, #ffffff, #edf5ff);
}

.analyze-head-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.analyze-head-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #22324f;
}

.analyze-head-chip {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(69, 111, 189, 0.12);
  color: #4067b2;
  font-size: 22rpx;
}

.analyze-head-grid {
  margin-top: 14rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 8rpx;
}

.analyze-head-item {
  padding: 12rpx 10rpx;
  border-radius: 14rpx;
  background: #f4f8ff;
  text-align: center;
}

.analyze-head-label {
  font-size: 22rpx;
  color: #7485a9;
}

.analyze-head-value {
  margin-top: 6rpx;
  font-size: 27rpx;
  font-weight: 700;
  color: #243652;
}

.analyze-entry-card,
.analyze-section {
  padding: 18rpx;
  border: none;
}

.analyze-entry-card {
  background:
    radial-gradient(circle at 100% 0%, rgba(255, 230, 168, 0.24), transparent 38%),
    linear-gradient(135deg, #ffffff, #f3f8ff);
}

.analyze-entry-title {
  font-size: 27rpx;
  font-weight: 700;
  color: #2a3c5c;
}

.analyze-entry-text {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.62;
  color: #586b92;
}

.analyze-section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.analyze-section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #243450;
}

.analyze-section-state {
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  font-size: 21rpx;
  color: #5a74a5;
  background: #edf3ff;
}

.runtime-note-row {
  margin-top: 10rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.inline-note {
  padding: 10rpx 12rpx;
  border-radius: 12rpx;
  background: #f5f8ff;
  font-size: 22rpx;
  line-height: 1.5;
}

.thought-input {
  margin-top: 12rpx;
  min-height: 230rpx;
  width: 100%;
  border-radius: 14rpx;
  border: 2rpx solid rgba(88, 116, 166, 0.14);
  background: #f8fbff;
  padding: 16rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  line-height: 1.68;
  color: #253754;
}

.thought-footer {
  margin-top: 10rpx;
  display: flex;
  justify-content: flex-end;
}

.thought-footer-count {
  font-size: 22rpx;
  color: #8193b3;
}

.media-row {
  margin-top: 12rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx;
}

.media-row .btn {
  width: 100%;
  min-height: 72rpx;
  line-height: 72rpx;
  padding: 0 !important;
  font-size: 24rpx !important;
}

.media-btn-plain {
  color: #5b7098 !important;
  background: #f4f8ff !important;
  border: 2rpx solid rgba(92, 116, 157, 0.18) !important;
  box-shadow: none !important;
}

.preview-wrap {
  margin-top: 12rpx;
  padding: 10rpx;
  border-radius: 14rpx;
  background: #f4f8ff;
}

.preview-wrap-pending {
  background:
    radial-gradient(circle at 100% 0%, rgba(128, 174, 255, 0.22), transparent 38%),
    #f0f6ff;
}

.preview-image,
.framed-image {
  width: 100%;
  border-radius: 12rpx;
  overflow: hidden;
}

.confirm-stack {
  margin-top: 12rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.confirm-primary-btn {
  width: 100%;
  min-height: 76rpx;
  line-height: 76rpx;
  padding: 0 !important;
  font-size: 25rpx !important;
}

.confirm-row {
  margin-top: 0;
}

.audio-status-panel {
  margin-top: 12rpx;
  padding: 12rpx;
  border-radius: 12rpx;
  background: #f5f8ff;
}

.audio-status-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.audio-status-badge {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(86, 115, 168, 0.12);
  color: #5572a6;
  font-size: 21rpx;
}

.audio-status-badge-live {
  background: rgba(47, 111, 255, 0.14);
  color: #2f6fff;
}

.audio-status-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: currentColor;
}

.audio-status-badge-live .audio-status-dot {
  animation: pulse-dot 1.2s ease-in-out infinite;
}

.audio-status-time {
  font-size: 22rpx;
  color: #7285aa;
}

.analyze-dock-spacer {
  height: 230rpx;
}

.analyze-dock {
  position: fixed;
  left: 20rpx;
  right: 20rpx;
  z-index: 980;
  bottom: calc(112rpx + constant(safe-area-inset-bottom));
  bottom: calc(112rpx + env(safe-area-inset-bottom));
}

.analyze-dock-card {
  padding: 14rpx;
  border: none;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 12rpx 28rpx rgba(53, 89, 152, 0.16);
}

.analyze-dock-head {
  margin-bottom: 10rpx;
}

.analyze-dock-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #243550;
}

.analyze-dock-sub {
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: #61759d;
  word-break: break-word;
}

.submit-btn,
.analyze-dock-btn {
  width: 100%;
  min-height: 80rpx;
  line-height: 80rpx;
  padding: 0 !important;
  font-size: 28rpx !important;
}

@keyframes pulse-dot {
  0%,
  100% {
    opacity: 1;
    transform: scale(1);
  }
  50% {
    opacity: 0.4;
    transform: scale(1.28);
  }
}
