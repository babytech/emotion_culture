.page-root {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.analyze-page {
  padding-bottom: 260rpx;
}

.hero {
  padding: 32rpx 28rpx 28rpx;
  background:
    radial-gradient(circle at 85% 12%, rgba(255, 255, 255, 0.45), transparent 26%),
    linear-gradient(135deg, rgba(147, 37, 29, 0.16), rgba(211, 160, 91, 0.2)),
    var(--card);
}

.hero-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.hero-copy {
  flex: 1;
  min-width: 0;
}

.hero-title {
  font-size: 50rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
  line-height: 1.18;
  color: #40271b;
}

.hero-subtitle {
  margin-top: 10rpx;
  font-size: 25rpx;
  line-height: 1.6;
  color: #735c4d;
}

.hero-stamp {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 250, 242, 0.78);
  border: 2rpx solid rgba(147, 37, 29, 0.12);
  font-size: 22rpx;
  color: #7d5640;
  white-space: nowrap;
}

.analyze-hero-badge {
  position: relative;
  z-index: 1;
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 18rpx 12rpx 16rpx;
  background:
    linear-gradient(135deg, rgba(255, 252, 247, 0.94), rgba(250, 237, 216, 0.88));
  border: 2rpx solid rgba(147, 37, 29, 0.08);
  box-shadow: 0 10rpx 20rpx rgba(124, 76, 40, 0.08);
  color: #7d5640;
}

.analyze-hero-badge-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, rgba(211, 160, 91, 0.98), rgba(199, 128, 53, 0.92));
  box-shadow: 0 0 0 6rpx rgba(211, 160, 91, 0.12);
}

.analyze-hero-badge-text {
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.hero-chip-row {
  margin-top: 22rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.hero-chip {
  padding: 14rpx 16rpx;
  border-radius: 22rpx;
  background: rgba(255, 250, 243, 0.8);
  border: 2rpx solid rgba(147, 37, 29, 0.08);
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.18);
}

.analyze-summary-row {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.analyze-summary-chip {
  min-width: 0;
}

.hero-chip-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
}

.hero-chip-label {
  font-size: 21rpx;
  color: #896f5d;
}

.hero-chip-value {
  font-size: 23rpx;
  font-weight: 700;
  color: #7b4b2a;
  white-space: nowrap;
}

.section {
  padding: 28rpx 24rpx;
}

.section-thought {
  background:
    radial-gradient(circle at 100% 0%, rgba(211, 160, 91, 0.12), transparent 28%),
    linear-gradient(180deg, rgba(255, 251, 245, 0.98), rgba(248, 241, 232, 0.96));
}

.section-selfie {
  background:
    radial-gradient(circle at 0% 0%, rgba(147, 37, 29, 0.08), transparent 28%),
    linear-gradient(180deg, rgba(255, 250, 245, 0.98), rgba(249, 240, 235, 0.96));
}

.section-audio {
  background:
    radial-gradient(circle at 100% 0%, rgba(211, 160, 91, 0.1), transparent 30%),
    linear-gradient(180deg, rgba(255, 251, 244, 0.98), rgba(247, 239, 230, 0.96));
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.section-head-tight {
  margin-bottom: 16rpx;
}

.section-head-main {
  min-width: 0;
  flex: 1;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.section-index {
  width: 52rpx;
  height: 52rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #f8ebd1, #efcf9a);
  color: #7f532f;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 700;
  flex-shrink: 0;
}

.section-thought .section-index {
  background: linear-gradient(135deg, #f7ead6, #eecb97);
}

.section-selfie .section-index {
  background: linear-gradient(135deg, #f8e4df, #efc1b5);
}

.section-audio .section-index {
  background: linear-gradient(135deg, #f7efd9, #efdbad);
}

.section-heading {
  flex: 1;
  min-width: 0;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.25;
}

.section-state {
  flex-shrink: 0;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 248, 235, 0.92);
  border: 2rpx solid rgba(147, 37, 29, 0.08);
  font-size: 22rpx;
  color: #855731;
}

.runtime-note-row {
  margin-top: -4rpx;
  margin-bottom: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.inline-note {
  padding: 14rpx 16rpx;
  border-radius: 18rpx;
  background: rgba(255, 248, 235, 0.74);
  font-size: 23rpx;
  line-height: 1.6;
}

.thought-input {
  min-height: 260rpx;
  width: 100%;
  border-radius: 22rpx;
  background:
    linear-gradient(180deg, rgba(255, 254, 250, 0.98), rgba(253, 247, 238, 0.96));
  border: 2rpx solid rgba(161, 38, 27, 0.16);
  box-shadow:
    inset 0 2rpx 0 rgba(255, 255, 255, 0.72),
    0 10rpx 18rpx rgba(122, 79, 45, 0.06);
  padding: 22rpx 20rpx 18rpx;
  line-height: 1.72;
  font-size: 29rpx;
  box-sizing: border-box;
}

.thought-footer {
  margin-top: 14rpx;
  padding: 0 2rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.thought-footer-note {
  min-width: 0;
  flex: 1;
  font-size: 22rpx;
  color: #8a7361;
}

.thought-footer-count {
  flex-shrink: 0;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 247, 235, 0.92);
  border: 2rpx solid rgba(147, 37, 29, 0.08);
  font-size: 21rpx;
  color: #845933;
}

.media-row {
  display: flex;
  gap: 14rpx;
  flex-wrap: wrap;
}

.media-btn {
  flex: 1;
  min-width: 0;
}

.media-btn-plain {
  color: #6a5240 !important;
  background: linear-gradient(135deg, rgba(255, 250, 242, 0.96), rgba(245, 234, 216, 0.96)) !important;
  border: 2rpx solid rgba(146, 51, 36, 0.12) !important;
  box-shadow: none !important;
}

.media-row .btn-secondary,
.confirm-row .btn-secondary {
  color: #5f4328 !important;
  background: linear-gradient(135deg, #fff8ec 0%, #f4ddb2 100%) !important;
  border: 2rpx solid rgba(146, 51, 36, 0.12) !important;
}

.media-row .btn-primary,
.confirm-row .btn-primary,
.submit-btn {
  color: #fff !important;
  background: linear-gradient(135deg, #9f2a1f 0%, #c84434 100%) !important;
  border: 2rpx solid rgba(125, 28, 21, 0.2) !important;
}

.preview-wrap {
  margin-top: 16rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  background: rgba(255, 251, 245, 0.74);
  border: 2rpx solid rgba(147, 37, 29, 0.08);
}

.preview-wrap-pending {
  background: rgba(255, 246, 239, 0.92);
}

.preview-label {
  margin-bottom: 10rpx;
  font-size: 24rpx;
  color: #7f4f27;
  font-weight: 600;
}

.preview-image {
  width: 100%;
  height: auto;
  border-radius: 22rpx;
  display: block;
}

.framed-image {
  border: 2rpx solid rgba(146, 51, 36, 0.1);
  box-shadow: inset 0 0 0 8rpx rgba(255, 250, 243, 0.85);
  background: #f6eee2;
}

.confirm-row {
  margin-top: 12rpx;
  flex-wrap: nowrap;
}

.confirm-row .btn {
  flex: 1;
  min-width: 0;
}

.confirm-stack {
  margin-top: 14rpx;
}

.confirm-primary-btn {
  width: 100%;
}

.audio-status {
  margin-top: 14rpx;
  font-size: 26rpx;
}

.audio-status-panel {
  padding: 18rpx 18rpx 16rpx;
  border-radius: 20rpx;
  background:
    linear-gradient(135deg, rgba(255, 248, 235, 0.86), rgba(248, 237, 216, 0.8));
  border: 2rpx solid rgba(147, 37, 29, 0.08);
}

.audio-status-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.audio-status-badge {
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 252, 247, 0.96);
  border: 2rpx solid rgba(147, 37, 29, 0.06);
  color: #7f562f;
  font-size: 22rpx;
  font-weight: 700;
}

.audio-status-badge-live {
  background: rgba(255, 241, 238, 0.96);
  color: #a1261b;
}

.audio-status-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, rgba(211, 160, 91, 0.98), rgba(199, 128, 53, 0.92));
  box-shadow: 0 0 0 6rpx rgba(211, 160, 91, 0.12);
}

.audio-status-badge-live .audio-status-dot {
  background: linear-gradient(135deg, rgba(200, 68, 52, 0.98), rgba(161, 38, 27, 0.92));
  box-shadow: 0 0 0 6rpx rgba(200, 68, 52, 0.12);
}

.audio-status-time {
  flex-shrink: 0;
  font-size: 22rpx;
  color: #8b7564;
}

.analyze-dock-spacer {
  height: 320rpx;
  flex-shrink: 0;
}

.analyze-dock {
  position: fixed;
  left: 26rpx;
  right: 26rpx;
  bottom: calc(244rpx + constant(safe-area-inset-bottom));
  bottom: calc(244rpx + env(safe-area-inset-bottom));
  z-index: 900;
  pointer-events: none;
}

.analyze-dock-card {
  position: relative;
  padding: 22rpx 22rpx 20rpx;
  background:
    radial-gradient(circle at 100% 0%, rgba(200, 68, 52, 0.12), transparent 30%),
    linear-gradient(180deg, rgba(255, 250, 243, 0.99), rgba(248, 239, 226, 0.99));
  border-color: rgba(146, 51, 36, 0.16);
  box-shadow: 0 16rpx 34rpx rgba(77, 44, 28, 0.16);
  pointer-events: auto;
  overflow: hidden;
}

.analyze-dock-card::before {
  content: "";
  position: absolute;
  left: 22rpx;
  right: 22rpx;
  top: 0;
  height: 8rpx;
  border-radius: 0 0 999rpx 999rpx;
  background: linear-gradient(90deg, rgba(200, 68, 52, 0.18), rgba(211, 160, 91, 0.28), rgba(200, 68, 52, 0.12));
}

.analyze-dock-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.analyze-dock-copy {
  min-width: 0;
  flex: 1;
}

.analyze-dock-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(159, 42, 31, 0.08);
  color: #8f3429;
  font-size: 22rpx;
  font-weight: 700;
}

.analyze-dock-title {
  margin-top: 10rpx;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.3;
  color: #43291b;
}

.analyze-dock-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.56;
  color: #735d4d;
}

.analyze-dock-status {
  margin-top: 16rpx;
  padding: 18rpx 18rpx 16rpx;
  border-radius: 22rpx;
  border: 2rpx solid rgba(146, 51, 36, 0.12);
}

.analyze-dock-status-active {
  background: rgba(255, 245, 227, 0.92);
  border-color: rgba(161, 38, 27, 0.18);
}

.analyze-dock-status-failed {
  background: rgba(255, 241, 241, 0.96);
  border-color: rgba(180, 33, 33, 0.22);
}

.analyze-dock-status-title {
  font-size: 25rpx;
  font-weight: 700;
  color: #6c4223;
}

.analyze-dock-status-text {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.62;
  color: #6f5a49;
}

.submit-btn {
  margin-top: 18rpx;
  width: 100%;
  min-height: 100rpx;
  line-height: 100rpx;
  font-size: 32rpx !important;
  box-shadow: 0 16rpx 28rpx rgba(159, 42, 31, 0.2) !important;
}

.analyze-dock-btn {
  margin-bottom: 0;
}
