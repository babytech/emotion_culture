.journey-page {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding-bottom: 148rpx;
}

.journey-hero {
  padding: 20rpx;
  border: none;
  background:
    radial-gradient(circle at 100% 0%, rgba(145, 186, 255, 0.25), transparent 36%),
    radial-gradient(circle at 10% 92%, rgba(255, 171, 122, 0.14), transparent 34%),
    linear-gradient(135deg, #ffffff, #eef6ff);
}

.journey-hero-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.journey-hero-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #22324e;
}

.journey-hero-chip {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(73, 119, 208, 0.12);
  color: #3f67b3;
  font-size: 22rpx;
}

.journey-hero-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #61739a;
}

.journey-hero-grid {
  margin-top: 14rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 8rpx;
}

.journey-hero-stat {
  padding: 12rpx 10rpx;
  border-radius: 14rpx;
  background: linear-gradient(135deg, #f4f8ff, #edf8ff 60%, #fff0e7);
  text-align: center;
}

.journey-hero-stat-label {
  font-size: 22rpx;
  color: #7486aa;
}

.journey-hero-stat-value {
  margin-top: 6rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #263856;
}

.journey-entry-card,
.journey-week-card,
.journey-today-card,
.journey-list-card {
  padding: 18rpx;
  border: none;
}

.journey-entry-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 10rpx;
}

.journey-entry-item {
  padding: 14rpx 10rpx;
  border-radius: 14rpx;
  background: linear-gradient(135deg, #f4f8ff, #eef8ff 56%, #fff1e8);
  text-align: center;
}

.journey-entry-badge {
  display: inline-flex;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: rgba(68, 107, 183, 0.12);
  color: #3f66ad;
  font-size: 21rpx;
}

.journey-entry-title {
  margin-top: 8rpx;
  font-size: 26rpx;
  font-weight: 700;
  color: #24334f;
}

.journey-entry-sub {
  margin-top: 6rpx;
  font-size: 21rpx;
  color: #7082a6;
}

.journey-week-head,
.journey-today-head,
.journey-list-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.journey-week-title,
.journey-today-title,
.journey-list-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #24334f;
}

.journey-week-chip {
  font-size: 22rpx;
  color: #5b76a9;
}

.journey-week-body {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.65;
  color: #52658d;
}

.journey-today-toggle {
  font-size: 22rpx;
  color: #5b76a9;
}

.journey-today-meta {
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #7b8cae;
}

.journey-today-headline {
  margin-top: 8rpx;
  font-size: 27rpx;
  line-height: 1.45;
  color: #2d3d5e;
}

.journey-today-summary,
.journey-today-note {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.65;
  color: #5d729a;
}

.journey-today-source {
  margin-top: 10rpx;
  font-size: 21rpx;
  color: #8a9ab8;
}

.journey-today-empty {
  margin-top: 10rpx;
  font-size: 23rpx;
  color: #8a9ab8;
}

.journey-list {
  margin-top: 10rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.journey-list-item {
  padding: 14rpx;
  border-radius: 14rpx;
  background: linear-gradient(135deg, #f5f8ff, #eef9ff);
}

.journey-list-item-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
}

.journey-list-item-emotion {
  font-size: 27rpx;
  font-weight: 700;
  color: #243450;
}

.journey-list-item-time {
  font-size: 21rpx;
  color: #8092b3;
}

.journey-list-item-summary {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.62;
  color: #586d96;
}

.journey-list-empty {
  margin-top: 8rpx;
  font-size: 23rpx;
  color: #8496b7;
}
