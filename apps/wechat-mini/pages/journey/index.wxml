<view class="container journey-page">
  <view class="card journey-hero">
    <view class="journey-hero-head">
      <view class="journey-hero-title">记录</view>
      <view class="journey-hero-chip">{{recentStatus}}</view>
    </view>
    <view class="journey-hero-sub">{{journeyHeroLead}}</view>
    <view class="journey-hero-grid">
      <view class="journey-hero-stat">
        <view class="journey-hero-stat-label">本月</view>
        <view class="journey-hero-stat-value">{{monthCount}}</view>
      </view>
      <view class="journey-hero-stat">
        <view class="journey-hero-stat-label">连续</view>
        <view class="journey-hero-stat-value">{{currentStreak}}</view>
      </view>
      <view class="journey-hero-stat">
        <view class="journey-hero-stat-label">最长</view>
        <view class="journey-hero-stat-value">{{longestStreak}}</view>
      </view>
    </view>
  </view>

  <view class="card journey-entry-card">
    <view class="journey-entry-grid">
      <view
        wx:for="{{entryCards}}"
        wx:key="key"
        class="journey-entry-item"
        data-path="{{item.path}}"
        bindtap="openEntry"
      >
        <view class="journey-entry-badge">{{item.badge}}</view>
        <view class="journey-entry-title">{{item.title}}</view>
        <view class="journey-entry-sub">{{item.subtitle}}</view>
      </view>
    </view>
  </view>

  <view class="card journey-week-card">
    <view class="journey-week-head">
      <view class="journey-week-title">本周摘要</view>
      <view class="journey-week-chip">{{weekInsightStatus}}</view>
    </view>
    <view class="journey-week-body">{{weekInsight}}</view>
  </view>

  <view class="card journey-today-card">
    <view class="journey-today-head">
      <view class="journey-today-title">历史上的今天</view>
      <view wx:if="{{todayHistory.available}}" class="journey-today-toggle" bindtap="toggleTodayHistory">
        {{todayHistory.expanded ? "收起" : "展开"}}
      </view>
    </view>
    <view wx:if="{{todayHistory.available}}">
      <view class="journey-today-meta">{{todayHistory.monthDay}} {{todayHistory.eventYear}}</view>
      <view class="journey-today-headline">{{todayHistory.headline}}</view>
      <view wx:if="{{todayHistory.expanded}}" class="journey-today-summary">{{todayHistory.summary}}</view>
      <view wx:if="{{todayHistory.expanded && todayHistory.optionalNote}}" class="journey-today-note">
        {{todayHistory.optionalNote}}
      </view>
      <view class="journey-today-source">{{todayHistory.sourceLabel}}{{todayHistory.cacheHit ? " · 缓存" : ""}}</view>
    </view>
    <view wx:else class="journey-today-empty">内容整理中</view>
  </view>

  <view class="card journey-list-card">
    <view class="journey-list-head">
      <view class="journey-list-title">最近记录</view>
    </view>

    <view wx:if="{{recentItems.length}}" class="journey-list">
      <view wx:for="{{recentItems}}" wx:key="historyId" class="journey-list-item" data-id="{{item.historyId}}" bindtap="openRecent">
        <view class="journey-list-item-head">
          <view class="journey-list-item-emotion">{{item.primaryEmotionLabel}}</view>
          <view class="journey-list-item-time">{{item.displayTime}}</view>
        </view>
        <view class="journey-list-item-summary">{{item.summary}}</view>
      </view>
    </view>
    <view wx:else class="journey-list-empty">暂无记录</view>
  </view>
</view>
