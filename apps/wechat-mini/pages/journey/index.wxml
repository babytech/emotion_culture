<view class="container shell-page">
  <view class="card shell-hero">
    <view class="section-head">
      <view class="section-head-copy">
        <view class="section-kicker">Journey Hub</view>
        <view class="shell-title">记录轨迹</view>
        <view class="section-sub journey-hero-sub">把最近记录、周摘要和历史片段放在同一条回看路径里。</view>
      </view>
      <view class="shell-badge journey-hero-badge">
        <view class="journey-hero-badge-dot"></view>
        <text class="journey-hero-badge-text">记录</text>
      </view>
    </view>
    <view class="journey-hero-stage">
      <view class="journey-hero-main-card">
        <view class="journey-hero-main-label">本月打卡</view>
        <view class="journey-hero-main-value">{{monthCount}}</view>
        <view class="journey-hero-main-meta">{{journeyHeroNote}}</view>
      </view>
      <view class="journey-hero-side">
        <view class="journey-hero-mini-card">
          <view class="journey-hero-mini-label">当前连续</view>
          <view class="journey-hero-mini-value">{{currentStreak}}</view>
        </view>
        <view class="journey-hero-mini-card journey-hero-mini-card-accent">
          <view class="journey-hero-mini-label">最长连续</view>
          <view class="journey-hero-mini-value">{{longestStreak}}</view>
        </view>
      </view>
    </view>
  </view>

  <view class="card section-card">
    <view class="section-head">
      <view class="section-head-copy">
        <view class="section-title">本周回看</view>
        <view class="section-sub">从周视角看你最近的情绪节奏。</view>
      </view>
      <view class="status-chip">{{weekInsightStatus}}</view>
    </view>
    <view class="journey-week-card">
      <view class="journey-week-mark">周</view>
      <view class="journey-week-body">{{weekInsight}}</view>
    </view>
  </view>

  <view class="card section-card">
    <view class="section-head">
      <view class="section-head-copy">
        <view class="section-title">历史上的今天</view>
        <view class="section-sub">默认收起，按需展开，不打断主线回看。</view>
      </view>
      <view class="today-history-head-actions">
        <view class="status-chip">{{todayHistory.statusText}}</view>
        <view wx:if="{{todayHistory.available}}" class="today-history-toggle" bindtap="toggleTodayHistory">
          {{todayHistory.expanded ? "收起" : "展开"}}
        </view>
      </view>
    </view>

    <view wx:if="{{todayHistory.available}}" class="journey-today-card">
      <view class="today-history-topline">
        <view class="today-history-date">{{todayHistory.monthDay}}</view>
        <view wx:if="{{todayHistory.eventYear}}" class="today-history-year">{{todayHistory.eventYear}}</view>
      </view>
      <view class="journey-today-headline">{{todayHistory.headline}}</view>
      <view wx:if="{{todayHistory.expanded}}" class="journey-today-summary">{{todayHistory.summary}}</view>
      <view wx:if="{{todayHistory.expanded && todayHistory.optionalNote}}" class="journey-today-note">
        {{todayHistory.optionalNote}}
      </view>
      <view class="journey-today-foot">
        <view class="journey-today-source">{{todayHistory.sourceLabel}}{{todayHistory.cacheHit ? " · 缓存" : ""}}</view>
        <view class="journey-today-tip">{{todayHistory.expanded ? "默认收起，不打断你的回看主线" : "点展开可查看摘要"}}</view>
      </view>
    </view>

    <view wx:else class="empty-copy">今日历史内容还在整理中，稍后会在这里补上一条简短历史片段。</view>
  </view>

  <view class="card section-card">
    <view class="section-head">
      <view class="section-head-copy">
        <view class="section-title">继续查看</view>
        <view class="section-sub">按你当前关注点切到对应板块继续回看。</view>
      </view>
      <view class="status-chip">快捷入口</view>
    </view>
    <view class="journey-entry-grid">
      <view
        wx:for="{{entryCards}}"
        wx:key="key"
        class="journey-entry-card journey-entry-card-{{item.tone}} {{item.featured ? 'journey-entry-card-featured' : ''}}"
        data-path="{{item.path}}"
        bindtap="openEntry"
      >
        <view class="journey-entry-head">
          <view class="journey-entry-badge">{{item.badge}}</view>
          <view class="journey-entry-link">进入</view>
        </view>
        <view class="journey-entry-title">{{item.title}}</view>
        <view class="journey-entry-sub">{{item.subtitle}}</view>
      </view>
    </view>
  </view>

  <view class="card section-card">
    <view class="section-head">
      <view class="section-head-copy">
        <view class="section-title">最近记录轨迹</view>
        <view class="section-sub">默认展示最近 3 条记录，点击可直达详情。</view>
      </view>
      <view class="status-chip">{{recentStatus}}</view>
    </view>

    <view wx:if="{{recentItems.length}}" class="journey-recent-list">
      <view
        wx:for="{{recentItems}}"
        wx:key="historyId"
        class="journey-recent-item"
        data-id="{{item.historyId}}"
        bindtap="openRecent"
      >
        <view class="journey-recent-card">
          <view class="journey-recent-head">
            <view class="journey-recent-emotion">{{item.primaryEmotionLabel}}</view>
            <view class="journey-recent-time">{{item.displayTime}}</view>
          </view>
          <view class="journey-recent-summary">{{item.summary}}</view>
          <view class="journey-recent-link">查看详情</view>
        </view>
      </view>
    </view>

    <view wx:else class="empty-copy journey-empty-copy">完成更多记录后，这里会展示最近 3 条轨迹。</view>
  </view>
</view>
