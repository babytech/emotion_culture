.checkin-page {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.checkin-topbar {
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  min-height: 64rpx;
}

.checkin-topbar-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1f2d49;
}

.checkin-topbar-rule {
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  font-size: 24rpx;
  color: #5d6b86;
}

.checkin-status-card {
  padding: 26rpx 22rpx 24rpx;
  text-align: center;
  background:
    radial-gradient(circle at 50% 0%, rgba(250, 220, 128, 0.34), transparent 54%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(248, 250, 255, 0.98));
}

.checkin-ring-wrap {
  display: flex;
  justify-content: center;
  margin-top: 4rpx;
}

.checkin-ring {
  width: 176rpx;
  height: 176rpx;
  border-radius: 999rpx;
  background: radial-gradient(circle at 30% 24%, #f9ecbe, #e8d38b 78%);
  box-shadow:
    0 0 0 10rpx rgba(244, 228, 179, 0.35),
    0 16rpx 30rpx rgba(224, 201, 138, 0.22);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.checkin-ring-streak {
  font-size: 46rpx;
  line-height: 1;
  font-weight: 700;
  color: #ffffff;
}

.checkin-ring-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.92);
}

.checkin-message {
  margin-top: 22rpx;
  font-size: 27rpx;
  line-height: 1.5;
  color: #2a3450;
}

.checkin-btn {
  margin-top: 18rpx;
  width: 100%;
}

.checkin-error {
  padding: 18rpx;
  color: #b03a52;
  border-color: rgba(176, 58, 82, 0.2);
  background: #fff4f6;
}

.checkin-grid-card {
  padding: 24rpx 20rpx 22rpx;
}

.checkin-grid-head {
  font-size: 30rpx;
  font-weight: 700;
  color: #27314b;
}

.checkin-points {
  color: #d0a93f;
  margin-left: 6rpx;
}

.checkin-days-grid {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 14rpx 10rpx;
}

.checkin-day-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.checkin-day-dot {
  width: 76rpx;
  height: 76rpx;
  border-radius: 999rpx;
  background: #edf0f8;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #a2acc4;
  border: 2rpx solid rgba(99, 115, 151, 0.08);
}

.checkin-day-dot-current {
  background: #ffffff;
  border-color: rgba(86, 105, 149, 0.42);
  color: #556995;
}

.checkin-day-dot-done {
  background: #4a5f92;
  border-color: rgba(74, 95, 146, 0.5);
  color: #ffffff;
}

.checkin-day-check {
  font-size: 32rpx;
  line-height: 1;
}

.checkin-day-plus {
  font-size: 23rpx;
  line-height: 1;
}

.checkin-day-label {
  font-size: 22rpx;
  color: #4f5c7a;
}

.checkin-award-mask {
  position: fixed;
  inset: 0;
  background: rgba(17, 24, 39, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.checkin-award-dialog {
  width: 78%;
  border-radius: 26rpx;
  overflow: hidden;
  background: #ffffff;
}

.checkin-award-head {
  padding: 44rpx 20rpx 10rpx;
  font-size: 68rpx;
  line-height: 1;
  text-align: center;
  color: #ffffff;
  font-weight: 700;
  background: linear-gradient(180deg, #f2dc93, #e8cd74);
}

.checkin-award-sub {
  padding: 10rpx 20rpx 22rpx;
  font-size: 25rpx;
  line-height: 1.5;
  text-align: center;
  color: rgba(255, 255, 255, 0.95);
  background: linear-gradient(180deg, #f2dc93, #e8cd74);
}

.checkin-award-preview {
  padding: 24rpx 14rpx 16rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 8rpx;
}

.checkin-award-day {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.checkin-award-dot {
  width: 64rpx;
  height: 64rpx;
  border-radius: 999rpx;
  background: #eceff7;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #9aa6c2;
  font-size: 23rpx;
}

.checkin-award-dot-done {
  background: #ddb953;
  color: #ffffff;
}

.checkin-award-label {
  font-size: 22rpx;
  color: #4f5c7a;
}

.checkin-award-btn {
  width: calc(100% - 30rpx);
  margin: 0 15rpx 16rpx;
}
