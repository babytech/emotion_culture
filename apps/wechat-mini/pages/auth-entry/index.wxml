<view class="auth-entry-page">
  <view class="container auth-background">
    <view class="auth-profile-head">
      <view class="auth-profile-avatar">情</view>
      <view class="auth-profile-copy">
        <view class="auth-profile-title">{{statusTitle}}</view>
        <view class="auth-profile-subtitle">{{statusSubtitle}}</view>
      </view>
      <view class="auth-profile-chip">{{statusChip}}</view>
    </view>

    <view class="card auth-benefit-card">
      <view class="auth-benefit-item">
        <view class="auth-benefit-icon auth-benefit-icon-vip">会</view>
        <view class="auth-benefit-label">会员</view>
      </view>
      <view class="auth-benefit-item">
        <view class="auth-benefit-icon auth-benefit-icon-points">积</view>
        <view class="auth-benefit-label">积分</view>
      </view>
      <view class="auth-benefit-item">
        <view class="auth-benefit-icon auth-benefit-icon-history">史</view>
        <view class="auth-benefit-label">历史</view>
      </view>
    </view>

    <view class="card auth-menu-card">
      <view wx:for="{{profileRows}}" wx:key="key" class="auth-menu-row">
        <view class="auth-menu-icon">{{item.icon}}</view>
        <view class="auth-menu-title">{{item.title}}</view>
        <view class="auth-menu-hint">{{item.hint}}</view>
        <view class="auth-menu-arrow">›</view>
      </view>
    </view>
  </view>

  <view class="auth-dim-mask"></view>

  <view class="auth-sheet">
    <view class="auth-sheet-handle"></view>
    <view class="auth-sheet-brand">情绪文化</view>
    <view class="auth-sheet-title">使用当前微信身份进入</view>
    <view class="auth-sheet-subtitle">完成后将以当前微信身份进入首页。</view>

    <view class="auth-step-card">
      <view class="auth-step-row">
        <view class="auth-step-badge {{agreed ? 'auth-step-badge-done' : ''}}">1</view>
        <view class="auth-step-copy">
          <view class="auth-step-title">同意</view>
          <view class="auth-step-desc">
            点击同意隐私授权后，才可继续进入首页。
          </view>
        </view>
        <button
          class="auth-inline-btn {{agreed ? 'auth-inline-btn-done' : ''}}"
          bindtap="handleAgreeTap"
          loading="{{isAuthorizingPrivacy}}"
          disabled="{{agreed || isAuthorizingPrivacy}}"
        >
          {{agreed ? '已完成' : '同意'}}
        </button>
      </view>

      <view class="auth-step-links">
        <text class="auth-link" bindtap="openPrivacyContract">
          {{privacyContractName ? privacyContractName : '《小程序用户隐私保护指引》'}}
        </text>
      </view>
    </view>

    <button
      class="btn btn-primary auth-enter-btn"
      bindtap="handleEnterWithWechat"
      loading="{{isEnteringWechat}}"
      disabled="{{isEnteringWechat || !agreed}}"
    >
      使用当前微信身份进入
    </button>

    <view class="auth-enter-hint">{{agreed ? enterHint : '请先点击同意，再进入首页'}}</view>
  </view>
</view>
