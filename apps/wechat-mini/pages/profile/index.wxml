<view class="container profile-page">
  <view class="profile-head-title">会员中心</view>

  <view class="card profile-member-card">
    <view class="profile-member-main">
      <view class="profile-avatar">微</view>
      <view class="profile-member-info">
        <view class="profile-member-name">{{memberName}}</view>
        <view class="profile-member-level">{{memberLevel}}</view>
      </view>
      <button class="btn btn-primary profile-sign-btn" bindtap="openCheckinPage">
        {{checkin.signedToday ? "已签到" : "签到"}}
      </button>
    </view>

    <view class="profile-stats">
      <view class="profile-stat-item">
        <view class="profile-stat-value">{{checkin.pointsBalance}}</view>
        <view class="profile-stat-label">我的积分</view>
      </view>
      <view class="profile-stat-item">
        <view class="profile-stat-value">{{checkin.currentStreak}}</view>
        <view class="profile-stat-label">连续签到</view>
      </view>
      <view class="profile-stat-item">
        <view class="profile-stat-value">{{retentionDays}}</view>
        <view class="profile-stat-label">保留天数</view>
      </view>
    </view>
  </view>

  <view class="card profile-benefit-card">
    <view class="profile-benefit-title">我的权益</view>
    <view class="profile-benefit-banner">SUNTEC Emotion Club</view>
    <view class="profile-benefit-sub">{{checkin.message}}</view>
  </view>

  <view class="card profile-quick-card">
    <view class="profile-section-title">常用服务</view>
    <view class="profile-quick-grid">
      <view
        wx:for="{{quickActions}}"
        wx:key="key"
        class="profile-quick-item"
        data-key="{{item.key}}"
        bindtap="handleQuickAction"
      >
        <view class="profile-quick-icon">{{item.icon}}</view>
        <view class="profile-quick-text">{{item.title}}</view>
      </view>
    </view>
  </view>

  <view class="card profile-setting-card">
    <view class="profile-section-title">隐私与数据</view>
    <view class="profile-switch-row">
      <view class="profile-switch-copy">
        <view class="profile-switch-title">保存我的历史记录</view>
        <view class="profile-switch-sub">{{updatedAtText}}</view>
      </view>
      <switch
        checked="{{saveHistory}}"
        disabled="{{isLoading || isSaving}}"
        bindchange="handleSaveHistoryChange"
        color="#2f6fff"
      />
    </view>
    <view wx:if="{{errorMsg}}" class="profile-error">{{errorMsg}}</view>
    <view class="profile-setting-actions">
      <button class="btn btn-secondary profile-setting-btn" bindtap="handleClearHistory">清空历史</button>
      <button class="btn btn-secondary profile-setting-btn" bindtap="goSettingsDetail">更多设置</button>
    </view>
  </view>

  <view class="card profile-support-card">
    <view class="profile-section-title">反馈与支持</view>
    <view class="profile-support-email">{{feedbackEmail}}</view>
    <view class="profile-support-tip">建议附上页面路径与操作步骤，方便快速定位。</view>
    <button class="btn btn-secondary profile-support-btn" bindtap="copyFeedbackEmail">复制反馈邮箱</button>
  </view>
</view>
