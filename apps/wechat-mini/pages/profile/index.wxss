.profile-page {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding-bottom: 148rpx;
}

.profile-head-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1f2d49;
  margin-bottom: 2rpx;
}

.profile-member-card {
  padding: 22rpx 20rpx;
  border: none;
}

.profile-member-main {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.profile-avatar {
  width: 84rpx;
  height: 84rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #5d89ff, #85adff);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 700;
}

.profile-member-info {
  flex: 1;
  min-width: 0;
}

.profile-member-name {
  font-size: 34rpx;
  font-weight: 700;
  color: #24324e;
}

.profile-member-level {
  margin-top: 6rpx;
  display: inline-flex;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(238, 203, 107, 0.2);
  color: #b58b1f;
  font-size: 21rpx;
}

.profile-sign-btn {
  min-height: 64rpx;
  line-height: 64rpx;
  font-size: 24rpx !important;
  padding: 0 20rpx !important;
}

.profile-stats {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 8rpx;
}

.profile-stat-item {
  text-align: center;
}

.profile-stat-value {
  font-size: 38rpx;
  font-weight: 700;
  color: #253552;
}

.profile-stat-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #617399;
}

.profile-benefit-card {
  padding: 20rpx;
  border: none;
}

.profile-benefit-title {
  font-size: 31rpx;
  font-weight: 700;
  color: #25334f;
}

.profile-benefit-banner {
  margin-top: 14rpx;
  border-radius: 18rpx;
  padding: 26rpx 18rpx;
  background:
    radial-gradient(circle at 100% 0%, rgba(255, 224, 145, 0.26), transparent 36%),
    linear-gradient(135deg, #edf4ff, #e8f8ff);
  color: #4e6fb0;
  font-size: 44rpx;
  line-height: 1.1;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.profile-benefit-sub {
  margin-top: 12rpx;
  font-size: 23rpx;
  color: #66789e;
}

.profile-quick-card,
.profile-setting-card,
.profile-support-card {
  padding: 20rpx;
  border: none;
}

.profile-section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #25334f;
}

.profile-quick-grid {
  margin-top: 14rpx;
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 8rpx;
}

.profile-quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.profile-quick-icon {
  width: 70rpx;
  height: 70rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #edf3ff, #dde9ff);
  color: #3562bf;
  font-size: 29rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.profile-quick-text {
  font-size: 21rpx;
  text-align: center;
  color: #5b6d93;
}

.profile-switch-row {
  margin-top: 14rpx;
  padding: 18rpx 16rpx;
  border-radius: 18rpx;
  background: #f5f8ff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.profile-switch-copy {
  flex: 1;
  min-width: 0;
}

.profile-switch-title {
  font-size: 27rpx;
  font-weight: 700;
  color: #25334f;
}

.profile-switch-sub {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #6c7fa4;
}

.profile-error {
  margin-top: 12rpx;
  padding: 14rpx 12rpx;
  border-radius: 14rpx;
  background: #fff3f5;
  color: #b03a52;
  font-size: 22rpx;
}

.profile-setting-actions {
  margin-top: 14rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 10rpx;
}

.profile-setting-btn,
.profile-support-btn {
  width: 100%;
}

.profile-support-email {
  margin-top: 14rpx;
  font-size: 30rpx;
  line-height: 1.35;
  color: #29406a;
  font-weight: 700;
  word-break: break-all;
}

.profile-support-tip {
  margin-top: 10rpx;
  font-size: 23rpx;
  line-height: 1.6;
  color: #6d7ea1;
}

.profile-support-btn {
  margin-top: 14rpx;
}
