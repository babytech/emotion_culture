.profile-hero-badge {
  position: relative;
  z-index: 1;
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
  padding: 12rpx 18rpx 12rpx 16rpx;
  background:
    linear-gradient(135deg, rgba(255, 252, 247, 0.94), rgba(250, 237, 216, 0.88));
  border: 2rpx solid rgba(147, 37, 29, 0.08);
  box-shadow: 0 10rpx 20rpx rgba(124, 76, 40, 0.08);
  color: #7d5640;
}

.profile-hero-badge-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, rgba(211, 160, 91, 0.98), rgba(199, 128, 53, 0.92));
  box-shadow: 0 0 0 6rpx rgba(211, 160, 91, 0.12);
}

.profile-hero-badge-text {
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.profile-chip-row {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.profile-chip {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 251, 243, 0.82);
  border: 2rpx solid rgba(147, 37, 29, 0.08);
  font-size: 23rpx;
  color: #6b4f3b;
}

.profile-hero-stage {
  margin-top: 22rpx;
  display: grid;
  grid-template-columns: 1.18fr 0.92fr;
  gap: 14rpx;
}

.profile-hero-main-card {
  position: relative;
  overflow: hidden;
  padding: 24rpx 22rpx;
  border-radius: 28rpx;
  background:
    radial-gradient(circle at 100% 0%, rgba(255, 255, 255, 0.24), transparent 36%),
    linear-gradient(180deg, rgba(167, 39, 30, 0.96), rgba(128, 32, 25, 0.95));
  color: #fff7f0;
  box-shadow: 0 18rpx 42rpx rgba(120, 31, 24, 0.22);
}

.profile-hero-main-card-on {
  background:
    radial-gradient(circle at 100% 0%, rgba(255, 255, 255, 0.24), transparent 36%),
    linear-gradient(180deg, rgba(167, 39, 30, 0.96), rgba(128, 32, 25, 0.95));
  color: #fff7f0;
  box-shadow: 0 18rpx 42rpx rgba(120, 31, 24, 0.22);
}

.profile-hero-main-card-off {
  background:
    radial-gradient(circle at 100% 0%, rgba(255, 255, 255, 0.14), transparent 36%),
    linear-gradient(180deg, rgba(95, 100, 110, 0.96), rgba(61, 66, 75, 0.96));
  color: #f4f5f8;
  box-shadow: 0 18rpx 42rpx rgba(57, 62, 71, 0.22);
}

.profile-hero-main-card::after {
  content: "";
  position: absolute;
  right: -30rpx;
  bottom: -36rpx;
  width: 140rpx;
  height: 140rpx;
  border-radius: 999rpx;
  background: radial-gradient(circle, rgba(255, 230, 197, 0.2), transparent 72%);
}

.profile-hero-main-label {
  position: relative;
  z-index: 1;
  font-size: 22rpx;
  color: rgba(255, 243, 232, 0.82);
}

.profile-hero-main-value {
  position: relative;
  z-index: 1;
  margin-top: 16rpx;
  font-size: 42rpx;
  line-height: 1.12;
  font-weight: 700;
}

.profile-hero-main-meta {
  position: relative;
  z-index: 1;
  margin-top: 18rpx;
  font-size: 23rpx;
  line-height: 1.68;
  color: rgba(255, 241, 229, 0.84);
}

.profile-hero-main-card-off .profile-hero-main-label {
  color: rgba(245, 245, 248, 0.76);
}

.profile-hero-main-card-off .profile-hero-main-meta {
  color: rgba(245, 245, 248, 0.8);
}

.profile-hero-side {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.profile-hero-mini-card {
  flex: 1;
  padding: 20rpx 18rpx;
  border-radius: 24rpx;
  background: rgba(255, 251, 245, 0.86);
  border: 2rpx solid rgba(147, 37, 29, 0.08);
  box-shadow: 0 10rpx 22rpx rgba(124, 76, 40, 0.06);
}

.profile-hero-mini-card-accent {
  background:
    radial-gradient(circle at 100% 0%, rgba(211, 160, 91, 0.16), transparent 34%),
    rgba(255, 248, 239, 0.9);
}

.profile-hero-mini-label {
  font-size: 22rpx;
  color: #8a715d;
}

.profile-hero-mini-value {
  margin-top: 12rpx;
  font-size: 34rpx;
  line-height: 1.16;
  font-weight: 700;
  color: #6d3d22;
}

.profile-hero-mini-value-small {
  font-size: 24rpx;
  line-height: 1.42;
}

.profile-quick-grid {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.profile-quick-card {
  padding: 22rpx 20rpx 20rpx;
  border-radius: 26rpx;
  background: rgba(255, 248, 239, 0.84);
  border: 2rpx solid rgba(147, 37, 29, 0.08);
  box-shadow: 0 10rpx 22rpx rgba(124, 76, 40, 0.08);
}

.profile-quick-card-history {
  background:
    radial-gradient(circle at 100% 0%, rgba(211, 160, 91, 0.18), transparent 34%),
    linear-gradient(135deg, rgba(255, 251, 245, 0.98), rgba(247, 236, 217, 0.94));
}

.profile-quick-card-favorites {
  background:
    radial-gradient(circle at 100% 0%, rgba(167, 120, 65, 0.12), transparent 32%),
    rgba(251, 244, 233, 0.92);
}

.profile-quick-card-analyze {
  background:
    radial-gradient(circle at 100% 0%, rgba(147, 37, 29, 0.08), transparent 30%),
    rgba(255, 248, 239, 0.9);
}

.profile-quick-card-settings {
  background:
    radial-gradient(circle at 100% 0%, rgba(211, 160, 91, 0.12), transparent 32%),
    rgba(255, 250, 243, 0.92);
}

.profile-quick-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.profile-quick-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(247, 230, 199, 0.84);
  color: #84592f;
  font-size: 21rpx;
}

.profile-quick-link {
  flex-shrink: 0;
  font-size: 22rpx;
  font-weight: 700;
  color: #a1261b;
}

.profile-quick-title {
  margin-top: 12rpx;
  font-size: 29rpx;
  font-weight: 700;
  color: #5c3520;
}

.profile-quick-sub {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.62;
  color: #7d6959;
}

.profile-switch-row {
  margin-top: 18rpx;
  padding: 22rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 248, 239, 0.84);
  border: 2rpx solid rgba(147, 37, 29, 0.08);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.profile-switch-copy {
  flex: 1;
  min-width: 0;
}

.profile-switch-title {
  font-size: 29rpx;
  font-weight: 700;
  color: #5c3520;
}

.profile-switch-sub {
  margin-top: 8rpx;
  font-size: 23rpx;
  line-height: 1.6;
  color: #7d6959;
}

.profile-clear-btn,
.profile-feedback-btn {
  width: 100%;
  margin-top: 18rpx;
}

.profile-privacy-grid {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.profile-privacy-card {
  padding: 22rpx 20rpx;
  border-radius: 24rpx;
  background:
    linear-gradient(135deg, rgba(255, 251, 245, 0.98), rgba(250, 240, 226, 0.92));
  border: 2rpx solid rgba(147, 37, 29, 0.07);
  box-shadow: 0 8rpx 20rpx rgba(124, 76, 40, 0.06);
}

.profile-privacy-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(247, 230, 199, 0.84);
  color: #84592f;
  font-size: 21rpx;
}

.profile-privacy-title {
  margin-top: 12rpx;
  font-size: 28rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #5b3621;
}

.profile-privacy-body {
  margin-top: 10rpx;
  font-size: 23rpx;
  line-height: 1.68;
  color: #756252;
}

.profile-support-card {
  margin-top: 18rpx;
  padding: 24rpx 22rpx;
  border-radius: 26rpx;
  background:
    radial-gradient(circle at 100% 0%, rgba(211, 160, 91, 0.18), transparent 30%),
    linear-gradient(135deg, rgba(255, 251, 245, 0.98), rgba(247, 236, 217, 0.94));
  border: 2rpx solid rgba(147, 37, 29, 0.08);
  box-shadow: 0 12rpx 24rpx rgba(124, 76, 40, 0.08);
}

.profile-support-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.profile-support-copy {
  min-width: 0;
  flex: 1;
}

.profile-support-label {
  font-size: 22rpx;
  color: #8a715d;
}

.profile-support-email {
  margin-top: 12rpx;
  font-size: 31rpx;
  line-height: 1.34;
  font-weight: 700;
  color: #5b3520;
  word-break: break-all;
}

.profile-support-chip {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(247, 230, 199, 0.9);
  color: #835628;
  font-size: 21rpx;
}

.profile-support-meta-row {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.profile-support-meta {
  font-size: 22rpx;
  line-height: 1.56;
  color: #8e7867;
}
