.camera-page {
  min-height: 100vh;
  padding: 28rpx 24rpx calc(36rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.camera-topbar {
  padding: 16rpx 8rpx 0;
}

.camera-title {
  font-size: 42rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #2d2018;
}

.camera-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #7a6a5e;
}

.camera-stage {
  overflow: hidden;
  border-radius: 36rpx;
  border: 2rpx solid rgba(146, 51, 36, 0.14);
  background:
    radial-gradient(circle at 50% 10%, rgba(255, 255, 255, 0.16), transparent 28%),
    linear-gradient(180deg, rgba(31, 24, 20, 0.96), rgba(24, 19, 15, 0.98));
  box-shadow: 0 18rpx 46rpx rgba(62, 36, 23, 0.18);
}

.camera-view,
.camera-preview {
  width: 100%;
  display: block;
  background: #1f1814;
}

.camera-placeholder {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255, 255, 255, 0.82);
  font-size: 28rpx;
  line-height: 1.6;
}

.camera-error {
  padding: 20rpx 22rpx;
  border-radius: 24rpx;
  background: rgba(255, 241, 241, 0.98);
  border: 2rpx solid rgba(159, 53, 53, 0.12);
  color: #8f3535;
  font-size: 24rpx;
  line-height: 1.6;
}

.camera-warn {
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: rgba(255, 245, 228, 0.98);
  border: 2rpx solid rgba(153, 98, 31, 0.12);
  color: #99621f;
  font-size: 24rpx;
  line-height: 1.6;
}

.camera-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding-top: 4rpx;
}

.camera-side-btn {
  flex: 1;
}

.camera-shot-btn {
  flex: 1.35;
}
