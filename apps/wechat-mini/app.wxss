:root {
  --paper: #f6efe5;
  --paper-deep: #efe2cf;
  --paper-glow: #fffaf3;
  --ink: #241912;
  --ink-soft: #5f4c3f;
  --accent: #93251d;
  --accent-strong: #c84434;
  --accent-2: #d3a05b;
  --accent-2-soft: #f7e6c8;
  --muted: #867569;
  --line: rgba(146, 51, 36, 0.14);
  --card: rgba(255, 250, 242, 0.96);
  --shadow-lg: 0 18rpx 46rpx rgba(62, 36, 23, 0.12);
  --shadow-sm: 0 8rpx 20rpx rgba(62, 36, 23, 0.08);
  --success-bg: #e8f7ee;
  --success-ink: #0f6c4d;
  --warn-bg: #fff5e4;
  --warn-ink: #99621f;
  --danger-bg: #fff1f1;
  --danger-ink: #9f3535;
}

page {
  min-height: 100%;
  background:
    radial-gradient(circle at 8% 16%, rgba(211, 160, 91, 0.24), transparent 34%),
    radial-gradient(circle at 100% 2%, rgba(147, 37, 29, 0.18), transparent 32%),
    linear-gradient(180deg, rgba(255, 248, 238, 0.9), rgba(246, 239, 229, 0.98)),
    var(--paper);
  color: var(--ink);
  font-family: "STSong", "Songti SC", serif;
}

.container {
  padding: 26rpx;
  padding-bottom: calc(26rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(26rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.card {
  background: var(--card);
  border-radius: 28rpx;
  border: 2rpx solid var(--line);
  box-shadow: var(--shadow-lg);
  backdrop-filter: blur(10rpx);
}

.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  border-radius: 999rpx !important;
  padding: 0 30rpx !important;
  min-height: 88rpx;
  line-height: 88rpx;
  font-size: 29rpx !important;
  font-weight: 700;
  letter-spacing: 1rpx;
  color: #3a2a1e;
  background-color: #fff8ee !important;
  border: 2rpx solid rgba(146, 51, 36, 0.14) !important;
  box-shadow: var(--shadow-sm);
}

.btn::after {
  border: none !important;
}

.btn-primary {
  color: #fff !important;
  background-color: #a1261b !important;
  background-image: linear-gradient(135deg, #9f2a1f 0%, #c84434 100%) !important;
  border-color: rgba(125, 28, 21, 0.2) !important;
  text-shadow: 0 1rpx 0 rgba(0, 0, 0, 0.12);
}

.btn-secondary {
  color: #5f4328 !important;
  background-color: #fff6e8 !important;
  background-image: linear-gradient(135deg, #fff8ec 0%, #f4ddb2 100%) !important;
  border-color: rgba(146, 51, 36, 0.12) !important;
}

.btn[disabled] {
  opacity: 0.72;
  box-shadow: none;
}

.btn-primary[disabled] {
  color: rgba(255, 255, 255, 0.92) !important;
  background-color: #b85d53 !important;
  background-image: linear-gradient(135deg, #b85d53 0%, #d1877f 100%) !important;
}

.btn-secondary[disabled] {
  color: rgba(95, 67, 40, 0.82) !important;
  background-color: #f5ead8 !important;
  background-image: linear-gradient(135deg, #faf3e7 0%, #efddbf 100%) !important;
}

.text-muted {
  color: var(--muted);
}

.shell-page {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  padding-bottom: 250rpx;
}

.shell-hero {
  padding: 34rpx 30rpx;
  background:
    radial-gradient(circle at 88% 8%, rgba(255, 255, 255, 0.42), transparent 26%),
    linear-gradient(135deg, rgba(147, 37, 29, 0.18), rgba(211, 160, 91, 0.22)),
    var(--card);
}

.shell-kicker {
  font-size: 21rpx;
  letter-spacing: 3rpx;
  text-transform: uppercase;
  color: #92644a;
}

.shell-title {
  margin-top: 10rpx;
  font-size: 46rpx;
  line-height: 1.18;
  font-weight: 700;
}

.shell-subtitle {
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #6d5b4c;
}

.shell-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 251, 243, 0.84);
  border: 2rpx solid rgba(147, 37, 29, 0.1);
  color: #7d5640;
  font-size: 22rpx;
  white-space: nowrap;
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.metric-card {
  padding: 22rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 251, 245, 0.78);
  border: 2rpx solid rgba(147, 37, 29, 0.08);
}

.metric-label {
  font-size: 22rpx;
  color: #8a715d;
}

.metric-value {
  margin-top: 8rpx;
  font-size: 30rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #7e4d2d;
}

.section-card {
  padding: 28rpx 24rpx;
}

.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.section-head-copy {
  flex: 1;
  min-width: 0;
}

.section-kicker {
  font-size: 21rpx;
  letter-spacing: 3rpx;
  text-transform: uppercase;
  color: #95674b;
}

.section-title {
  margin-top: 10rpx;
  font-size: 34rpx;
  line-height: 1.2;
  font-weight: 700;
}

.section-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.66;
  color: #7b695c;
}

.status-chip {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(247, 230, 199, 0.82);
  color: #835628;
  font-size: 22rpx;
  white-space: nowrap;
}

.state-panel {
  margin-top: 18rpx;
  padding: 20rpx 18rpx;
  border-radius: 22rpx;
  background: rgba(255, 248, 238, 0.82);
  border: 2rpx solid rgba(147, 37, 29, 0.08);
}

.state-panel-muted {
  color: #7e7365;
}

.mini-tag-row {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.mini-tag {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 251, 243, 0.82);
  border: 2rpx solid rgba(147, 37, 29, 0.08);
  font-size: 23rpx;
  color: #6b4f3b;
}

.empty-copy {
  padding: 22rpx 20rpx;
  border-radius: 22rpx;
  background: rgba(246, 240, 231, 0.76);
  color: #7b6d5f;
  font-size: 25rpx;
  line-height: 1.7;
}

.action-grid-2 {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.action-btn-light {
  width: 100%;
  min-height: 82rpx;
  line-height: 82rpx;
  padding: 0 !important;
  font-size: 27rpx !important;
}

.section-note {
  margin-top: 12rpx;
  font-size: 23rpx;
  line-height: 1.68;
  color: #8a7a6c;
}
