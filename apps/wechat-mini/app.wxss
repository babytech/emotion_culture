:root {
  --paper: #eef3ff;
  --paper-deep: #e6edff;
  --paper-glow: #f9fbff;
  --ink: #1f2d49;
  --ink-soft: #47587c;
  --accent: #2f6fff;
  --accent-strong: #4a8dff;
  --accent-2: #e1b84f;
  --accent-2-soft: #f8edc7;
  --muted: #7184a8;
  --line: rgba(95, 118, 162, 0.16);
  --card: rgba(255, 255, 255, 0.95);
  --shadow-lg: 0 16rpx 40rpx rgba(62, 88, 138, 0.14);
  --shadow-sm: 0 8rpx 20rpx rgba(62, 88, 138, 0.08);
  --success-bg: #e8f7ee;
  --success-ink: #0f6c4d;
  --warn-bg: #fff5e4;
  --warn-ink: #99621f;
  --danger-bg: #fff1f1;
  --danger-ink: #9f3535;
}

page {
  min-height: 100%;
  background:
    radial-gradient(circle at 8% 12%, rgba(136, 178, 255, 0.26), transparent 34%),
    radial-gradient(circle at 100% 2%, rgba(228, 203, 136, 0.16), transparent 34%),
    linear-gradient(180deg, rgba(250, 252, 255, 0.95), rgba(238, 244, 255, 0.98)),
    var(--paper);
  color: var(--ink);
  font-family: "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
}

.container {
  padding: 26rpx;
  padding-bottom: calc(26rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.card {
  background: var(--card);
  border-radius: 24rpx;
  border: 2rpx solid rgba(102, 124, 170, 0.08);
  box-shadow: var(--shadow-lg);
  backdrop-filter: blur(10rpx);
}

.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  border-radius: 999rpx !important;
  padding: 0 30rpx !important;
  min-height: 88rpx;
  line-height: 88rpx;
  font-size: 29rpx !important;
  font-weight: 700;
  letter-spacing: 1rpx;
  color: #2a3a58;
  background-color: #f6f9ff !important;
  border: 2rpx solid rgba(84, 111, 164, 0.14) !important;
  box-shadow: var(--shadow-sm);
}

.btn::after {
  border: none !important;
}

.btn-primary {
  color: #fff !important;
  background-color: #2f6fff !important;
  background-image: linear-gradient(135deg, #2f6fff 0%, #5a93ff 100%) !important;
  border-color: rgba(44, 95, 188, 0.2) !important;
  text-shadow: 0 1rpx 0 rgba(0, 0, 0, 0.12);
}

.btn-secondary {
  color: #36588e !important;
  background-color: #f4f8ff !important;
  background-image: linear-gradient(135deg, #f8fbff 0%, #e6efff 100%) !important;
  border-color: rgba(84, 111, 164, 0.12) !important;
}

.btn[disabled] {
  opacity: 0.72;
  box-shadow: none;
}

.btn-primary[disabled] {
  color: rgba(255, 255, 255, 0.92) !important;
  background-color: #89aef3 !important;
  background-image: linear-gradient(135deg, #89aef3 0%, #a9c5f7 100%) !important;
}

.btn-secondary[disabled] {
  color: rgba(83, 106, 151, 0.82) !important;
  background-color: #edf2fb !important;
  background-image: linear-gradient(135deg, #f8faff 0%, #e9f0fc 100%) !important;
}

.text-muted {
  color: var(--muted);
}

.shell-page {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  padding-bottom: 188rpx;
}

.shell-hero {
  padding: 34rpx 30rpx;
  background:
    radial-gradient(circle at 88% 8%, rgba(255, 255, 255, 0.42), transparent 26%),
    linear-gradient(135deg, rgba(147, 37, 29, 0.18), rgba(211, 160, 91, 0.22)),
    var(--card);
}

.shell-kicker {
  font-size: 21rpx;
  letter-spacing: 3rpx;
  text-transform: uppercase;
  color: #92644a;
}

.shell-title {
  margin-top: 10rpx;
  font-size: 46rpx;
  line-height: 1.18;
  font-weight: 700;
}

.shell-subtitle {
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #6d5b4c;
}

.shell-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 251, 243, 0.84);
  border: 2rpx solid rgba(147, 37, 29, 0.1);
  color: #7d5640;
  font-size: 22rpx;
  white-space: nowrap;
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.metric-card {
  padding: 22rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(255, 251, 245, 0.78);
  border: 2rpx solid rgba(147, 37, 29, 0.08);
}

.metric-label {
  font-size: 22rpx;
  color: #8a715d;
}

.metric-value {
  margin-top: 8rpx;
  font-size: 30rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #7e4d2d;
}

.section-card {
  padding: 28rpx 24rpx;
}

.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.section-head-copy {
  flex: 1;
  min-width: 0;
}

.section-kicker {
  font-size: 21rpx;
  letter-spacing: 3rpx;
  text-transform: uppercase;
  color: #95674b;
}

.section-title {
  margin-top: 10rpx;
  font-size: 34rpx;
  line-height: 1.2;
  font-weight: 700;
}

.section-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.66;
  color: #7b695c;
}

.status-chip {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(247, 230, 199, 0.82);
  color: #835628;
  font-size: 22rpx;
  white-space: nowrap;
}

.state-panel {
  margin-top: 18rpx;
  padding: 20rpx 18rpx;
  border-radius: 22rpx;
  background: rgba(255, 248, 238, 0.82);
  border: 2rpx solid rgba(147, 37, 29, 0.08);
}

.state-panel-muted {
  color: #7e7365;
}

.mini-tag-row {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.mini-tag {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 251, 243, 0.82);
  border: 2rpx solid rgba(147, 37, 29, 0.08);
  font-size: 23rpx;
  color: #6b4f3b;
}

.empty-copy {
  padding: 22rpx 20rpx;
  border-radius: 22rpx;
  background: rgba(246, 240, 231, 0.76);
  color: #7b6d5f;
  font-size: 25rpx;
  line-height: 1.7;
}

.action-grid-2 {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.action-btn-light {
  width: 100%;
  min-height: 82rpx;
  line-height: 82rpx;
  padding: 0 !important;
  font-size: 27rpx !important;
}

.section-note {
  margin-top: 12rpx;
  font-size: 23rpx;
  line-height: 1.68;
  color: #8a7a6c;
}
