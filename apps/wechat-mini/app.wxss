:root {
  --paper: #edf4ff;
  --paper-deep: #e6efff;
  --paper-glow: #fbfdff;
  --ink: #1d2b47;
  --ink-soft: #46597f;
  --accent: #316fff;
  --accent-strong: #38c6d5;
  --accent-2: #ff9f72;
  --accent-2-soft: #ffe6d8;
  --muted: #6f83a8;
  --line: rgba(90, 117, 168, 0.14);
  --card: rgba(255, 255, 255, 0.9);
  --shadow-lg: 0 18rpx 44rpx rgba(54, 85, 139, 0.13);
  --shadow-sm: 0 10rpx 24rpx rgba(54, 85, 139, 0.08);
  --success-bg: #e8f7ee;
  --success-ink: #0f6c4d;
  --warn-bg: #fff5e4;
  --warn-ink: #99621f;
  --danger-bg: #fff1f1;
  --danger-ink: #9f3535;
}

page {
  min-height: 100%;
  background:
    radial-gradient(circle at 8% 12%, rgba(109, 166, 255, 0.25), transparent 34%),
    radial-gradient(circle at 95% 6%, rgba(91, 219, 235, 0.2), transparent 34%),
    radial-gradient(circle at 88% 96%, rgba(255, 172, 122, 0.16), transparent 30%),
    linear-gradient(180deg, rgba(251, 253, 255, 0.96), rgba(236, 244, 255, 0.98)),
    var(--paper);
  color: var(--ink);
  font-family: "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif;
}

.container {
  padding: 26rpx;
  padding-bottom: calc(26rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.card {
  background: var(--card);
  border-radius: 24rpx;
  border: 2rpx solid rgba(106, 133, 182, 0.08);
  box-shadow: var(--shadow-lg);
  backdrop-filter: blur(12rpx);
}

.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  border-radius: 999rpx !important;
  padding: 0 30rpx !important;
  min-height: 88rpx;
  line-height: 88rpx;
  font-size: 29rpx !important;
  font-weight: 700;
  letter-spacing: 1rpx;
  color: #2a3a58;
  background-color: #f6f9ff !important;
  border: 2rpx solid rgba(84, 111, 164, 0.14) !important;
  box-shadow: var(--shadow-sm);
}

.btn::after {
  border: none !important;
}

.btn-primary {
  color: #fff !important;
  background-color: #316fff !important;
  background-image: linear-gradient(135deg, #316fff 0%, #40a4ff 52%, #38c6d5 100%) !important;
  border-color: rgba(45, 98, 190, 0.2) !important;
  text-shadow: 0 1rpx 0 rgba(0, 0, 0, 0.12);
}

.btn-secondary {
  color: #35578f !important;
  background-color: #f4f8ff !important;
  background-image: linear-gradient(135deg, #fcfdff 0%, #e8f4ff 54%, #ffece2 100%) !important;
  border-color: rgba(84, 111, 164, 0.12) !important;
}

.btn[disabled] {
  opacity: 0.72;
  box-shadow: none;
}

.btn-primary[disabled] {
  color: rgba(255, 255, 255, 0.92) !important;
  background-color: #89aef3 !important;
  background-image: linear-gradient(135deg, #89aef3 0%, #a9c5f7 100%) !important;
}

.btn-secondary[disabled] {
  color: rgba(83, 106, 151, 0.82) !important;
  background-color: #edf2fb !important;
  background-image: linear-gradient(135deg, #f8faff 0%, #e9f0fc 100%) !important;
}

.text-muted {
  color: var(--muted);
}

.shell-page {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  padding-bottom: 188rpx;
}

.shell-hero {
  padding: 34rpx 30rpx;
  background:
    radial-gradient(circle at 88% 8%, rgba(255, 255, 255, 0.42), transparent 26%),
    radial-gradient(circle at 12% 90%, rgba(255, 155, 109, 0.16), transparent 34%),
    linear-gradient(135deg, rgba(73, 116, 221, 0.2), rgba(56, 184, 210, 0.18)),
    var(--card);
}

.shell-kicker {
  font-size: 21rpx;
  letter-spacing: 3rpx;
  text-transform: uppercase;
  color: #5079b8;
}

.shell-title {
  margin-top: 10rpx;
  font-size: 46rpx;
  line-height: 1.18;
  font-weight: 700;
}

.shell-subtitle {
  margin-top: 16rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #58709d;
}

.shell-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(241, 248, 255, 0.88);
  border: 2rpx solid rgba(60, 123, 210, 0.14);
  color: #3f65a5;
  font-size: 22rpx;
  white-space: nowrap;
}

.metric-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.metric-card {
  padding: 22rpx 20rpx;
  border-radius: 24rpx;
  background: rgba(244, 250, 255, 0.8);
  border: 2rpx solid rgba(61, 127, 209, 0.08);
}

.metric-label {
  font-size: 22rpx;
  color: #6078a3;
}

.metric-value {
  margin-top: 8rpx;
  font-size: 30rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #2f5ea7;
}

.section-card {
  padding: 28rpx 24rpx;
}

.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.section-head-copy {
  flex: 1;
  min-width: 0;
}

.section-kicker {
  font-size: 21rpx;
  letter-spacing: 3rpx;
  text-transform: uppercase;
  color: #5579b6;
}

.section-title {
  margin-top: 10rpx;
  font-size: 34rpx;
  line-height: 1.2;
  font-weight: 700;
}

.section-sub {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.66;
  color: #61779f;
}

.status-chip {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(227, 243, 255, 0.84);
  color: #3f6aa8;
  font-size: 22rpx;
  white-space: nowrap;
}

.state-panel {
  margin-top: 18rpx;
  padding: 20rpx 18rpx;
  border-radius: 22rpx;
  background: rgba(244, 250, 255, 0.82);
  border: 2rpx solid rgba(71, 127, 199, 0.08);
}

.state-panel-muted {
  color: #7e7365;
}

.mini-tag-row {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.mini-tag {
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(243, 250, 255, 0.86);
  border: 2rpx solid rgba(64, 126, 200, 0.08);
  font-size: 23rpx;
  color: #3e649f;
}

.empty-copy {
  padding: 22rpx 20rpx;
  border-radius: 22rpx;
  background: rgba(243, 249, 255, 0.76);
  color: #657ca5;
  font-size: 25rpx;
  line-height: 1.7;
}

.action-grid-2 {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.action-btn-light {
  width: 100%;
  min-height: 82rpx;
  line-height: 82rpx;
  padding: 0 !important;
  font-size: 27rpx !important;
}

.section-note {
  margin-top: 12rpx;
  font-size: 23rpx;
  line-height: 1.68;
  color: #8a7a6c;
}
