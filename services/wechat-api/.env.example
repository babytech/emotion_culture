API_ENV=development
API_PORT=9000

# WeChat cloud file download (cloud://fileid -> temp URL)
WECHAT_APP_ID=wx_your_app_id
WECHAT_APP_SECRET=your_app_secret
WECHAT_CLOUDBASE_ENV=your-cloudbase-env-id

# SMTP settings (used by backend email module at runtime).
# For local backend debug, fill these values in services/wechat-api/.env.
EMAIL_SENDER_ADDRESS=your_sender@example.com
EMAIL_SENDER_PASSWORD=your_app_password
SMTP_SERVER_HOST=smtp.gmail.com
SMTP_SERVER_PORT=587

# Speech-to-text (BE-010) settings.
# provider: auto | http | mock
# ASR service switch: on | off
# on: attempt transcript with current provider/endpoint
# off: skip transcript request regardless of endpoint/provider
SPEECH_ASR_SERVICE=on
SPEECH_STT_PROVIDER=auto

# Used when provider=http, or provider=auto with endpoint configured.
# Example for Tencent gateway in this same service:
# SPEECH_STT_ENDPOINT=https://your-cloud-host-domain/api/stt/tencent
SPEECH_STT_ENDPOINT=
SPEECH_STT_TOKEN=
SPEECH_STT_AUTH_HEADER=Authorization
SPEECH_STT_AUTH_SCHEME=Bearer
SPEECH_STT_TIMEOUT_SEC=18
SPEECH_STT_HTTP_METHOD=POST
# multipart | raw | json_base64
SPEECH_STT_HTTP_MODE=multipart
SPEECH_STT_FILE_FIELD=audio
SPEECH_STT_FILE_MIME=
SPEECH_STT_RAW_CONTENT_TYPE=
SPEECH_STT_JSON_AUDIO_FIELD=audio_base64
SPEECH_STT_JSON_FILENAME_FIELD=filename
# JSON object strings (optional), e.g. {"model":"whisper-1"}.
SPEECH_STT_FORM_JSON=
SPEECH_STT_JSON_TEMPLATE=
SPEECH_STT_HEADERS_JSON=
SPEECH_STT_QUERY_JSON=
# Comma separated response paths, e.g. text,data.text,result.text
SPEECH_STT_RESPONSE_PATHS=

# Tencent ASR gateway config (used by /api/stt/tencent).
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_ASR_ENDPOINT=asr.tencentcloudapi.com
TENCENT_ASR_SERVICE=asr
TENCENT_ASR_ACTION=SentenceRecognition
TENCENT_ASR_VERSION=2019-06-14
TENCENT_ASR_REGION=ap-guangzhou
TENCENT_ASR_ENGINE_MODEL_TYPE=16k_zh
TENCENT_ASR_SUB_SERVICE_TYPE=2
TENCENT_ASR_PROJECT_ID=0
TENCENT_ASR_WORD_INFO=0
TENCENT_ASR_TIMEOUT_SEC=20
TENCENT_ASR_MAX_AUDIO_BYTES=3145728
# Optional shared secret for protecting /api/stt/tencent from public abuse.
TENCENT_STT_GATEWAY_TOKEN=

# Whether to hard-require transcript for voice quality gate.
# Note: this is transcript strictness, NOT ASR on/off switch.
# 0: allow voice emotion analysis even when transcript is empty (recommended)
# 1: reject empty transcript with VOICE_TRANSCRIPT_EMPTY
VOICE_REQUIRE_TRANSCRIPT=0

# Phase-2 retention switches.
# RETENTION_SERVICE_ENABLED controls retention feature family.
# RETENTION_WEEKLY_REPORT_ENABLED and RETENTION_FAVORITES_ENABLED are sub-switches.
# Note: these switches do not affect phase-1 /api/analyze or /api/history basics.
RETENTION_SERVICE_ENABLED=on
RETENTION_WEEKLY_REPORT_ENABLED=on
RETENTION_FAVORITES_ENABLED=on
FAVORITES_MAX_ITEMS=500
WEEKLY_REPORT_CACHE_MAX_ITEMS=32

# Used only when provider=mock (local validation).
SPEECH_STT_MOCK_TEXT=

# Phase-3 dynamic media generate provider switch.
# local_mock | http | liblib_signed
MEDIA_GEN_PROVIDER=local_mock

# Generic HTTP image provider (when MEDIA_GEN_PROVIDER=http).
MEDIA_GEN_HTTP_ENDPOINT=
MEDIA_GEN_HTTP_MODE=multipart
MEDIA_GEN_HTTP_STYLE_FIELD=style
MEDIA_GEN_HTTP_PROMPT_FIELD=prompt
MEDIA_GEN_HTTP_FILE_FIELD=image
MEDIA_GEN_HTTP_RESPONSE_PATH=result.url,data.url,url
MEDIA_GEN_HTTP_AUTH_HEADER=Authorization
MEDIA_GEN_HTTP_AUTH_TOKEN=
MEDIA_GEN_HTTP_TIMEOUT_SEC=25

# Liblib OpenAPI signed provider (when MEDIA_GEN_PROVIDER=liblib_signed).
# Important: keep AccessKey/SecretKey only in backend env, never in mini program.
MEDIA_GEN_LIBLIB_BASE_URL=https://openapi.liblibai.cloud
MEDIA_GEN_LIBLIB_CREATE_URI=/api/genImg
MEDIA_GEN_LIBLIB_CREATE_METHOD=POST
MEDIA_GEN_LIBLIB_ACCESS_KEY=
MEDIA_GEN_LIBLIB_SECRET_KEY=
MEDIA_GEN_LIBLIB_ACCESS_KEY_PARAM=AccessKey
MEDIA_GEN_LIBLIB_TIMESTAMP_PARAM=Timestamp
MEDIA_GEN_LIBLIB_NONCE_PARAM=SignatureNonce
MEDIA_GEN_LIBLIB_SIGNATURE_PARAM=Signature
MEDIA_GEN_LIBLIB_NONCE_WITH_DASH=0
MEDIA_GEN_LIBLIB_QUERY_JSON=
MEDIA_GEN_LIBLIB_HEADERS_JSON=
MEDIA_GEN_LIBLIB_CREATE_JSON_TEMPLATE=
# Field supports dotted path such as generateParams.prompt / generateParams.image_list.0.
# Leave STYLE/PROMPT field empty when your provider payload doesn't need them.
MEDIA_GEN_LIBLIB_STYLE_FIELD=style
MEDIA_GEN_LIBLIB_PROMPT_FIELD=prompt
MEDIA_GEN_LIBLIB_IMAGE_FIELD=image
# base64 | hex | url | none
MEDIA_GEN_LIBLIB_IMAGE_MODE=base64
MEDIA_GEN_LIBLIB_IMAGE_ENCODING_FIELD=image_encoding
MEDIA_GEN_LIBLIB_RESPONSE_PATH=data.images.0.imageUrl,data.image_url,data.imageUrl,data.url,result.url,url
# Optional async polling (when create response only returns task id)
MEDIA_GEN_LIBLIB_STATUS_URI=
MEDIA_GEN_LIBLIB_STATUS_METHOD=POST
MEDIA_GEN_LIBLIB_STATUS_JSON_TEMPLATE=
MEDIA_GEN_LIBLIB_STATUS_TASK_FIELD=generateUuid
MEDIA_GEN_LIBLIB_TASK_ID_PATH=data.generateUuid,generateUuid,data.task_id,task_id,data.id,id
MEDIA_GEN_LIBLIB_STATUS_STATE_PATH=data.generateStatus,generateStatus,data.status,status,data.state,state
MEDIA_GEN_LIBLIB_STATUS_DONE_VALUES=5,SUCCESS,SUCCEEDED,DONE,FINISHED,2,ok
MEDIA_GEN_LIBLIB_STATUS_FAILED_VALUES=6,7,FAILED,FAIL,ERROR,-1
MEDIA_GEN_LIBLIB_POLL_INTERVAL_MS=1500
MEDIA_GEN_LIBLIB_POLL_ATTEMPTS=25

# Face quality gate (BE-012).
FACE_MIN_CANDIDATE_AREA_RATIO=0.01
FACE_DEDUPE_IOU_THRESHOLD=0.3
FACE_MIN_PRESENCE_EYE_COUNT=1
FACE_HIGH_AREA_PRESENCE_RATIO=0.08
FACE_MIN_AREA_RATIO=0.022
FACE_MULTI_MIN_RATIO=0.8
FACE_MULTI_SECONDARY_ABS_RATIO_FACTOR=0.75
FACE_MIN_BRIGHTNESS=50
FACE_MIN_LAPLACIAN_VAR=30
