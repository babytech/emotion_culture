API_ENV=development
API_PORT=9000

# WeChat cloud file download (cloud://fileid -> temp URL)
WECHAT_APP_ID=wx_your_app_id
WECHAT_APP_SECRET=your_app_secret
WECHAT_CLOUDBASE_ENV=your-cloudbase-env-id

# SMTP settings (used by backend email module at runtime).
# For local backend debug, fill these values in services/wechat-api/.env.
EMAIL_SENDER_ADDRESS=your_sender@example.com
EMAIL_SENDER_PASSWORD=your_app_password
SMTP_SERVER_HOST=smtp.gmail.com
SMTP_SERVER_PORT=587

# Speech-to-text (BE-010) settings.
# provider: auto | http | mock
SPEECH_STT_PROVIDER=auto

# Used when provider=http, or provider=auto with endpoint configured.
SPEECH_STT_ENDPOINT=
SPEECH_STT_TOKEN=
SPEECH_STT_TIMEOUT_SEC=18

# Used only when provider=mock (local validation).
SPEECH_STT_MOCK_TEXT=

# Face quality gate (BE-012).
FACE_MIN_AREA_RATIO=0.06
FACE_MIN_BRIGHTNESS=55
FACE_MIN_LAPLACIAN_VAR=45
